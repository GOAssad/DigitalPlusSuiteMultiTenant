@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Persistence
@using Microsoft.EntityFrameworkCore
@implements IDisposable
@inject ILicenciaService LicenciaService
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ITenantService Tenant
@inject NavigationManager Nav

@if (alertas.Count > 0)
{
    @foreach (var alerta in alertas)
    {
        <div class="alert @alerta.CssClass @(alerta.NoDismiss ? "" : "alert-dismissible") m-3 mb-0 d-flex align-items-center" role="alert">
            <i class="bi @alerta.Icono me-2 fs-5"></i>
            <div class="flex-grow-1">
                @alerta.Mensaje
                @if (!string.IsNullOrEmpty(alerta.LinkTexto))
                {
                    <a href="@alerta.LinkUrl" class="alert-link ms-1">@alerta.LinkTexto</a>
                }
            </div>
        </div>
    }
}

@code {
    private List<AlertaLicencia> alertas = new();

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        await CargarAlertas();
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (e.Location.Contains("upgraded"))
        {
            var empresaId = Tenant.EmpresaId;
            if (empresaId > 0) LicenciaService.InvalidarCache(empresaId);
        }
        await CargarAlertas();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }

    private async Task CargarAlertas()
    {
        alertas.Clear();
        try
        {
            var empresaId = Tenant.EmpresaId;
            if (empresaId == 0) return;

            var licencia = await LicenciaService.GetLicenciaInfoAsync(empresaId);

            await using var db = await DbFactory.CreateDbContextAsync();

            // 1. Fichadas
            if (!licencia.EsIlimitado(licencia.MaxFichadasMes))
            {
                var hace30d = DateTime.Now.AddDays(-30);
                var fichadasUlt30d = await db.Fichadas.CountAsync(f => f.FechaHora >= hace30d);
                var porcentaje = licencia.MaxFichadasMes > 0 ? (fichadasUlt30d * 100 / licencia.MaxFichadasMes) : 0;

                if (fichadasUlt30d >= licencia.MaxFichadasMes)
                {
                    alertas.Add(new AlertaLicencia
                    {
                        CssClass = "alert-danger",
                        Icono = "bi-exclamation-octagon",
                        Mensaje = $"Se alcanzó el límite de fichadas del plan {licencia.PlanDisplay} ({fichadasUlt30d}/{licencia.MaxFichadasMes} en los últimos 30 días). No se pueden registrar nuevas fichadas.",
                        LinkTexto = "Mejorar plan",
                        LinkUrl = "/configuracion/planes"
                    });
                }
                else if (porcentaje >= 80)
                {
                    alertas.Add(new AlertaLicencia
                    {
                        CssClass = "alert-warning",
                        Icono = "bi-exclamation-triangle",
                        Mensaje = $"Se utilizaron {fichadasUlt30d} de {licencia.MaxFichadasMes} fichadas permitidas en los últimos 30 días ({porcentaje}%).",
                        LinkTexto = "Mejorar plan",
                        LinkUrl = "/configuracion/planes"
                    });
                }
            }

            // 2. Legajos
            if (!licencia.EsIlimitado(licencia.MaxLegajos))
            {
                var legajosActivos = await db.Legajos.CountAsync(l => l.IsActive);

                if (legajosActivos >= licencia.MaxLegajos)
                {
                    alertas.Add(new AlertaLicencia
                    {
                        CssClass = "alert-danger",
                        Icono = "bi-people-fill",
                        Mensaje = $"Se alcanzó el límite de legajos del plan {licencia.PlanDisplay} ({legajosActivos}/{licencia.MaxLegajos}). No se pueden crear nuevos legajos.",
                        LinkTexto = "Mejorar plan",
                        LinkUrl = "/configuracion/planes"
                    });
                }
            }

            // 3. Sucursales
            if (!licencia.EsIlimitado(licencia.MaxSucursales))
            {
                var sucursalesActivas = await db.Sucursales.CountAsync();

                if (sucursalesActivas >= licencia.MaxSucursales)
                {
                    alertas.Add(new AlertaLicencia
                    {
                        CssClass = "alert-danger",
                        Icono = "bi-building-fill-exclamation",
                        Mensaje = $"Se alcanzó el límite de sucursales del plan {licencia.PlanDisplay} ({sucursalesActivas}/{licencia.MaxSucursales}). No se pueden crear nuevas sucursales.",
                        LinkTexto = "Mejorar plan",
                        LinkUrl = "/configuracion/planes"
                    });
                }
            }

            // 4. Terminales móviles
            if (!licencia.EsIlimitado(licencia.MaxTerminalesMoviles))
            {
                var terminalesActivas = await db.TerminalesMoviles
                    .IgnoreQueryFilters()
                    .CountAsync(t => t.EmpresaId == empresaId && t.Activo);

                if (terminalesActivas >= licencia.MaxTerminalesMoviles)
                {
                    alertas.Add(new AlertaLicencia
                    {
                        CssClass = "alert-warning",
                        Icono = "bi-phone-fill",
                        Mensaje = $"Se alcanzó el límite de terminales móviles del plan {licencia.PlanDisplay} ({terminalesActivas}/{licencia.MaxTerminalesMoviles}).",
                        LinkTexto = "Mejorar plan",
                        LinkUrl = "/configuracion/planes"
                    });
                }
            }

            // 5. Suscripción cancelada (sigue activa hasta vencimiento)
            if (licencia.SuscripcionCancelada && licencia.PlanVencimiento.HasValue)
            {
                var diasRestantes = (licencia.PlanVencimiento.Value - DateTime.UtcNow).Days;
                var fechaVenc = licencia.PlanVencimiento.Value.ToString("dd/MM/yyyy");

                if (diasRestantes <= 0)
                {
                    // Suscripción ya expiró — el sistema se suspenderá automáticamente
                    alertas.Insert(0, new AlertaLicencia
                    {
                        CssClass = "alert-danger",
                        Icono = "bi-exclamation-octagon",
                        Mensaje = $"Tu plan {licencia.PlanDisplay} ha expirado. El sistema quedará inactivo en breve. Contratá un plan para mantener el acceso.",
                        LinkTexto = "Contratar plan",
                        LinkUrl = "/configuracion/planes",
                        NoDismiss = true
                    });
                }
                else if (diasRestantes <= 7)
                {
                    alertas.Insert(0, new AlertaLicencia
                    {
                        CssClass = "alert-danger",
                        Icono = "bi-exclamation-octagon",
                        Mensaje = $"Tu plan {licencia.PlanDisplay} expira en {diasRestantes} día{(diasRestantes == 1 ? "" : "s")} ({fechaVenc}). Después el sistema quedará inactivo.",
                        LinkTexto = "Contratar plan",
                        LinkUrl = "/configuracion/planes",
                        NoDismiss = true
                    });
                }
                else
                {
                    alertas.Insert(0, new AlertaLicencia
                    {
                        CssClass = "alert-warning",
                        Icono = "bi-clock-history",
                        Mensaje = $"Tu plan {licencia.PlanDisplay} expira el {fechaVenc}. Después de esa fecha el sistema quedará inactivo.",
                        LinkTexto = "Contratar plan",
                        LinkUrl = "/configuracion/planes",
                        NoDismiss = true
                    });
                }
            }

            // 6. Licencia expirada o suspendida
            if (licencia.LicenseType == "suspended")
            {
                alertas.Insert(0, new AlertaLicencia
                {
                    CssClass = "alert-danger",
                    Icono = "bi-shield-exclamation",
                    Mensaje = "La licencia de esta empresa se encuentra suspendida. Contacte a soporte para reactivarla.",
                    LinkTexto = "Contactar soporte",
                    LinkUrl = "/configuracion/planes"
                });
            }
            else if (licencia.ExpiresAt.HasValue && licencia.ExpiresAt.Value < DateTime.UtcNow)
            {
                alertas.Insert(0, new AlertaLicencia
                {
                    CssClass = "alert-danger",
                    Icono = "bi-calendar-x",
                    Mensaje = $"La licencia venció el {licencia.ExpiresAt.Value:dd/MM/yyyy}. Renueve su plan para continuar operando.",
                    LinkTexto = "Renovar plan",
                    LinkUrl = "/configuracion/planes"
                });
            }
            else if (licencia.ExpiresAt.HasValue && licencia.ExpiresAt.Value < DateTime.UtcNow.AddDays(7))
            {
                alertas.Insert(0, new AlertaLicencia
                {
                    CssClass = "alert-warning",
                    Icono = "bi-calendar-event",
                    Mensaje = $"La licencia vence el {licencia.ExpiresAt.Value:dd/MM/yyyy}. Renueve pronto para evitar interrupciones.",
                    LinkTexto = "Renovar plan",
                    LinkUrl = "/configuracion/planes"
                });
            }
        }
        catch
        {
            // No bloquear el portal si falla la consulta de licencia
        }
    }

    private class AlertaLicencia
    {
        public string CssClass { get; set; } = "alert-warning";
        public string Icono { get; set; } = "bi-exclamation-triangle";
        public string Mensaje { get; set; } = "";
        public string? LinkTexto { get; set; }
        public string? LinkUrl { get; set; }
        public bool NoDismiss { get; set; }
    }
}
