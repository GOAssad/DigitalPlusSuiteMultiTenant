@page "/feriados/crear"
@page "/feriados/editar/{Id:int}"
@inherits DigitalPlusMultiTenant.Web.Components.DbComponentBase
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize]
@rendermode InteractiveServer

@inject NavigationManager Nav

<PageTitle>@(IsEdit ? "Editar" : "Nuevo") Feriado - DigitalPlus</PageTitle>

<div class="d-flex align-items-center mb-3">
    <a href="feriados" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">@(IsEdit ? "Editar" : "Nuevo") Feriado</h4>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <EditForm Model="model" OnValidSubmit="Save" FormName="feriadoForm">
            <DataAnnotationsValidator />
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Fecha</label>
                    <InputDate @bind-Value="model.Fecha" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Nombre</label>
                    <InputText @bind-Value="model.Nombre" class="form-control" />
                    <ValidationMessage For="() => model.Nombre" class="text-danger small" />
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary me-2"><i class="bi bi-check-lg me-1"></i>Guardar</button>
                <a href="feriados" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </EditForm>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    private bool IsEdit => Id > 0;
    private Feriado model = new() { Fecha = DateOnly.FromDateTime(DateTime.Today) };
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (IsEdit) { var e = await Db.Feriados.FindAsync(Id); if (e == null) { Nav.NavigateTo("feriados"); return; } model = e; }
    }

    private async Task Save()
    {
        try { if (!IsEdit) Db.Feriados.Add(model); await Db.SaveChangesAsync(); Nav.NavigateTo("feriados"); }
        catch (DbUpdateException ex) { errorMessage = ex.InnerException?.Message ?? ex.Message; }
    }
}
