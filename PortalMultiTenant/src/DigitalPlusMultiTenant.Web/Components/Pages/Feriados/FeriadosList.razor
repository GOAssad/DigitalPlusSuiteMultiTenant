@page "/feriados"
@inherits DigitalPlusMultiTenant.Web.Components.DbComponentBase
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize]
@rendermode InteractiveServer

@inject IJSRuntime JS
@inject ITenantService Tenant
@using DigitalPlusMultiTenant.Web.Helpers

<PageTitle>Feriados - DigitalPlus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-calendar-event me-2"></i>Feriados</h4>
    <div>
        <button class="btn btn-outline-secondary btn-sm me-2" @onclick="CargarDatos" title="Actualizar"><i class="bi bi-arrow-clockwise"></i></button>
        @if (items?.Any() == true)
        {
            <button class="btn btn-outline-success btn-sm me-1" @onclick="ExportarExcel"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
            <button class="btn btn-outline-secondary btn-sm me-2" @onclick="ExportarCsv"><i class="bi bi-filetype-csv me-1"></i>CSV</button>
        }
        <AuthorizeView Roles="SuperAdmin,AdminEmpresa">
            <a href="feriados/crear" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Nuevo Feriado</a>
        </AuthorizeView>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small mb-1">Buscar</label>
                <input type="text" class="form-control form-control-sm" placeholder="Nombre..."
                       @bind="filtro" @bind:event="oninput" @bind:after="BuscarDebounce" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Año</label>
                <input type="number" class="form-control form-control-sm" @bind="anio" @bind:after="Buscar" />
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th role="button" @onclick='() => SetOrden("fecha")'>
                            Fecha @SortIcon("fecha")
                        </th>
                        <th>Dia</th>
                        <th role="button" @onclick='() => SetOrden("nombre")'>
                            Nombre @SortIcon("nombre")
                        </th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (items == null)
                    {
                        <tr><td colspan="4" class="text-center py-4"><DigitalPlusMultiTenant.Web.Components.Shared.LoadingIndicator Small="true" Message="" /></td></tr>
                    }
                    else if (!items.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>No hay feriados cargados</td></tr>
                    }
                    else
                    {
                        @foreach (var f in items)
                        {
                            <tr>
                                <td>@f.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@f.Fecha.ToString("dddd", new System.Globalization.CultureInfo("es-AR"))</td>
                                <td>@f.Nombre</td>
                                <td class="text-end">
                                    <AuthorizeView Roles="SuperAdmin,AdminEmpresa">
                                        <a href="feriados/editar/@f.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                        @if (confirmEliminarId == f.Id)
                                        {
                                            <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(f)"><i class="bi bi-check-lg me-1"></i>Confirmar</button>
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => confirmEliminarId = 0"><i class="bi bi-x-lg"></i></button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => confirmEliminarId = f.Id"><i class="bi bi-trash"></i></button>
                                        }
                                    </AuthorizeView>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<Feriado>? items;
    private string filtro = "";
    private int anio = Clock.Today.Year;
    private string ordenColumna = "fecha";
    private bool ordenDesc;
    private CancellationTokenSource? _debounceToken;

    protected override async Task OnInitializedAsync() => await CargarDatos();

    private async Task BuscarDebounce()
    {
        _debounceToken?.Cancel();
        _debounceToken = new CancellationTokenSource();
        try { await Task.Delay(300, _debounceToken.Token); await CargarDatos(); }
        catch (TaskCanceledException) { }
    }

    private async Task Buscar() => await CargarDatos();

    private async Task SetOrden(string columna)
    {
        if (ordenColumna == columna) ordenDesc = !ordenDesc;
        else { ordenColumna = columna; ordenDesc = false; }
        await CargarDatos();
    }

    private MarkupString SortIcon(string columna)
    {
        if (ordenColumna != columna)
            return new MarkupString("<i class=\"bi bi-chevron-expand text-muted small\"></i>");
        return ordenDesc
            ? new MarkupString("<i class=\"bi bi-sort-down\"></i>")
            : new MarkupString("<i class=\"bi bi-sort-up\"></i>");
    }

    private async Task CargarDatos()
    {
        var desde = new DateOnly(anio, 1, 1);
        var hasta = new DateOnly(anio, 12, 31);
        var query = Db.Feriados.Where(f => f.Fecha >= desde && f.Fecha <= hasta);

        if (!string.IsNullOrWhiteSpace(filtro))
        {
            var f = filtro.Trim().ToLower();
            query = query.Where(fe => fe.Nombre.ToLower().Contains(f));
        }

        var ordered = ordenColumna switch
        {
            "nombre" => ordenDesc ? query.OrderByDescending(f => f.Nombre) : query.OrderBy(f => f.Nombre),
            _ => ordenDesc ? query.OrderByDescending(f => f.Fecha) : query.OrderBy(f => f.Fecha),
        };

        items = await ordered.ToListAsync();
    }

    private async Task ExportarExcel()
    {
        if (items == null) return;
        var filtros = new List<string>();
        if (!string.IsNullOrWhiteSpace(filtro)) filtros.Add($"Busqueda: {filtro}");
        var bytes = ExcelExporter.Generar(items,
            new ExcelExportConfig { Titulo = "Feriados", NombreEmpresa = Tenant.EmpresaNombre, FechaDesde = $"Año {anio}", Filtros = filtros,
                Encabezados = ["Fecha", "Dia", "Nombre"],
                Formatos = [ExcelColFormat.Fecha, ExcelColFormat.Texto, ExcelColFormat.Texto] },
            f => [f.Fecha, f.Fecha.ToString("dddd", new System.Globalization.CultureInfo("es-AR")), f.Nombre]);
        await JS.InvokeVoidAsync("downloadFile", "feriados.xlsx", Convert.ToBase64String(bytes), "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    private async Task ExportarCsv()
    {
        if (items == null) return;
        var bytes = CsvExporter.ToCsvBytes(items,
            ["Fecha", "Dia", "Nombre"],
            f => [f.Fecha.ToString("dd/MM/yyyy"),
                  f.Fecha.ToString("dddd", new System.Globalization.CultureInfo("es-AR")), f.Nombre]);
        await JS.InvokeVoidAsync("downloadFile", "feriados.csv", Convert.ToBase64String(bytes), "text/csv");
    }

    private int confirmEliminarId;

    private async Task Eliminar(Feriado f)
    {
        Db.Feriados.Remove(f);
        await Db.SaveChangesAsync();
        confirmEliminarId = 0;
        await CargarDatos();
    }
}
