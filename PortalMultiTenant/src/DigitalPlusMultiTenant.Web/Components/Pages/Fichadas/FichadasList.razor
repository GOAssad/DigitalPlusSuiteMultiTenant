@page "/fichadas"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize]
@rendermode InteractiveServer

@inject IApplicationDbContext Db

<PageTitle>Fichadas - DigitalPlus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-card-checklist me-2"></i>Fichadas</h4>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small mb-1">Desde</label>
                <input type="date" class="form-control form-control-sm" @bind="fechaDesde" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Hasta</label>
                <input type="date" class="form-control form-control-sm" @bind="fechaHasta" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Sucursal</label>
                <select class="form-select form-select-sm" @bind="filtroSucursal">
                    <option value="0">Todas</option>
                    @foreach (var s in sucursales)
                    {
                        <option value="@s.Id">@s.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Legajo</label>
                <input type="text" class="form-control form-control-sm" placeholder="Nombre o nro legajo..."
                       @bind="filtro" />
            </div>
            <div class="col-md-1">
                <label class="form-label small mb-1">Tipo</label>
                <select class="form-select form-select-sm" @bind="filtroTipo">
                    <option value="">Todos</option>
                    <option value="E">Entrada</option>
                    <option value="S">Salida</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary btn-sm" @onclick="Buscar">
                    <i class="bi bi-search me-1"></i>Buscar
                </button>
            </div>
        </div>
    </div>
</div>

@if (buscando)
{
    <div class="text-center py-4"><div class="spinner-border"></div><div class="mt-2">Buscando...</div></div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th role="button" @onclick='() => SetOrden("legajo")'>
                                Legajo @SortIcon("legajo")
                            </th>
                            <th role="button" @onclick='() => SetOrden("nombre")'>
                                Apellido y Nombre @SortIcon("nombre")
                            </th>
                            <th role="button" @onclick='() => SetOrden("sucursal")'>
                                Sucursal @SortIcon("sucursal")
                            </th>
                            <th role="button" @onclick='() => SetOrden("fecha")'>
                                Fecha @SortIcon("fecha")
                            </th>
                            <th>Hora</th>
                            <th role="button" @onclick='() => SetOrden("tipo")'>
                                Tipo @SortIcon("tipo")
                            </th>
                            <th>Origen</th>
                            <th>Terminal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (fichadas == null || !fichadas.Any())
                        {
                            <tr><td colspan="8" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                @(fichadas == null ? "Seleccione un rango de fechas y presione Buscar" : "No hay fichadas en el periodo")
                            </td></tr>
                        }
                        else
                        {
                            @foreach (var f in fichadas)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">@f.Legajo?.NumeroLegajo</span></td>
                                    <td><strong>@f.Legajo?.Apellido</strong>, @f.Legajo?.Nombre</td>
                                    <td>@f.Sucursal?.Nombre</td>
                                    <td>@f.FechaHora.ToString("dd/MM/yyyy")</td>
                                    <td>@f.FechaHora.ToString("HH:mm:ss")</td>
                                    <td>
                                        <span class="badge @(f.Tipo == "E" ? "bg-success" : "bg-danger")">
                                            @(f.Tipo == "E" ? "Entrada" : "Salida")
                                        </span>
                                    </td>
                                    <td>@f.Origen</td>
                                    <td>@f.Terminal?.Nombre</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (totalRegistros > 0)
        {
            <div class="card-footer d-flex justify-content-between align-items-center">
                <span class="text-muted small">
                    Mostrando @((pagina - 1) * pageSize + 1)-@Math.Min(pagina * pageSize, totalRegistros) de @totalRegistros.ToString("N0") registros
                </span>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(pagina <= 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => IrPagina(1)" disabled="@(pagina <= 1)">
                                <i class="bi bi-chevron-double-left"></i>
                            </button>
                        </li>
                        <li class="page-item @(pagina <= 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => IrPagina(pagina - 1)" disabled="@(pagina <= 1)">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                        </li>

                        @foreach (var p in GetPaginasVisibles())
                        {
                            <li class="page-item @(p == pagina ? "active" : "")">
                                <button class="page-link" @onclick="() => IrPagina(p)">@p</button>
                            </li>
                        }

                        <li class="page-item @(pagina >= totalPaginas ? "disabled" : "")">
                            <button class="page-link" @onclick="() => IrPagina(pagina + 1)" disabled="@(pagina >= totalPaginas)">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </li>
                        <li class="page-item @(pagina >= totalPaginas ? "disabled" : "")">
                            <button class="page-link" @onclick="() => IrPagina(totalPaginas)" disabled="@(pagina >= totalPaginas)">
                                <i class="bi bi-chevron-double-right"></i>
                            </button>
                        </li>

                        <li class="page-item disabled ms-2">
                            <span class="page-link bg-transparent border-0 text-muted">
                                Pag @pagina de @totalPaginas
                            </span>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
}

@code {
    private List<Fichada>? fichadas;
    private List<Sucursal> sucursales = new();
    private DateTime fechaDesde = DateTime.Today;
    private DateTime fechaHasta = DateTime.Today;
    private string filtro = "";
    private int filtroSucursal;
    private string filtroTipo = "";
    private bool buscando;

    // Paginacion
    private const int pageSize = 50;
    private int pagina = 1;
    private int totalRegistros;
    private int totalPaginas;

    // Ordenamiento
    private string ordenColumna = "fecha";
    private bool ordenDesc = true;

    protected override async Task OnInitializedAsync()
    {
        sucursales = await Db.Sucursales.Where(s => s.IsActive).OrderBy(s => s.Nombre).ToListAsync();
    }

    private async Task Buscar()
    {
        pagina = 1;
        await CargarDatos();
    }

    private async Task IrPagina(int p)
    {
        pagina = p;
        await CargarDatos();
    }

    private async Task SetOrden(string columna)
    {
        if (ordenColumna == columna)
            ordenDesc = !ordenDesc;
        else
        {
            ordenColumna = columna;
            ordenDesc = columna == "fecha";
        }
        pagina = 1;
        await CargarDatos();
    }

    private MarkupString SortIcon(string columna)
    {
        if (ordenColumna != columna)
            return new MarkupString("<i class=\"bi bi-chevron-expand text-muted small\"></i>");
        return ordenDesc
            ? new MarkupString("<i class=\"bi bi-sort-down\"></i>")
            : new MarkupString("<i class=\"bi bi-sort-up\"></i>");
    }

    private async Task CargarDatos()
    {
        buscando = true;
        StateHasChanged();

        try
        {
            var desde = fechaDesde.Date;
            var hasta = fechaHasta.Date.AddDays(1);

            var query = Db.Fichadas
                .Include(f => f.Legajo)
                .Include(f => f.Sucursal)
                .Include(f => f.Terminal)
                .Where(f => f.FechaHora >= desde && f.FechaHora < hasta);

            if (filtroSucursal > 0)
                query = query.Where(f => f.SucursalId == filtroSucursal);

            if (!string.IsNullOrWhiteSpace(filtroTipo))
                query = query.Where(f => f.Tipo == filtroTipo);

            if (!string.IsNullOrWhiteSpace(filtro))
            {
                var f = filtro.Trim().ToLower();
                query = query.Where(x => x.Legajo!.Apellido.ToLower().Contains(f)
                    || x.Legajo!.Nombre.ToLower().Contains(f)
                    || x.Legajo!.NumeroLegajo.ToLower().Contains(f));
            }

            totalRegistros = await query.CountAsync();
            totalPaginas = Math.Max(1, (int)Math.Ceiling(totalRegistros / (double)pageSize));
            if (pagina > totalPaginas) pagina = totalPaginas;

            var ordered = ordenColumna switch
            {
                "legajo" => ordenDesc ? query.OrderByDescending(f => f.Legajo!.NumeroLegajo) : query.OrderBy(f => f.Legajo!.NumeroLegajo),
                "nombre" => ordenDesc ? query.OrderByDescending(f => f.Legajo!.Apellido).ThenByDescending(f => f.Legajo!.Nombre) : query.OrderBy(f => f.Legajo!.Apellido).ThenBy(f => f.Legajo!.Nombre),
                "sucursal" => ordenDesc ? query.OrderByDescending(f => f.Sucursal!.Nombre) : query.OrderBy(f => f.Sucursal!.Nombre),
                "tipo" => ordenDesc ? query.OrderByDescending(f => f.Tipo) : query.OrderBy(f => f.Tipo),
                _ => ordenDesc ? query.OrderByDescending(f => f.FechaHora) : query.OrderBy(f => f.FechaHora),
            };

            fichadas = await ordered
                .Skip((pagina - 1) * pageSize)
                .Take(pageSize)
                .ToListAsync();
        }
        finally
        {
            buscando = false;
        }
    }

    private IEnumerable<int> GetPaginasVisibles()
    {
        var start = Math.Max(1, pagina - 2);
        var end = Math.Min(totalPaginas, pagina + 2);

        // Asegurar al menos 5 paginas visibles si hay suficientes
        if (end - start < 4)
        {
            if (start == 1) end = Math.Min(totalPaginas, start + 4);
            else start = Math.Max(1, end - 4);
        }

        for (var i = start; i <= end; i++)
            yield return i;
    }
}
