@page "/usuarios/crear"
@page "/usuarios/editar/{Id}"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize(Roles = "SuperAdmin,AdminEmpresa")]
@rendermode InteractiveServer

@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject ITenantService Tenant
@inject NavigationManager Nav

<PageTitle>@(IsEdit ? "Editar" : "Nuevo") Usuario - DigitalPlus</PageTitle>

<div class="d-flex align-items-center mb-3">
    <a href="usuarios" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">@(IsEdit ? "Editar" : "Nuevo") Usuario</h4>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <EditForm Model="model" OnValidSubmit="Save" FormName="usuarioForm">
            <DataAnnotationsValidator />
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Email</label>
                    <InputText @bind-Value="model.Email" class="form-control" disabled="@IsEdit" />
                    <ValidationMessage For="() => model.Email" class="text-danger small" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Nombre Completo</label>
                    <InputText @bind-Value="model.NombreCompleto" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Rol</label>
                    <InputSelect @bind-Value="model.Rol" class="form-select">
                        <option value="">-- Seleccionar --</option>
                        @foreach (var r in roles)
                        {
                            <option value="@r">@r — @DescripcionRol(r)</option>
                        }
                    </InputSelect>
                    @if (!string.IsNullOrEmpty(model.Rol))
                    {
                        <small class="text-muted mt-1 d-block"><i class="bi bi-info-circle me-1"></i>@DescripcionRol(model.Rol)</small>
                    }
                </div>
                @if (!IsEdit)
                {
                    <div class="col-md-4">
                        <label class="form-label">Contraseña</label>
                        <InputText type="password" @bind-Value="model.Password" class="form-control" />
                        <ValidationMessage For="() => model.Password" class="text-danger small" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Confirmar Contraseña</label>
                        <InputText type="password" @bind-Value="model.ConfirmPassword" class="form-control" />
                        <ValidationMessage For="() => model.ConfirmPassword" class="text-danger small" />
                    </div>
                }
                <div class="col-md-3">
                    <label class="form-label">Estado</label>
                    <div class="form-check form-switch mt-2">
                        <InputCheckbox @bind-Value="model.IsActive" class="form-check-input" />
                        <label class="form-check-label">Activo</label>
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Escritorio</label>
                    <div class="form-check form-switch mt-2">
                        <InputCheckbox @bind-Value="model.AccesoAdminDesktop" class="form-check-input" />
                        <label class="form-check-label">Acceso Administrador desktop</label>
                    </div>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary me-2"><i class="bi bi-check-lg me-1"></i>Guardar</button>
                <a href="usuarios" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </EditForm>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success mt-3">@successMessage</div>
        }
    </div>
</div>

@if (IsEdit)
{
    <div class="card border-0 shadow-sm mt-3">
        <div class="card-body">
            <h6>Cambiar Contraseña</h6>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Nueva Contraseña</label>
                    <input type="password" class="form-control" @bind="newPassword" />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button class="btn btn-warning" @onclick="ChangePassword"><i class="bi bi-key me-1"></i>Cambiar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string? Id { get; set; }
    private bool IsEdit => !string.IsNullOrEmpty(Id);
    private UsuarioModel model = new() { IsActive = true };
    private List<string> roles = new();
    private string? errorMessage;
    private string? successMessage;
    private string? newPassword;

    protected override async Task OnInitializedAsync()
    {
        roles = await RoleManager.Roles
            .Where(r => r.Name != "SuperAdmin")
            .Select(r => r.Name!).OrderBy(r => r).ToListAsync();

        if (IsEdit)
        {
            var user = await UserManager.FindByIdAsync(Id!);
            if (user == null || user.EmpresaId != Tenant.EmpresaId) { Nav.NavigateTo("usuarios"); return; }
            model.Email = user.Email ?? "";
            model.NombreCompleto = user.NombreCompleto;
            model.IsActive = user.IsActive;
            model.AccesoAdminDesktop = user.AccesoAdminDesktop;
            var userRoles = await UserManager.GetRolesAsync(user);
            model.Rol = userRoles.FirstOrDefault();
            // Si el rol actual no esta en la lista (ej: SuperAdmin), agregarlo para que el combo lo muestre
            if (!string.IsNullOrEmpty(model.Rol) && !roles.Contains(model.Rol))
                roles.Insert(0, model.Rol);
        }
    }

    private async Task Save()
    {
        errorMessage = null; successMessage = null;
        try
        {
            if (IsEdit)
            {
                var user = await UserManager.FindByIdAsync(Id!);
                if (user == null) { errorMessage = "Usuario no encontrado"; return; }
                user.NombreCompleto = model.NombreCompleto;
                user.IsActive = model.IsActive;
                user.AccesoAdminDesktop = model.AccesoAdminDesktop;
                var result = await UserManager.UpdateAsync(user);
                if (!result.Succeeded) { errorMessage = string.Join(", ", result.Errors.Select(e => e.Description)); return; }

                var currentRoles = await UserManager.GetRolesAsync(user);
                if (currentRoles.Any()) await UserManager.RemoveFromRolesAsync(user, currentRoles);
                if (!string.IsNullOrEmpty(model.Rol)) await UserManager.AddToRoleAsync(user, model.Rol);

                successMessage = "Usuario actualizado";
            }
            else
            {
                if (string.IsNullOrEmpty(model.Password)) { errorMessage = "La contraseña es requerida"; return; }
                if (model.Password != model.ConfirmPassword) { errorMessage = "Las contraseñas no coinciden"; return; }

                var user = new ApplicationUser
                {
                    UserName = model.Email,
                    Email = model.Email,
                    NombreCompleto = model.NombreCompleto,
                    EmpresaId = Tenant.EmpresaId,
                    IsActive = model.IsActive,
                    AccesoAdminDesktop = model.AccesoAdminDesktop,
                    CreatedAt = DateTime.UtcNow
                };
                var result = await UserManager.CreateAsync(user, model.Password);
                if (!result.Succeeded) { errorMessage = string.Join(", ", result.Errors.Select(e => e.Description)); return; }

                if (!string.IsNullOrEmpty(model.Rol)) await UserManager.AddToRoleAsync(user, model.Rol);

                Nav.NavigateTo("usuarios");
            }
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task ChangePassword()
    {
        errorMessage = null; successMessage = null;
        if (string.IsNullOrEmpty(newPassword)) { errorMessage = "Ingrese la nueva contraseña"; return; }
        var user = await UserManager.FindByIdAsync(Id!);
        if (user == null) { errorMessage = "Usuario no encontrado"; return; }
        var token = await UserManager.GeneratePasswordResetTokenAsync(user);
        var result = await UserManager.ResetPasswordAsync(user, token, newPassword);
        if (!result.Succeeded) { errorMessage = string.Join(", ", result.Errors.Select(e => e.Description)); return; }
        successMessage = "Contraseña actualizada";
        newPassword = null;
    }

    private static string DescripcionRol(string rol) => rol switch
    {
        "AdminEmpresa" => "Acceso total a la empresa",
        "Operador" => "Gestiona legajos, fichadas y vacaciones",
        "Consulta" => "Solo lectura, reportes y exportacion",
        _ => ""
    };

    private class UsuarioModel
    {
        [Required(ErrorMessage = "El email es requerido")]
        [EmailAddress(ErrorMessage = "Email no valido")]
        public string Email { get; set; } = "";
        public string? NombreCompleto { get; set; }
        public string? Rol { get; set; }
        public string? Password { get; set; }
        public string? ConfirmPassword { get; set; }
        public bool IsActive { get; set; }
        public bool AccesoAdminDesktop { get; set; }
    }
}
