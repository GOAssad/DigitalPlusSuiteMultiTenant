@page "/usuarios"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize(Roles = "SuperAdmin,AdminEmpresa")]
@rendermode InteractiveServer

@inject UserManager<ApplicationUser> UserManager
@inject ITenantService Tenant

<PageTitle>Usuarios - DigitalPlus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-people me-2"></i>Usuarios</h4>
    <a href="usuarios/crear" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Nuevo Usuario</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Email</th>
                    <th>Nombre</th>
                    <th>Rol</th>
                    <th>Activo</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (items == null)
                {
                    <tr><td colspan="5" class="text-center py-4"><div class="spinner-border spinner-border-sm"></div></td></tr>
                }
                else if (!items.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>No hay usuarios</td></tr>
                }
                else
                {
                    @foreach (var u in items)
                    {
                        <tr class="@(!u.User.IsActive ? "table-secondary" : "")">
                            <td>@u.User.Email</td>
                            <td>@u.User.NombreCompleto</td>
                            <td><span class="badge bg-info">@u.Role</span></td>
                            <td>
                                @if (u.User.IsActive)
                                { <span class="badge bg-success">Si</span> }
                                else
                                { <span class="badge bg-secondary">No</span> }
                            </td>
                            <td class="text-end">
                                <a href="usuarios/editar/@u.User.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<UserViewModel>? items;

    protected override async Task OnInitializedAsync()
    {
        var empresaId = Tenant.EmpresaId;
        var users = await UserManager.Users.Where(u => u.EmpresaId == empresaId).OrderBy(u => u.Email).ToListAsync();
        items = new List<UserViewModel>();
        foreach (var u in users)
        {
            var roles = await UserManager.GetRolesAsync(u);
            items.Add(new UserViewModel { User = u, Role = roles.FirstOrDefault() ?? "Sin rol" });
        }
    }

    private class UserViewModel
    {
        public ApplicationUser User { get; set; } = null!;
        public string Role { get; set; } = "";
    }
}
