@page "/configuracion"
@inherits DigitalPlusMultiTenant.Web.Components.DbComponentBase
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize(Roles = "SuperAdmin,AdminEmpresa")]
@rendermode InteractiveServer

<PageTitle>Configuracion - DigitalPlus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-gear me-2"></i>Configuracion</h4>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small mb-1">Buscar</label>
                <input type="text" class="form-control form-control-sm" placeholder="Clave o descripcion..."
                       @bind="filtro" @bind:event="oninput" @bind:after="BuscarDebounce" />
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th role="button" @onclick='() => SetOrden("clave")'>
                            Clave @SortIcon("clave")
                        </th>
                        <th role="button" @onclick='() => SetOrden("descripcion")'>
                            Descripcion @SortIcon("descripcion")
                        </th>
                        <th>Valor</th>
                        <th role="button" @onclick='() => SetOrden("tipo")'>
                            Tipo @SortIcon("tipo")
                        </th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (items == null)
                    {
                        <tr><td colspan="5" class="text-center py-4"><DigitalPlusMultiTenant.Web.Components.Shared.LoadingIndicator Small="true" Message="" /></td></tr>
                    }
                    else if (!items.Any())
                    {
                        <tr><td colspan="5" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>No hay variables configuradas</td></tr>
                    }
                    else
                    {
                        @foreach (var v in items)
                        {
                            <tr>
                                <td><code>@v.Clave</code></td>
                                <td>@v.Descripcion</td>
                                <td>
                                    @if (editingId == v.Id)
                                    {
                                        <input type="text" class="form-control form-control-sm" @bind="editValue" style="max-width:300px" />
                                    }
                                    else
                                    {
                                        @v.Valor
                                    }
                                </td>
                                <td><span class="badge bg-light text-dark">@v.TipoValor</span></td>
                                <td class="text-end">
                                    @if (editingId == v.Id)
                                    {
                                        <button class="btn btn-sm btn-success me-1" @onclick="() => SaveVariable(v)"><i class="bi bi-check-lg"></i></button>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEdit"><i class="bi bi-x-lg"></i></button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEdit(v)"><i class="bi bi-pencil"></i></button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(isError ? "alert-danger" : "alert-success") mt-3">@message</div>
}

@code {
    private List<VariableSistema>? items;
    private string filtro = "";
    private string ordenColumna = "clave";
    private bool ordenDesc;
    private int? editingId;
    private string? editValue;
    private string? message;
    private bool isError;
    private CancellationTokenSource? _debounceToken;

    protected override async Task OnInitializedAsync() => await CargarDatos();

    private async Task BuscarDebounce()
    {
        _debounceToken?.Cancel();
        _debounceToken = new CancellationTokenSource();
        try { await Task.Delay(300, _debounceToken.Token); await CargarDatos(); }
        catch (TaskCanceledException) { }
    }

    private async Task SetOrden(string columna)
    {
        if (ordenColumna == columna) ordenDesc = !ordenDesc;
        else { ordenColumna = columna; ordenDesc = false; }
        await CargarDatos();
    }

    private MarkupString SortIcon(string columna)
    {
        if (ordenColumna != columna)
            return new MarkupString("<i class=\"bi bi-chevron-expand text-muted small\"></i>");
        return ordenDesc
            ? new MarkupString("<i class=\"bi bi-sort-down\"></i>")
            : new MarkupString("<i class=\"bi bi-sort-up\"></i>");
    }

    private async Task CargarDatos()
    {
        var query = Db.VariablesSistema.AsQueryable();

        if (!string.IsNullOrWhiteSpace(filtro))
        {
            var f = filtro.Trim().ToLower();
            query = query.Where(v => v.Clave.ToLower().Contains(f)
                || (v.Descripcion != null && v.Descripcion.ToLower().Contains(f)));
        }

        var ordered = ordenColumna switch
        {
            "descripcion" => ordenDesc ? query.OrderByDescending(v => v.Descripcion) : query.OrderBy(v => v.Descripcion),
            "tipo" => ordenDesc ? query.OrderByDescending(v => v.TipoValor) : query.OrderBy(v => v.TipoValor),
            _ => ordenDesc ? query.OrderByDescending(v => v.Clave) : query.OrderBy(v => v.Clave),
        };

        items = await ordered.ToListAsync();
    }

    private void StartEdit(VariableSistema v) { editingId = v.Id; editValue = v.Valor; message = null; }
    private void CancelEdit() { editingId = null; editValue = null; }

    private async Task SaveVariable(VariableSistema v)
    {
        try
        {
            v.Valor = editValue;
            await Db.SaveChangesAsync();
            editingId = null;
            message = $"Variable '{v.Clave}' actualizada";
            isError = false;
        }
        catch (Exception ex) { message = ex.Message; isError = true; }
    }
}
