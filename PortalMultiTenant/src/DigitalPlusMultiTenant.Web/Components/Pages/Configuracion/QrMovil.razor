@page "/configuracion/qr-movil"
@inherits DigitalPlusMultiTenant.Web.Components.DbComponentBase
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using QRCoder
@attribute [Authorize(Roles = "SuperAdmin,AdminEmpresa")]
@rendermode InteractiveServer

@inject DigitalPlusMultiTenant.Application.Interfaces.ITenantService Tenant
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>QR Fichada Movil - DigitalPlus</PageTitle>

<div class="d-print-none d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-qr-code me-2"></i>QR para Fichada Movil</h4>
    <div>
        <button class="btn btn-primary" @onclick="Imprimir">
            <i class="bi bi-printer me-1"></i>Imprimir
        </button>
        <a href="configuracion" class="btn btn-outline-secondary ms-2">
            <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
    </div>
</div>

@if (cargando)
{
    <div class="text-center py-5">
        <DigitalPlusMultiTenant.Web.Components.Shared.LoadingIndicator Message="Generando QR..." />
    </div>
}
else
{
    <div class="d-print-none alert alert-info small mb-3">
        <i class="bi bi-info-circle me-1"></i>
        Imprima este QR y peguelo en un lugar visible (recepcion, oficina, vestuario).
        Los empleados escanean con su celular para instalar la app de fichaje movil.
    </div>

    @* ── Cartel imprimible ── *@
    <div class="qr-print-container">
        <div class="card shadow mx-auto" style="max-width: 480px;">
            <div class="card-body text-center py-4 px-4">
                <div class="mb-3" style="background: #0B1120; padding: 16px; border-radius: 8px;">
                    <h3 class="mb-0" style="color: #C9A84C; font-weight: 700;">Digital One</h3>
                </div>

                <h5 class="fw-bold mt-3 mb-1">Fichada desde tu celular</h5>
                <p class="text-muted mb-3">Escanea el codigo QR con la camara de tu celular</p>

                <div class="d-flex justify-content-center mb-3">
                    <div class="p-3 bg-white rounded border" style="display: inline-block;">
                        @((MarkupString)qrSvg)
                    </div>
                </div>

                <p class="text-muted small mb-2">@empresaNombre</p>

                <div class="bg-light rounded p-2 mb-3">
                    <code class="text-dark small" style="word-break: break-all;">@pwaUrl</code>
                </div>

                <div class="border-top pt-3">
                    <div class="row text-start g-2">
                        <div class="col-12">
                            <small class="text-muted">
                                <strong class="d-block mb-1">Instrucciones:</strong>
                                <span class="d-block"><i class="bi bi-1-circle me-1"></i>Escanea el QR o ingresa la URL en el navegador</span>
                                <span class="d-block"><i class="bi bi-2-circle me-1"></i>Ingresa el codigo de activacion que te dio tu supervisor</span>
                                <span class="d-block"><i class="bi bi-3-circle me-1"></i>Agrega la app a la pantalla de inicio</span>
                                <span class="d-block"><i class="bi bi-4-circle me-1"></i>Listo! Ya podes fichar entrada y salida</span>
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ── Opciones adicionales (no se imprimen) ── *@
    <div class="d-print-none mt-4">
        <div class="card shadow-sm mx-auto" style="max-width: 480px;">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="bi bi-share me-2"></i>Compartir link</h6>
            </div>
            <div class="card-body">
                <div class="input-group mb-2">
                    <input type="text" class="form-control form-control-sm" value="@pwaUrl" readonly />
                    <button class="btn btn-outline-primary btn-sm" @onclick="CopiarLink">
                        <i class="bi bi-clipboard me-1"></i>Copiar
                    </button>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <a href="@whatsappShareUrl" target="_blank" class="btn btn-success btn-sm">
                        <i class="bi bi-whatsapp me-1"></i>Enviar por WhatsApp
                    </a>
                    <a href="mailto:?subject=Fichada%20movil%20-%20@(Uri.EscapeDataString(empresaNombre))&body=@(Uri.EscapeDataString(shareText))" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-envelope me-1"></i>Enviar por email
                    </a>
                </div>
                @if (copiado)
                {
                    <div class="text-success small mt-1"><i class="bi bi-check me-1"></i>Copiado al portapapeles</div>
                }
            </div>
        </div>
    </div>
}

<style>
    @@media print {
        body * { visibility: hidden; }
        .qr-print-container, .qr-print-container * { visibility: visible; }
        .qr-print-container {
            position: absolute; left: 0; top: 0; width: 100%;
        }
        .qr-print-container .card {
            border: none !important;
            box-shadow: none !important;
            max-width: 100% !important;
        }
    }
</style>

@code {
    private bool cargando = true;
    private string qrSvg = "";
    private string pwaUrl = "";
    private string empresaNombre = "";
    private string whatsappShareUrl = "";
    private string shareText = "";
    private bool copiado;

    protected override async Task OnInitializedAsync()
    {
        var empresaId = Tenant.EmpresaId;
        if (empresaId == 0) return;

        var empresa = await Db.Empresas
            .AsNoTracking()
            .Where(e => e.Id == empresaId)
            .Select(e => new { e.Nombre })
            .FirstOrDefaultAsync();
        empresaNombre = empresa?.Nombre ?? "";

        var baseUrl = Nav.BaseUri.TrimEnd('/');
        pwaUrl = $"{baseUrl}/mobile/";

        // Generar QR como SVG
        using var qrGenerator = new QRCodeGenerator();
        using var qrCodeData = qrGenerator.CreateQrCode(pwaUrl, QRCodeGenerator.ECCLevel.M);
        using var svgQrCode = new SvgQRCode(qrCodeData);
        qrSvg = svgQrCode.GetGraphic(6, "#0B1120", "#FFFFFF", false);

        // Links para compartir
        shareText = $"Descarga la app de fichaje movil de {empresaNombre}:\n{pwaUrl}\n\nEscanea el QR o ingresa desde tu navegador. Necesitas el codigo de activacion que te dio tu supervisor.";
        whatsappShareUrl = $"https://wa.me/?text={Uri.EscapeDataString(shareText)}";

        cargando = false;
    }

    private async Task Imprimir()
    {
        await JS.InvokeVoidAsync("print");
    }

    private async Task CopiarLink()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", pwaUrl);
        copiado = true;
        StateHasChanged();
        await Task.Delay(2000);
        copiado = false;
    }
}
