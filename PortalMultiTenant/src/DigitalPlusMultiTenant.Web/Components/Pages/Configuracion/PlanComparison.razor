@page "/configuracion/planes"
@inherits DigitalPlusMultiTenant.Web.Components.DbComponentBase
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Infrastructure.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Net.Http.Json
@attribute [Authorize(Roles = "SuperAdmin,AdminEmpresa")]
@rendermode InteractiveServer

@inject ITenantService Tenant
@inject ILicenciaService LicenciaService
@inject LemonSqueezyService LsqService
@inject AuthenticationStateProvider AuthStateProvider
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Planes - DigitalPlus</PageTitle>

@* ── Alertas de retorno de checkout ── *@
@if (mostrarAlertaSuccess)
{
    <div class="alert alert-success alert-dismissible mb-3">
        <i class="bi bi-check-circle-fill me-2"></i>
        <strong>Tu plan fue actualizado!</strong> Los nuevos limites estan activos.
        <button type="button" class="btn-close" @onclick="() => mostrarAlertaSuccess = false"></button>
    </div>
}
@if (mostrarAlertaCanceled)
{
    <div class="alert alert-warning alert-dismissible mb-3">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        El proceso de pago fue cancelado.
        <button type="button" class="btn-close" @onclick="() => mostrarAlertaCanceled = false"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-gem me-2"></i>Comparacion de Planes</h4>
</div>

@if (cargando)
{
    <div class="text-center py-5">
        <DigitalPlusMultiTenant.Web.Components.Shared.LoadingIndicator Message="Cargando planes..." />
    </div>
}
else if (planes.Count == 0)
{
    <div class="alert alert-info">No se pudieron obtener los planes disponibles. Intente nuevamente mas tarde.</div>
}
else
{
    @* ── Toggle Mensual / Anual ── *@
    <div class="text-center mb-4">
        <div class="btn-group" role="group">
            <button type="button" class="btn @(periodoAnual ? "btn-outline-primary" : "btn-primary")"
                    @onclick="() => periodoAnual = false">
                Mensual
            </button>
            <button type="button" class="btn @(periodoAnual ? "btn-primary" : "btn-outline-primary")"
                    @onclick="() => periodoAnual = true">
                Anual
                @{
                    var mejorDescuento = planes
                        .Where(p => p.ImporteMensual > 0 && p.ImporteAnual > 0)
                        .Select(p => Math.Round((1 - p.ImporteAnual / (p.ImporteMensual * 12)) * 100))
                        .DefaultIfEmpty(0)
                        .Max();
                }
                @if (mejorDescuento > 0)
                {
                    <span class="badge bg-success ms-1">Ahorra @mejorDescuento%</span>
                }
            </button>
        </div>
    </div>

    <div class="row g-4 mb-4">
        @foreach (var plan in planes)
        {
            var esPlanActual = string.Equals(plan.Plan, planActual, StringComparison.OrdinalIgnoreCase);
            var ordenActual = planes.FirstOrDefault(p => string.Equals(p.Plan, planActual, StringComparison.OrdinalIgnoreCase))?.Orden ?? 0;
            var esPlanInferior = plan.Orden < ordenActual;
            var esPlanSuperior = plan.Orden > ordenActual;
            var esEnterprise = string.Equals(plan.Plan, "enterprise", StringComparison.OrdinalIgnoreCase);
            var esFree = string.Equals(plan.Plan, "free", StringComparison.OrdinalIgnoreCase);

            var parametrosLista = plan.ParametrosVisibles
                .Where(p => !string.Equals(p.Categoria, "Precio", StringComparison.OrdinalIgnoreCase)
                          && !string.Equals(p.Categoria, "Sistema", StringComparison.OrdinalIgnoreCase))
                .OrderBy(p => p.OrdenVisualizacion)
                .ToList();

            <div class="col-xl-3 col-lg-6 col-md-6">
                <div class="card h-100 shadow-sm @(esPlanActual ? "border-success border-2" : esPlanInferior ? "opacity-50" : "border-0")"
                     style="@(esPlanActual ? "box-shadow: 0 0 15px rgba(25, 135, 84, 0.3) !important;" : "")">

                    @if (esPlanActual)
                    {
                        <div class="card-header bg-success text-white text-center py-2">
                            <small class="fw-bold"><i class="bi bi-check-circle-fill me-1"></i>Plan actual</small>
                        </div>
                    }

                    <div class="card-body d-flex flex-column text-center">
                        @* ── CABECERA: nombre + precio ── *@
                        <h5 class="card-title fw-bold mb-1">@plan.PlanDisplay</h5>

                        @if (esEnterprise && plan.ImporteMensual == 0)
                        {
                            <div class="mb-3">
                                <span class="display-6 fw-bold text-warning">Consultar</span>
                            </div>
                        }
                        else if (plan.ImporteMensual > 0)
                        {
                            <div class="mb-3">
                                @if (periodoAnual && plan.ImporteAnual > 0)
                                {
                                    var precioMensualEquiv = Math.Round(plan.ImporteAnual / 12, 2);
                                    var totalSinDescuentoA = plan.ImporteMensual * 12;
                                    var pctDescuentoA = totalSinDescuentoA > 0
                                        ? Math.Round((1 - plan.ImporteAnual / totalSinDescuentoA) * 100)
                                        : 0;

                                    <div class="mb-1">
                                        <span class="display-6 fw-bold">$@precioMensualEquiv.ToString("N0")</span>
                                        <span class="text-muted">/mes</span>
                                    </div>
                                    <div class="mt-1">
                                        <span class="text-muted small">Facturado anualmente:</span>
                                        <span class="fw-bold text-success">$@plan.ImporteAnual.ToString("N0")</span>
                                        <span class="text-muted small">/año</span>
                                    </div>
                                    if (pctDescuentoA > 0)
                                    {
                                        <div class="mt-1">
                                            <span class="text-decoration-line-through text-muted small">$@totalSinDescuentoA.ToString("N0")</span>
                                            <span class="badge bg-success ms-1">@pctDescuentoA% OFF</span>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="mb-1">
                                        <span class="display-6 fw-bold">$@plan.ImporteMensual.ToString("N0")</span>
                                        <span class="text-muted">/mes</span>
                                    </div>

                                    if (plan.ImporteAnual > 0)
                                    {
                                        var totalSinDescuentoM = plan.ImporteMensual * 12;
                                        var pctDescuentoM = totalSinDescuentoM > 0
                                            ? Math.Round((1 - plan.ImporteAnual / totalSinDescuentoM) * 100)
                                            : 0;
                                        <div class="mt-2 p-2 rounded" style="background-color: rgba(25,135,84,0.1);">
                                            <span class="small text-muted">o</span>
                                            <span class="fw-bold text-success ms-1">$@plan.ImporteAnual.ToString("N0")</span>
                                            <span class="text-muted small">/año</span>
                                            @if (pctDescuentoM > 0)
                                            {
                                                <span class="badge bg-success ms-1">@pctDescuentoM% OFF</span>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <span class="display-6 fw-bold text-success">Gratis</span>
                            </div>
                        }

                        <hr />

                        @* ── LISTA: parametros visibles (no Precio, no Sistema) ── *@
                        <ul class="list-unstyled text-start flex-grow-1">
                            @foreach (var param in parametrosLista)
                            {
                                <li class="mb-2 d-flex align-items-start">
                                    @if (!string.IsNullOrEmpty(param.Icono))
                                    {
                                        <i class="bi @param.Icono me-2 text-primary mt-1"></i>
                                    }
                                    <span>
                                        <strong>@param.LabelAmigable:</strong>
                                        @if (string.Equals(param.TipoVisualizacion, "booleano", StringComparison.OrdinalIgnoreCase))
                                        {
                                            if (param.Valor >= 1)
                                            {
                                                <i class="bi bi-check-circle-fill text-success ms-1"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-x-circle-fill text-danger ms-1"></i>
                                            }
                                        }
                                        else
                                        {
                                            @param.ValorFormateado
                                        }
                                    </span>
                                </li>
                            }
                        </ul>

                        @* ── FOOTER: botones ── *@
                        @if (esPlanActual && (licenciaInfo?.SuscripcionExpirada ?? false))
                        {
                            <button class="btn btn-success mt-auto"
                                    @onclick="() => MostrarConfirmUpgrade(plan)"
                                    disabled="@solicitando">
                                <i class="bi bi-arrow-repeat me-1"></i>Volver a contratar
                            </button>
                        }
                        else if (esPlanActual)
                        {
                            <button class="btn btn-outline-success mt-auto" disabled>
                                <i class="bi bi-check-lg me-1"></i>Plan actual
                            </button>
                        }
                        else if (esPlanInferior)
                        {
                            <button class="btn btn-outline-secondary mt-auto" disabled>
                                Plan inferior
                            </button>
                        }
                        else if (esEnterprise)
                        {
                            <a href="mailto:notify@integraia.tech?subject=Consulta%20plan%20Enterprise%20-%20DigitalPlus"
                               class="btn btn-warning mt-auto">
                                <i class="bi bi-envelope me-1"></i>Contactar ventas
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-primary mt-auto"
                                    @onclick="() => MostrarConfirmUpgrade(plan)"
                                    disabled="@solicitando">
                                <i class="bi bi-arrow-up-circle me-1"></i>Contratar @plan.PlanDisplay
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @* ── Sección Gestionar suscripción (solo si LSQ activa) ── *@
    @if (licenciaInfo?.EsLemonSqueezy == true)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary bg-opacity-10">
                <h6 class="mb-0"><i class="bi bi-credit-card me-2"></i>Gestionar suscripcion</h6>
            </div>
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <p class="mb-1">
                            <strong>Plan activo:</strong> @licenciaInfo.PlanDisplay
                        </p>
                        @if (licenciaInfo.PlanVencimiento.HasValue)
                        {
                            <p class="mb-0 text-muted">
                                <i class="bi bi-calendar-check me-1"></i>
                                Proximo cobro: @licenciaInfo.PlanVencimiento.Value.ToString("dd/MM/yyyy")
                            </p>
                        }
                    </div>
                    <div class="col-md-6 text-md-end mt-2 mt-md-0">
                        @if (!string.IsNullOrEmpty(licenciaInfo.LsqUpdatePaymentUrl))
                        {
                            <a href="@licenciaInfo.LsqUpdatePaymentUrl" target="_blank"
                               class="btn btn-outline-secondary btn-sm me-2">
                                <i class="bi bi-credit-card me-1"></i>Actualizar tarjeta
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(licenciaInfo.LsqCustomerPortalUrl))
                        {
                            <a href="@licenciaInfo.LsqCustomerPortalUrl" target="_blank"
                               class="btn btn-outline-primary btn-sm me-2">
                                <i class="bi bi-receipt me-1"></i>Portal de facturacion
                            </a>
                        }
                        @if (!(licenciaInfo?.SuscripcionCancelada ?? false))
                        {
                            <button class="btn btn-link btn-sm text-danger" @onclick="() => mostrarCancelarModal = true"
                                    disabled="@cancelando">
                                Cancelar suscripcion
                            </button>
                        }
                        else
                        {
                            <span class="text-danger small d-block mb-2">
                                <i class="bi bi-exclamation-triangle me-1"></i>Suscripcion cancelada — activa hasta @(licenciaInfo.PlanVencimiento?.ToString("dd/MM/yyyy") ?? "fin del periodo"). Después el sistema quedará inactivo.
                            </span>
                            <button class="btn btn-success btn-sm" @onclick="() => RecontratarPlanActual()" disabled="@solicitando">
                                <i class="bi bi-arrow-repeat me-1"></i>Volver a suscribir
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="text-muted small">
        <i class="bi bi-info-circle me-1"></i>
        Todos los precios estan expresados en dolares estadounidenses (USD).
        Al contratar un plan sera redirigido a la pagina de pago segura. Una vez confirmado, los nuevos limites se activan automaticamente.
    </div>
}

@* ── Modal Confirmar Upgrade ── *@
@if (mostrarConfirmUpgrade && planSeleccionado != null)
{
    var modalParametros = planSeleccionado.ParametrosVisibles
        .Where(p => !string.Equals(p.Categoria, "Sistema", StringComparison.OrdinalIgnoreCase))
        .OrderBy(p => p.Categoria)
        .ThenBy(p => p.OrdenVisualizacion)
        .ToList();
    var categorias = modalParametros.Select(p => p.Categoria).Distinct().ToList();

    <div class="modal fade show d-block" tabindex="-1" style="background-color:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-primary bg-opacity-10">
                    <h6 class="modal-title"><i class="bi bi-arrow-up-circle me-2"></i>Confirmar contratacion</h6>
                    <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <p>Desea contratar el plan <strong>@planSeleccionado.PlanDisplay</strong> (@(periodoAnual ? "anual" : "mensual"))?</p>
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr>
                                <td class="fw-bold">Plan actual:</td>
                                <td>@(planes.FirstOrDefault(p => string.Equals(p.Plan, planActual, StringComparison.OrdinalIgnoreCase))?.PlanDisplay ?? planActual)</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">Plan solicitado:</td>
                                <td>@planSeleccionado.PlanDisplay</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">Periodo:</td>
                                <td>@(periodoAnual ? "Anual" : "Mensual")</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">Importe:</td>
                                <td class="fw-bold text-primary">
                                    @if (periodoAnual && planSeleccionado.ImporteAnual > 0)
                                    {
                                        @($"USD {planSeleccionado.ImporteAnual:N0} /año")
                                    }
                                    else
                                    {
                                        @($"USD {planSeleccionado.ImporteMensual:N0} /mes")
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    @foreach (var cat in categorias)
                    {
                        var paramsEnCat = modalParametros.Where(p => p.Categoria == cat).ToList();
                        <h6 class="mt-3 mb-2 text-muted fw-bold small text-uppercase">@cat</h6>
                        <table class="table table-sm mb-0">
                            <tbody>
                                @foreach (var param in paramsEnCat)
                                {
                                    <tr>
                                        <td class="fw-bold">
                                            @if (!string.IsNullOrEmpty(param.Icono))
                                            {
                                                <i class="bi @param.Icono me-1 text-primary"></i>
                                            }
                                            @param.LabelAmigable:
                                        </td>
                                        <td>
                                            @if (string.Equals(param.TipoVisualizacion, "booleano", StringComparison.OrdinalIgnoreCase))
                                            {
                                                if (param.Valor >= 1)
                                                {
                                                    <i class="bi bi-check-circle-fill text-success"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-x-circle-fill text-danger"></i>
                                                }
                                            }
                                            else
                                            {
                                                @param.ValorFormateado
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                    <div class="alert alert-info mt-3 mb-0 small">
                        <i class="bi bi-lock-fill me-1"></i>
                        Sera redirigido a una pagina de pago segura para completar la contratacion.
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="CerrarModal">Cancelar</button>
                    <button class="btn btn-primary btn-sm" @onclick="IniciarCheckout" disabled="@solicitando">
                        @if (solicitando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-credit-card me-1"></i>Continuar al pago
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (mostrarEmailRequerido)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header bg-warning bg-opacity-10">
                    <h6 class="modal-title"><i class="bi bi-envelope-exclamation me-2"></i>Email no verificado</h6>
                    <button type="button" class="btn-close" @onclick="() => mostrarEmailRequerido = false"></button>
                </div>
                <div class="modal-body text-center">
                    <i class="bi bi-envelope-exclamation text-warning" style="font-size: 3rem;"></i>
                    <p class="mt-3">Debe verificar su email antes de cambiar de plan.</p>
                    <p class="fw-bold mb-0">@emailUsuario</p>
                </div>
                <div class="modal-footer justify-content-center">
                    <button class="btn btn-secondary btn-sm" @onclick="() => mostrarEmailRequerido = false">Cancelar</button>
                    <a href="Account/VerificarEmail" class="btn btn-warning btn-sm">
                        <i class="bi bi-envelope-check me-1"></i>Verificar ahora
                    </a>
                </div>
            </div>
        </div>
    </div>
}

@* ── Modal Cancelar Suscripción ── *@
@if (mostrarCancelarModal && licenciaInfo != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger bg-opacity-10">
                    <h6 class="modal-title"><i class="bi bi-x-circle me-2"></i>Cancelar suscripcion</h6>
                    <button type="button" class="btn-close" @onclick="() => mostrarCancelarModal = false"></button>
                </div>
                <div class="modal-body">
                    <p>Confirmas la cancelacion? Tu plan <strong>@licenciaInfo.PlanDisplay</strong> seguira activo
                        hasta el <strong>@(licenciaInfo.PlanVencimiento?.ToString("dd/MM/yyyy") ?? "fin del periodo")</strong>.</p>
                    <p class="text-muted small mb-0">Al vencer, el sistema quedará inactivo hasta que contrates un nuevo plan.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="() => mostrarCancelarModal = false">Volver</button>
                    <button class="btn btn-danger btn-sm" @onclick="EjecutarCancelacion" disabled="@cancelando">
                        @if (cancelando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Si, cancelar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(mensaje))
{
    <div class="alert @(esError ? "alert-danger" : "alert-success") mt-3 alert-dismissible">
        @mensaje
        <button type="button" class="btn-close" @onclick="() => mensaje = null"></button>
    </div>
}

@code {
    private List<PlanComparacion> planes = new();
    private string planActual = "free";
    private string? companyId;
    private int empresaId;
    private bool cargando = true;
    private bool solicitando;
    private string? mensaje;
    private bool esError;
    private bool mostrarConfirmUpgrade;
    private PlanComparacion? planSeleccionado;
    private bool emailVerificado;
    private bool mostrarEmailRequerido;
    private string? emailUsuario;
    private bool periodoAnual;
    private bool mostrarAlertaSuccess;
    private bool mostrarAlertaCanceled;
    private LicenciaInfo? licenciaInfo;
    private bool mostrarCancelarModal;
    private bool cancelando;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            empresaId = Tenant.EmpresaId;
            if (empresaId == 0) return;

            // Detectar query params de retorno
            var uri = new Uri(Nav.Uri);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
            mostrarAlertaSuccess = query["success"] == "true";
            mostrarAlertaCanceled = query["canceled"] == "true";

            // Si viene de un upgrade exitoso, invalidar cache
            if (mostrarAlertaSuccess || uri.Query.Contains("upgraded"))
            {
                LicenciaService.InvalidarCache(empresaId);
            }

            // Obtener plan actual e info de empresa
            licenciaInfo = await LicenciaService.GetLicenciaInfoAsync(empresaId);
            planActual = licenciaInfo.Plan;

            // Obtener CompanyId (Codigo) de la empresa
            var empresa = await Db.Empresas
                .AsNoTracking()
                .Where(e => e.Id == empresaId)
                .Select(e => new { e.Codigo })
                .FirstOrDefaultAsync();
            companyId = empresa?.Codigo;

            // Verificar email
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            emailVerificado = authState.User.FindFirst("EmailConfirmed")?.Value == "true";
            emailUsuario = authState.User.Identity?.Name;

            // Obtener planes disponibles
            planes = await LicenciaService.GetPlanesComparacionAsync();
        }
        catch (Exception ex)
        {
            mensaje = "Error cargando planes: " + ex.Message;
            esError = true;
        }
        finally
        {
            cargando = false;
        }
    }

    private void RecontratarPlanActual()
    {
        var plan = planes.FirstOrDefault(p => string.Equals(p.Plan, planActual, StringComparison.OrdinalIgnoreCase));
        if (plan != null) MostrarConfirmUpgrade(plan);
    }

    private void MostrarConfirmUpgrade(PlanComparacion plan)
    {
        if (!emailVerificado)
        {
            mensaje = null;
            esError = true;
            mostrarEmailRequerido = true;
            return;
        }
        mostrarEmailRequerido = false;
        planSeleccionado = plan;
        mostrarConfirmUpgrade = true;
    }

    private void CerrarModal()
    {
        mostrarConfirmUpgrade = false;
        planSeleccionado = null;
    }

    private async Task IniciarCheckout()
    {
        if (planSeleccionado == null) return;
        solicitando = true;
        mensaje = null;

        try
        {
            // Obtener variant ID según plan y período
            var variantId = LsqService.GetVariantId(planSeleccionado.Plan, periodoAnual);

            if (string.IsNullOrEmpty(variantId))
            {
                // Fallback al flujo anterior (Portal Licencias) si no hay variant configurado
                await EnviarSolicitudUpgradeLegacy();
                return;
            }

            // Crear checkout en Lemon Squeezy
            var successUrl = $"{Nav.BaseUri}configuracion/planes?success=true";
            var checkoutUrl = await LsqService.CreateCheckoutAsync(companyId!, variantId, successUrl);

            if (string.IsNullOrEmpty(checkoutUrl))
            {
                mensaje = "Error al crear la sesion de pago. Intente nuevamente.";
                esError = true;
                CerrarModal();
                return;
            }

            // Redirigir al checkout de Lemon Squeezy
            CerrarModal();
            Nav.NavigateTo(checkoutUrl, forceLoad: true);
        }
        catch (Exception ex)
        {
            mensaje = "Error al iniciar el pago: " + ex.Message;
            esError = true;
            CerrarModal();
        }
        finally
        {
            solicitando = false;
        }
    }

    private async Task EjecutarCancelacion()
    {
        if (string.IsNullOrEmpty(companyId)) return;
        cancelando = true;
        mensaje = null;

        try
        {
            var result = await LsqService.CancelSubscriptionAsync(companyId);

            if (result.Ok)
            {
                // Refrescar licencia para mostrar el estado cancelado
                LicenciaService.InvalidarCache(empresaId);
                licenciaInfo = await LicenciaService.GetLicenciaInfoAsync(empresaId);
                mostrarCancelarModal = false;
                var fechaVenc = licenciaInfo?.PlanVencimiento?.ToString("dd/MM/yyyy") ?? "fin del periodo";
                mensaje = $"Tu suscripcion fue cancelada. El plan sigue activo hasta el {fechaVenc}. Después el sistema quedará inactivo.";
                esError = false;
            }
            else
            {
                mensaje = result.Error ?? "Error al cancelar la suscripcion.";
                esError = true;
                mostrarCancelarModal = false;
            }
        }
        catch (Exception ex)
        {
            mensaje = "Error: " + ex.Message;
            esError = true;
            mostrarCancelarModal = false;
        }
        finally
        {
            cancelando = false;
        }
    }

    /// <summary>
    /// Flujo legacy para cuando no hay variant IDs de Lemon Squeezy configurados.
    /// </summary>
    private async Task EnviarSolicitudUpgradeLegacy()
    {
        if (planSeleccionado == null || string.IsNullOrEmpty(companyId)) return;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var email = authState.User.Identity?.Name ?? "desconocido";

            var client = HttpClientFactory.CreateClient("PortalLicencias");
            var request = new
            {
                CompanyId = companyId,
                PlanSolicitado = planSeleccionado.Plan,
                SolicitadoPor = email,
                EmpresaId = 0
            };

            var response = await client.PostAsJsonAsync("/api/upgrade/solicitar", request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<UpgradeResponse>();
                if (result?.upgradeUrl != null)
                {
                    CerrarModal();
                    await JS.InvokeVoidAsync("open", result.upgradeUrl, "_self");
                    return;
                }
                mensaje = $"Solicitud de upgrade al plan {planSeleccionado.PlanDisplay} enviada correctamente.";
                esError = false;
                CerrarModal();
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                mensaje = $"Error al enviar la solicitud: {errorContent}";
                esError = true;
                CerrarModal();
            }
        }
        catch (Exception ex)
        {
            mensaje = "Error al enviar la solicitud: " + ex.Message;
            esError = true;
            CerrarModal();
        }
    }

    private class UpgradeResponse
    {
        public int id { get; set; }
        public string? token { get; set; }
        public string? upgradeUrl { get; set; }
        public string? mensaje { get; set; }
    }
}
