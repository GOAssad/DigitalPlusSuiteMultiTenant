@page "/"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@attribute [Authorize]

@inject IApplicationDbContext Db

<PageTitle>Dashboard - DigitalPlus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Dashboard</h4>
    <span class="text-muted">@DateTime.Now.ToString("dddd, dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-AR"))</span>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small">Legajos</div>
                        <div class="fs-3 fw-bold">@legajosCount</div>
                    </div>
                    <div class="card-icon bg-primary-subtle text-primary">
                        <i class="bi bi-people"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small">Sucursales</div>
                        <div class="fs-3 fw-bold">@sucursalesCount</div>
                    </div>
                    <div class="card-icon bg-success-subtle text-success">
                        <i class="bi bi-building"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small">Fichadas hoy</div>
                        <div class="fs-3 fw-bold">@fichadasHoyCount</div>
                    </div>
                    <div class="card-icon bg-info-subtle text-info">
                        <i class="bi bi-card-checklist"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small">Terminales</div>
                        <div class="fs-3 fw-bold">@terminalesCount</div>
                    </div>
                    <div class="card-icon bg-warning-subtle text-warning">
                        <i class="bi bi-pc-display"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom">
                <h6 class="mb-0"><i class="bi bi-card-checklist me-2"></i>Ultimas fichadas</h6>
            </div>
            <div class="card-body p-0">
                @if (ultimasFichadas.Any())
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Legajo</th>
                                <th>Fecha/Hora</th>
                                <th>Tipo</th>
                                <th>Origen</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var f in ultimasFichadas)
                            {
                                <tr>
                                    <td>@f.Legajo?.Apellido @f.Legajo?.Nombre</td>
                                    <td>@f.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <span class="badge @(f.Tipo == "E" ? "bg-success" : "bg-danger")">
                                            @(f.Tipo == "E" ? "Entrada" : "Salida")
                                        </span>
                                    </td>
                                    <td>@f.Origen</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        No hay fichadas registradas
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom">
                <h6 class="mb-0"><i class="bi bi-bell me-2"></i>Noticias</h6>
            </div>
            <div class="card-body">
                @if (ultimasNoticias.Any())
                {
                    @foreach (var n in ultimasNoticias)
                    {
                        <div class="mb-3 pb-3 border-bottom">
                            <div class="fw-semibold">@n.Titulo</div>
                            <div class="text-muted small">@n.FechaDesde.ToString("dd/MM/yyyy") - @n.FechaHasta.ToString("dd/MM/yyyy")</div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center text-muted py-3">
                        <i class="bi bi-megaphone fs-3 d-block mb-2"></i>
                        Sin noticias
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private int legajosCount;
    private int sucursalesCount;
    private int fichadasHoyCount;
    private int terminalesCount;
    private List<DigitalPlusMultiTenant.Domain.Entities.Fichada> ultimasFichadas = new();
    private List<DigitalPlusMultiTenant.Domain.Entities.Noticia> ultimasNoticias = new();

    protected override async Task OnInitializedAsync()
    {
        var hoy = DateTime.UtcNow.Date;

        legajosCount = await Db.Legajos.CountAsync();
        sucursalesCount = await Db.Sucursales.CountAsync();
        fichadasHoyCount = await Db.Fichadas.CountAsync(f => f.FechaHora >= hoy);
        terminalesCount = await Db.Terminales.CountAsync();

        ultimasFichadas = await Db.Fichadas
            .Include(f => f.Legajo)
            .OrderByDescending(f => f.FechaHora)
            .Take(10)
            .ToListAsync();

        var hoyDateOnly = DateOnly.FromDateTime(DateTime.Today);
        ultimasNoticias = await Db.Noticias
            .Where(n => n.FechaDesde <= hoyDateOnly && n.FechaHasta >= hoyDateOnly)
            .OrderByDescending(n => n.FechaDesde)
            .Take(5)
            .ToListAsync();
    }
}
