    // --- PIN ---
    private async Task GuardarPin()
    {
        pinMessage = null;
        if (string.IsNullOrWhiteSpace(nuevoPin) || nuevoPin.Length < 4)
        {
            pinMessage = "El PIN debe tener al menos 4 digitos.";
            pinMessageOk = false;
            return;
        }

        var existing = await Db.LegajoPines.FirstOrDefaultAsync(p => p.LegajoId == model.Id);
        var salt = Convert.ToBase64String(RandomNumberGenerator.GetBytes(16));
        var hash = ComputePinHash(nuevoPin, salt);

        if (existing != null)
        {
            existing.PinHash = hash;
            existing.PinSalt = salt;
            existing.PinMustChange = false;
            existing.PinChangedAt = DateTime.UtcNow;
        }
        else
        {
            Db.LegajoPines.Add(new LegajoPin
            {
                LegajoId = model.Id,
                PinHash = hash,
                PinSalt = salt,
                PinMustChange = false,
                PinChangedAt = DateTime.UtcNow,
                CreatedAt = DateTime.UtcNow
            });
        }

        await Db.SaveChangesAsync();
        tienePin = true;
        nuevoPin = null;
        pinMessage = "PIN actualizado correctamente.";
        pinMessageOk = true;
    }

    private async Task ResetearPin()
    {
        var existing = await Db.LegajoPines.FirstOrDefaultAsync(p => p.LegajoId == model.Id);
        if (existing != null)
        {
            Db.LegajoPines.Remove(existing);
            await Db.SaveChangesAsync();
        }
        tienePin = false;
        nuevoPin = null;
        pinMessage = "PIN eliminado. Asigne uno nuevo.";
        pinMessageOk = true;
    }

    private static string ComputePinHash(string pin, string salt)
    {
        byte[] bytes = Encoding.UTF8.GetBytes(salt + pin);
        byte[] hash = SHA256.HashData(bytes);
        return Convert.ToBase64String(hash);
    }

