    protected override async Task OnInitializedAsync()
    {
        mobileHabilitado = Tenant.MobileHabilitado;
        sectores = await Db.Sectores.Where(s => s.IsActive).OrderBy(s => s.Nombre).ToListAsync();
        categorias = await Db.Categorias.Where(c => c.IsActive).OrderBy(c => c.Nombre).ToListAsync();
        horarios = await Db.Horarios.Where(h => h.IsActive).OrderBy(h => h.Nombre).ToListAsync();
        sucursalesDisponibles = await Db.Sucursales.Where(s => s.IsActive).OrderBy(s => s.Nombre).ToListAsync();

        if (IsEdit)
        {
            var entity = await Db.Legajos
                .Include(l => l.LegajoSucursales).ThenInclude(ls => ls.Sucursal)
                .Include(l => l.Huellas)
                .Include(l => l.EventosCalendario).ThenInclude(e => e.Sucursal)
                .Include(l => l.Domicilio)
                .Include(l => l.Horario!).ThenInclude(h => h.Detalles)
                .FirstOrDefaultAsync(l => l.Id == Id);

            if (entity == null) { Nav.NavigateTo("legajos"); return; }
            model = entity;

            // Sucursales
            legajoSucursales = entity.LegajoSucursales
                .OrderBy(ls => ls.Sucursal.Nombre)
                .ToList();

            var asignadasIds = legajoSucursales.Select(ls => ls.SucursalId).ToHashSet();
            sucursalesDisponibles = sucursalesDisponibles.Where(s => !asignadasIds.Contains(s.Id)).ToList();

            // Domicilio
            if (entity.Domicilio != null)
            {
                domCalle = entity.Domicilio.Calle;
                domAltura = entity.Domicilio.Altura;
                domPiso = entity.Domicilio.Piso;
                domBarrio = entity.Domicilio.Barrio;
                domLocalidad = entity.Domicilio.Localidad;
                domProvincia = entity.Domicilio.Provincia;
                domCodigoPostal = entity.Domicilio.CodigoPostal;
            }

            // Huellas
            huellas = entity.Huellas.ToList();

            // PIN
            tienePin = await Db.LegajoPines.AnyAsync(p => p.LegajoId == entity.Id);

            // Calendario
            eventosCalendario = entity.EventosCalendario.ToList();

            // Incidencias
            incidenciasDisponibles = await Db.Incidencias.Where(i => i.IsActive).OrderBy(i => i.Nombre).ToListAsync();
            incidenciasLegajo = await Db.IncidenciaLegajos
                .Include(il => il.Incidencia)
                .Where(il => il.LegajoId == entity.Id)
                .OrderByDescending(il => il.Fecha)
                .Take(200)
                .ToListAsync();

            // Vacaciones
            vacacionesLegajo = await Db.Vacaciones
                .Where(v => v.LegajoId == entity.Id)
                .OrderByDescending(v => v.FechaDesde)
                .ToListAsync();

            // Terminal movil
            terminalMovil = await Db.TerminalesMoviles
                .FirstOrDefaultAsync(t => t.LegajoId == entity.Id && t.Activo);
        }
    }

