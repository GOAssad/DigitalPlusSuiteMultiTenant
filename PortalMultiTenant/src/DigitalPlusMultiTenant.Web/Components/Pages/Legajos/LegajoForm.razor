@page "/legajos/crear"
@page "/legajos/editar/{Id:int}"
@inherits DigitalPlusMultiTenant.Web.Components.DbComponentBase
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Security.Cryptography
@using System.Text
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize(Roles = "SuperAdmin,AdminEmpresa,Operador")]
@rendermode InteractiveServer

@inject NavigationManager Nav
@inject DigitalPlusMultiTenant.Application.Interfaces.ITenantService Tenant
@inject DigitalPlusMultiTenant.Application.Interfaces.ILicenciaService LicenciaService
@inject DigitalPlusMultiTenant.Infrastructure.Services.IEmailService EmailService

<PageTitle>@(IsEdit ? "Editar" : "Nuevo") Legajo - DigitalPlus</PageTitle>

<div class="d-flex align-items-center mb-3">
    <a href="legajos" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">@(IsEdit ? "Editar" : "Nuevo") Legajo</h4>
    @if (IsEdit)
    {
        <span class="badge bg-light text-muted ms-2 fs-6">#@model.NumeroLegajo</span>
        <span class="text-muted ms-2 fs-6">@model.Apellido, @model.Nombre</span>
    }
</div>

<EditForm Model="model" OnValidSubmit="Save" FormName="legajoForm">
    <DataAnnotationsValidator />

    @* ===== TABS ===== *@
    <ul class="nav nav-tabs mb-0" role="tablist">
        <li class="nav-item">
            <button type="button" class="nav-link @(activeTab == "datos" ? "active" : "")"
                    @onclick='() => activeTab = "datos"'>
                <i class="bi bi-person me-1"></i>Datos
            </button>
        </li>
        <li class="nav-item">
            <button type="button" class="nav-link @(activeTab == "sucursales" ? "active" : "")"
                    @onclick='() => activeTab = "sucursales"'>
                <i class="bi bi-building me-1"></i>Sucursales
                <span class="badge @(legajoSucursales.Count == 0 ? "bg-danger" : "bg-primary") ms-1">@legajoSucursales.Count</span>
            </button>
        </li>
        @if (IsEdit)
        {
            <li class="nav-item">
                <button type="button" class="nav-link @(activeTab == "huellas" ? "active" : "")"
                        @onclick='() => activeTab = "huellas"'>
                    <i class="bi bi-fingerprint me-1"></i>Huellas
                    <span class="badge bg-primary ms-1">@huellas.Count</span>
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link @(activeTab == "fichadas" ? "active" : "")"
                        @onclick="CargarTabFichadas">
                    <i class="bi bi-card-checklist me-1"></i>Fichadas
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link @(activeTab == "calendario" ? "active" : "")"
                        @onclick='() => activeTab = "calendario"'>
                    <i class="bi bi-calendar-week me-1"></i>Calendario
                </button>
            </li>
            @if (mobileHabilitado)
            {
                <li class="nav-item">
                    <button type="button" class="nav-link @(activeTab == "movil" ? "active" : "")"
                            @onclick='() => activeTab = "movil"'>
                        <i class="bi bi-phone me-1"></i>Movil
                        @if (terminalMovil != null)
                        {
                            <span class="badge bg-success ms-1"><i class="bi bi-check"></i></span>
                        }
                    </button>
                </li>
            }
        }
    </ul>

    <div class="card border-0 shadow-sm border-top-0 rounded-top-0">
        <div class="card-body">

            @* ===== TAB: DATOS ===== *@
            @if (activeTab == "datos")
            {
                @* ===== FOTO ===== *@
                @if (IsEdit && model.Foto != null && model.Foto.Length > 0)
                {
                    <div class="card border-0 shadow-sm mb-3">
                        <div class="card-body text-center py-3">
                            <img src="data:image/jpeg;base64,@Convert.ToBase64String(model.Foto)"
                                 alt="Foto del legajo"
                                 class="rounded"
                                 style="max-height: 180px; max-width: 180px; object-fit: cover;" />
                            <div class="text-muted small mt-1">Foto capturada desde la app de escritorio</div>
                        </div>
                    </div>
                }

                <h6 class="text-muted mb-3"><i class="bi bi-person me-1"></i>Datos personales</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-3">
                        <label class="form-label">Nro. Legajo</label>
                        <InputText @bind-Value="model.NumeroLegajo" class="form-control" />
                        <ValidationMessage For="() => model.NumeroLegajo" class="text-danger small" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Apellido</label>
                        <InputText @bind-Value="model.Apellido" class="form-control" />
                        <ValidationMessage For="() => model.Apellido" class="text-danger small" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Nombre</label>
                        <InputText @bind-Value="model.Nombre" class="form-control" />
                        <ValidationMessage For="() => model.Nombre" class="text-danger small" />
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label class="form-label">Email</label>
                        <InputText @bind-Value="model.Email" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Telefono</label>
                        <InputText @bind-Value="model.Telefono" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Fecha ingreso</label>
                        <InputDate @bind-Value="model.FechaIngreso" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Fecha egreso</label>
                        <InputDate @bind-Value="model.FechaEgreso" class="form-control" />
                    </div>
                </div>

                <h6 class="text-muted mb-3"><i class="bi bi-building me-1"></i>Organizacion</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label class="form-label">Sector</label>
                        <InputSelect @bind-Value="model.SectorId" class="form-select">
                            <option value="0">-- Seleccionar --</option>
                            @foreach (var s in sectores)
                            {
                                <option value="@s.Id">@s.Nombre</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Categoria</label>
                        <InputSelect @bind-Value="model.CategoriaId" class="form-select">
                            <option value="0">-- Seleccionar --</option>
                            @foreach (var c in categorias)
                            {
                                <option value="@c.Id">@c.Nombre</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Horario</label>
                        <InputSelect @bind-Value="model.HorarioId" class="form-select">
                            <option value="">-- Sin horario --</option>
                            @foreach (var h in horarios)
                            {
                                <option value="@h.Id">@h.Nombre</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-3">
                        <label class="form-label">Estado</label>
                        <div class="form-check form-switch mt-2">
                            <InputCheckbox @bind-Value="model.IsActive" class="form-check-input" />
                            <label class="form-check-label">Activo</label>
                        </div>
                    </div>
                    @if (mobileHabilitado)
                    {
                        <div class="col-md-3">
                            <label class="form-label">Acceso movil</label>
                            <div class="form-check form-switch mt-2">
                                <InputCheckbox @bind-Value="model.MobileHabilitado" class="form-check-input" />
                                <label class="form-check-label">Habilitado</label>
                            </div>
                        </div>
                    }
                </div>

                <h6 class="text-muted mb-3"><i class="bi bi-geo-alt me-1"></i>Domicilio</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-5">
                        <label class="form-label">Calle</label>
                        <input type="text" class="form-control" @bind="domCalle" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Altura</label>
                        <input type="text" class="form-control" @bind="domAltura" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Piso</label>
                        <input type="text" class="form-control" @bind="domPiso" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Barrio</label>
                        <input type="text" class="form-control" @bind="domBarrio" />
                    </div>
                </div>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label class="form-label">Localidad</label>
                        <input type="text" class="form-control" @bind="domLocalidad" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Provincia</label>
                        <input type="text" class="form-control" @bind="domProvincia" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Codigo Postal</label>
                        <input type="text" class="form-control" @bind="domCodigoPostal" />
                    </div>
                </div>

                @if (mobileHabilitado && IsEdit)
                {
                    <h6 class="text-muted mb-3"><i class="bi bi-phone me-1"></i>PIN Movil</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            @if (tienePin)
                            {
                                <span class="badge bg-success me-2"><i class="bi bi-check-circle me-1"></i>PIN configurado</span>
                                <button type="button" class="btn btn-sm btn-outline-warning" @onclick="ResetearPin">
                                    <i class="bi bi-arrow-repeat me-1"></i>Resetear PIN
                                </button>
                            }
                            else
                            {
                                <span class="badge bg-secondary me-2">Sin PIN</span>
                            }
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">@(tienePin ? "Nuevo PIN" : "Asignar PIN")</label>
                            <input type="password" class="form-control form-control-sm" maxlength="6" placeholder="6 digitos"
                                   @bind="nuevoPin" />
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="GuardarPin">
                                <i class="bi bi-save me-1"></i>@(tienePin ? "Cambiar" : "Asignar")
                            </button>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(pinMessage))
                    {
                        <div class="alert @(pinMessageOk ? "alert-success" : "alert-danger") py-2 small">@pinMessage</div>
                    }
                }
            }

            @* ===== TAB: SUCURSALES ===== *@
            @if (activeTab == "sucursales")
            {
                <h6 class="text-muted mb-3"><i class="bi bi-building me-1"></i>Sucursales asignadas</h6>

                <div class="card mb-2">
                    <div class="card-header py-2 bg-light">
                        <small class="fw-semibold">Disponibles</small>
                    </div>
                    <div class="list-group list-group-flush" style="max-height: 200px; overflow-y: auto;">
                        @if (sucursalesDisponibles.Count == 0)
                        {
                            <div class="list-group-item text-muted small">Todas las sucursales estan asignadas</div>
                        }
                        @foreach (var s in sucursalesDisponibles)
                        {
                            <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                    @onclick="() => AsignarSucursal(s)">
                                @s.Nombre
                                <i class="bi bi-arrow-down text-success"></i>
                            </button>
                        }
                    </div>
                </div>

                <div class="text-center my-2">
                    <i class="bi bi-arrow-down-up text-muted fs-5"></i>
                </div>

                <div>
                        <div class="card border-success">
                            <div class="card-header py-2 bg-success bg-opacity-10">
                                <small class="fw-semibold text-success">Asignadas (@legajoSucursales.Count)</small>
                            </div>
                            <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
                                @if (legajoSucursales.Count == 0)
                                {
                                    <div class="p-3 text-muted small">Sin sucursales asignadas</div>
                                }
                                else
                                {
                                    <table class="table table-sm table-hover mb-0 align-middle">
                                        <thead class="table-light" style="position: sticky; top: 0; z-index: 1;">
                                            <tr>
                                                <th>Sucursal</th>
                                                <th class="text-center" style="width:42px;" title="Huella digital"><i class="bi bi-fingerprint"></i></th>
                                                <th class="text-center" style="width:42px;" title="PIN"><i class="bi bi-keyboard"></i></th>
                                                <th class="text-center" style="width:42px;" title="Codigo QR"><i class="bi bi-qr-code"></i></th>
                                                <th class="text-center" style="width:42px;" title="Movil / GPS"><i class="bi bi-phone"></i></th>
                                                <th class="text-center" style="width:42px;" title="Kiosko"><i class="bi bi-display"></i></th>
                                                <th style="width:30px;"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var ls in legajoSucursales)
                                            {
                                                <tr>
                                                    <td><i class="bi bi-check-circle-fill text-success me-1"></i>@ls.Sucursal.Nombre</td>
                                                    <td class="text-center"><input type="checkbox" class="form-check-input" @bind="ls.PermiteHuella" /></td>
                                                    <td class="text-center"><input type="checkbox" class="form-check-input" @bind="ls.PermitePin" /></td>
                                                    <td class="text-center"><input type="checkbox" class="form-check-input" @bind="ls.PermiteQr" /></td>
                                                    <td class="text-center"><input type="checkbox" class="form-check-input" @bind="ls.PermiteMovil" /></td>
                                                    <td class="text-center"><input type="checkbox" class="form-check-input" @bind="ls.PermiteKiosko" /></td>
                                                    <td class="text-center">
                                                        <button type="button" class="btn btn-sm btn-outline-danger py-0 px-1" @onclick="() => DesasignarSucursal(ls)" title="Quitar">
                                                            <i class="bi bi-x"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                            </div>
                        </div>
                    </div>
                <small class="text-muted mt-2 d-block">Click en una sucursal disponible para asignarla. Los cambios se guardan con el boton Guardar.</small>
            }

            @* ===== TAB: HUELLAS ===== *@
            @if (activeTab == "huellas" && IsEdit)
            {
                <h6 class="text-muted mb-3"><i class="bi bi-fingerprint me-1"></i>Huellas registradas</h6>
                @if (huellas.Count == 0)
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-1"></i>
                        Este legajo no tiene huellas registradas. Las huellas se registran desde la aplicacion de escritorio (Fichador).
                    </div>
                }
                else
                {
                    <div class="row g-3">
                        @for (int i = 0; i < 10; i++)
                        {
                            var dedoId = i;
                            var tieneHuella = huellas.Any(h => h.DedoId == dedoId);
                            <div class="col-auto">
                                <div class="text-center p-3 rounded border @(tieneHuella ? "border-success bg-success bg-opacity-10" : "border-light bg-light")">
                                    <i class="bi @(tieneHuella ? "bi-fingerprint text-success" : "bi-dash text-muted") fs-3 d-block mb-1"></i>
                                    <small class="@(tieneHuella ? "text-success fw-semibold" : "text-muted")">@NombreDedo(dedoId)</small>
                                </div>
                            </div>
                        }
                    </div>
                    <small class="text-muted mt-3 d-block">
                        <i class="bi bi-info-circle me-1"></i>
                        @huellas.Count de 10 dedos registrados. Las huellas se gestionan desde la aplicacion de escritorio.
                    </small>
                }
            }

            @* ===== TAB: FICHADAS ===== *@
            @if (activeTab == "fichadas" && IsEdit)
            {
                <div class="row g-2 mb-3 align-items-end">
                    <div class="col-md-2">
                        <label class="form-label">Desde</label>
                        <input type="date" class="form-control form-control-sm" @bind="ficDesde" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Hasta</label>
                        <input type="date" class="form-control form-control-sm" @bind="ficHasta" />
                    </div>
                    <div class="col-md-2">
                        <button type="button" class="btn btn-primary btn-sm" @onclick="CargarFichadas">
                            <i class="bi bi-search me-1"></i>Buscar
                        </button>
                    </div>
                    <div class="col-md-6 text-end">
                        <button type="button" class="btn btn-success btn-sm" @onclick="AbrirNuevaFichada">
                            <i class="bi bi-plus-lg me-1"></i>Nueva Fichada
                        </button>
                    </div>
                </div>

                @if (ficCargando)
                {
                    <div class="text-center py-3"><DigitalPlusMultiTenant.Web.Components.Shared.LoadingIndicator Small="true" Message="Cargando fichadas..." /></div>
                }
                else if (ficItems == null)
                {
                    <div class="alert alert-info small">Seleccione un rango de fechas y presione Buscar.</div>
                }
                else if (!ficItems.Any() && !ficIncidencias.Any())
                {
                    <div class="text-center text-muted py-3"><i class="bi bi-inbox fs-3 d-block mb-2"></i>Sin fichadas ni incidencias en el periodo</div>
                }
                else
                {
                    <table class="table table-sm table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Fecha</th>
                                <th>Hora</th>
                                <th>Tipo</th>
                                <th>Origen</th>
                                <th>Sucursal</th>
                                <th>Detalle</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var f in ficItems!)
                            {
                                <tr>
                                    <td>@f.FechaHora.ToString("dd/MM/yyyy")</td>
                                    <td>@f.FechaHora.ToString("HH:mm:ss")</td>
                                    <td><span class="badge @(f.Tipo == "E" ? "bg-success" : "bg-danger")">@(f.Tipo == "E" ? "Entrada" : "Salida")</span></td>
                                    <td>
                                        @{ var (ficIcon, ficTitle, ficColor) = (f.Origen ?? "") switch
                                        {
                                            "Huella" => ("bi-fingerprint", "Huella", "text-primary"),
                                            "PIN" => ("bi-keyboard", "PIN", "text-warning"),
                                            "Movil" => ("bi-phone", "Movil", "text-success"),
                                            "Manual" => ("bi-pencil-square", "Manual", "text-info"),
                                            "Web" => ("bi-globe", "Web", "text-dark"),
                                            "QR" => ("bi-qr-code", "QR", "text-dark"),
                                            "Demo" => ("bi-play-circle", "Demo", "text-secondary"),
                                            _ => ("bi-fingerprint", "Huella", "text-primary")
                                        }; }
                                        <i class="bi @ficIcon @ficColor" title="@ficTitle"></i>
                                        @if (f.ModificadoPor != null)
                                        {
                                            <i class="bi bi-pencil-fill text-warning ms-1" title="Modificado por @f.ModificadoPor el @f.ModificadoAt?.ToString("dd/MM HH:mm")"></i>
                                        }
                                    </td>
                                    <td class="small text-muted">@f.Sucursal?.Nombre</td>
                                    <td class="small text-muted">
                                        @if (f.Origen == "Manual")
                                        {
                                            <span>por @f.CreatedBy</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => AbrirEditarFichada(f)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        @if (ficConfirmEliminar == f.Id)
                                        {
                                            <button type="button" class="btn btn-sm btn-danger" @onclick="() => ConfirmarEliminarFichada(f)">
                                                <i class="bi bi-check-lg me-1"></i>Confirmar
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => ficConfirmEliminar = 0">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => ficConfirmEliminar = f.Id">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                            @foreach (var il in ficIncidencias)
                            {
                                <tr class="table-light">
                                    <td>@il.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td class="text-muted">—</td>
                                    <td colspan="3">
                                        @if (!string.IsNullOrEmpty(il.Incidencia?.Color))
                                        {
                                            <span class="d-inline-block rounded me-1" style="width:12px;height:12px;background-color:@il.Incidencia.Color;vertical-align:middle;"></span>
                                        }
                                        <span class="badge bg-info">@il.Incidencia?.Nombre</span>
                                        @if (!string.IsNullOrEmpty(il.Detalle))
                                        {
                                            <span class="text-muted small ms-1">@il.Detalle</span>
                                        }
                                    </td>
                                    <td></td>
                                    <td></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                @if (ficMensaje != null)
                {
                    <div class="alert @(ficMensajeOk ? "alert-success" : "alert-danger") py-2 small mt-2">@ficMensaje</div>
                }
            }

            @* ===== TAB: CALENDARIO ===== *@
            @if (activeTab == "calendario" && IsEdit)
            {
                @* ===== GRILLA CALENDARIO MENSUAL ===== *@
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="d-flex align-items-center gap-2">
                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CalMesAnterior">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        <h5 class="mb-0 text-capitalize" style="min-width:180px;text-align:center;">
                            @calMes.ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-AR"))
                        </h5>
                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CalMesSiguiente">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                        <button type="button" class="btn btn-outline-primary btn-sm ms-2" @onclick="CalMesHoy">Hoy</button>
                    </div>
                    @if (model.Horario != null)
                    {
                        <span class="badge bg-light text-dark border">
                            <i class="bi bi-clock me-1"></i>Horario: @model.Horario.Nombre
                        </span>
                    }
                </div>

                <table class="table table-bordered mb-3" style="table-layout:fixed;">
                    <thead>
                        <tr class="text-center bg-light">
                            <th>Lu</th>
                            <th>Ma</th>
                            <th>Mi</th>
                            <th>Ju</th>
                            <th>Vi</th>
                            <th class="text-danger">Sa</th>
                            <th class="text-danger">Do</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var dias = GetCalDias();
                            var hoy = DateOnly.FromDateTime(DateTime.Today);
                        }
                        @for (int fila = 0; fila < dias.Count / 7; fila++)
                        {
                            <tr>
                                @for (int col = 0; col < 7; col++)
                                {
                                    var dia = dias[fila * 7 + col];
                                    if (dia == null)
                                    {
                                        <td class="bg-light" style="height:90px;"></td>
                                    }
                                    else
                                    {
                                        var d = dia.Value;
                                        var esHoy = d == hoy;
                                        var eventos = GetEventosDia(d);
                                        var horarioDia = GetHorarioDia(d);
                                        var esFinDeSemana = col >= 5;
                                        <td style="height:90px;vertical-align:top;padding:4px;cursor:pointer;@(esHoy ? "background-color:#fff3cd;" : esFinDeSemana ? "background-color:#f8f9fa;" : "")"
                                            @onclick="() => CalAbrirNuevo(d)">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <span class="fw-bold small @(esHoy ? "text-warning" : "")">@d.Day</span>
                                                @if (horarioDia != null)
                                                {
                                                    <span class="badge bg-light text-muted border" style="font-size:0.65rem;">
                                                        @horarioDia.HoraDesde.ToString("HH:mm")-@horarioDia.HoraHasta.ToString("HH:mm")
                                                    </span>
                                                }
                                            </div>
                                            @foreach (var ev in eventos)
                                            {
                                                var sucNombre = ev.SucursalId.HasValue ? SucursalesAsignadas.FirstOrDefault(s => s.Id == ev.SucursalId)?.Nombre : null;
                                                var evTitle = (sucNombre != null ? sucNombre + " - " : "") + ev.Nota;
                                                <div class="rounded px-1 mt-1 small text-white text-truncate"
                                                     title="@evTitle"
                                                     style="background-color:#0d6efd;font-size:0.7rem;cursor:pointer;"
                                                     @onclick:stopPropagation="true"
                                                     @onclick="() => CalAbrirEditar(ev)">
                                                    <i class="bi bi-calendar-event"></i>
                                                    @ev.HoraDesde.ToString("HH:mm")-@ev.HoraHasta.ToString("HH:mm")
                                                    @if (sucNombre != null)
                                                    {
                                                        <span class="opacity-75"> @sucNombre</span>
                                                    }
                                                    else if (!string.IsNullOrEmpty(ev.Nota))
                                                    {
                                                        <span> @ev.Nota</span>
                                                    }
                                                </div>
                                            }
                                        </td>
                                    }
                                }
                            </tr>
                        }
                    </tbody>
                </table>

                @* Lista compacta de eventos del mes *@
                @if (GetEventosMes().Count > 0)
                {
                    <h6 class="text-muted mb-2"><i class="bi bi-list-ul me-1"></i>Eventos del mes (@GetEventosMes().Count)</h6>
                    <div class="table-responsive mb-3">
                        <table class="table table-sm table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Desde</th>
                                    <th>Hasta</th>
                                    <th>Horario</th>
                                    <th>Sucursal</th>
                                    <th>Nota</th>
                                    <th style="width:80px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ev in GetEventosMes())
                                {
                                    <tr>
                                        <td>@ev.FechaDesde.ToString("dd/MM/yyyy")</td>
                                        <td>@ev.FechaHasta.ToString("dd/MM/yyyy")</td>
                                        <td>@ev.HoraDesde.ToString("HH:mm") - @ev.HoraHasta.ToString("HH:mm")</td>
                                        <td class="small">@(ev.Sucursal?.Nombre ?? (ev.SucursalId.HasValue ? SucursalesAsignadas.FirstOrDefault(s => s.Id == ev.SucursalId)?.Nombre : ""))</td>
                                        <td class="text-muted small">@ev.Nota</td>
                                        <td>
                                            <button type="button" class="btn btn-outline-primary btn-sm me-1" @onclick="() => CalAbrirEditar(ev)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => CalEliminarEvento(ev)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @* ===== MODAL EVENTO ===== *@
                @if (calShowModal)
                {
                    <div class="modal d-block" tabindex="-1" style="background-color:rgba(0,0,0,0.5);">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">
                                        <i class="bi bi-calendar-event me-1"></i>
                                        @(calEditando != null ? "Editar" : "Nuevo") evento
                                    </h5>
                                    <button type="button" class="btn-close" @onclick="() => calShowModal = false"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="row g-3">
                                        <div class="col-6">
                                            <label class="form-label">Fecha desde</label>
                                            <input type="date" class="form-control" @bind="calModalDesde" />
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label">Fecha hasta</label>
                                            <input type="date" class="form-control" @bind="calModalHasta" />
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label">Hora desde</label>
                                            <input type="time" class="form-control" @bind="calModalHoraDesde" />
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label">Hora hasta</label>
                                            <input type="time" class="form-control" @bind="calModalHoraHasta" />
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">Sucursal</label>
                                            <select class="form-select" @bind="calModalSucursalId">
                                                <option value="">Sin sucursal</option>
                                                @foreach (var s in SucursalesAsignadas)
                                                {
                                                    <option value="@s.Id">@s.Nombre</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">Nota</label>
                                            <input type="text" class="form-control" @bind="calModalNota" placeholder="Inventario, reemplazo, etc..." />
                                        </div>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    @if (calEditando != null)
                                    {
                                        <button type="button" class="btn btn-outline-danger me-auto" @onclick="() => { CalEliminarEvento(calEditando); calShowModal = false; }">
                                            <i class="bi bi-trash me-1"></i>Eliminar
                                        </button>
                                    }
                                    <button type="button" class="btn btn-secondary" @onclick="() => calShowModal = false">Cancelar</button>
                                    <button type="button" class="btn btn-primary" @onclick="CalGuardarEvento">
                                        <i class="bi bi-check-lg me-1"></i>Guardar
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <hr />
                <h6 class="text-muted mb-3"><i class="bi bi-calendar-check me-1"></i>Novedades del legajo</h6>

                @* Registrar incidencia *@
                <div class="card mb-3">
                    <div class="card-body py-2">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-3">
                                <label class="form-label">Incidencia</label>
                                <select class="form-select form-select-sm" @bind="incIndividualId">
                                    <option value="0">-- Seleccionar --</option>
                                    @foreach (var inc in incidenciasDisponibles)
                                    {
                                        <option value="@inc.Id">@inc.Nombre</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Desde</label>
                                <input type="date" class="form-control form-control-sm" @bind="incDesde" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Hasta</label>
                                <input type="date" class="form-control form-control-sm" @bind="incHasta" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Detalle</label>
                                <input type="text" class="form-control form-control-sm" @bind="incDetalle" placeholder="Opcional..." />
                            </div>
                            <div class="col-md-2">
                                <button type="button" class="btn btn-outline-success btn-sm w-100" @onclick="AgregarIncidencia">
                                    <i class="bi bi-plus-lg me-1"></i>Incidencia
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                @* Registrar vacaciones *@
                <div class="card mb-3">
                    <div class="card-body py-2">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-2">
                                <label class="form-label">Vacaciones desde</label>
                                <input type="date" class="form-control form-control-sm" @bind="vacDesde" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Hasta</label>
                                <input type="date" class="form-control form-control-sm" @bind="vacHasta" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Nota</label>
                                <input type="text" class="form-control form-control-sm" @bind="vacNota" placeholder="Opcional..." />
                            </div>
                            <div class="col-md-2">
                                <button type="button" class="btn btn-outline-primary btn-sm w-100" @onclick="AgregarVacacion">
                                    <i class="bi bi-sun me-1"></i>Vacaciones
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                @if (incMensaje != null)
                {
                    <div class="alert @(incMensajeOk ? "alert-success" : "alert-danger") py-2 small">@incMensaje</div>
                }

                @* Filtro y listado unificado *@
                <div class="row g-2 mb-2 align-items-end">
                    <div class="col-md-2">
                        <label class="form-label">Filtrar desde</label>
                        <input type="date" class="form-control form-control-sm" @bind="novDesde" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Hasta</label>
                        <input type="date" class="form-control form-control-sm" @bind="novHasta" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Tipo</label>
                        <select class="form-select form-select-sm" @bind="novFiltroTipo">
                            <option value="">Todos</option>
                            <option value="inc">Incidencias</option>
                            <option value="vac">Vacaciones</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="button" class="btn btn-primary btn-sm" @onclick="StateHasChanged">
                            <i class="bi bi-search me-1"></i>Filtrar
                        </button>
                    </div>
                </div>

                @if (GetNovedadesFiltradas().Count == 0)
                {
                    <div class="alert alert-info small">No hay registros en el periodo seleccionado.</div>
                }
                else
                {
                    <table class="table table-sm table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Tipo</th>
                                <th>Concepto</th>
                                <th>Fecha</th>
                                <th>Detalle</th>
                                <th style="width:100px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var n in GetNovedadesFiltradas())
                            {
                                <tr>
                                    <td>
                                        @if (n.Entidad == "vac")
                                        {
                                            <span class="badge bg-primary"><i class="bi bi-sun me-1"></i>Vacaciones</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark"><i class="bi bi-exclamation-triangle me-1"></i>Incidencia</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(n.Color))
                                        {
                                            <span class="d-inline-block rounded me-1" style="width:12px;height:12px;background-color:@n.Color;vertical-align:middle;"></span>
                                        }
                                        @n.Nombre
                                        @if (n.Entidad == "vac")
                                        {
                                            <span class="text-muted small ms-1">(@n.RangoTexto)</span>
                                        }
                                    </td>
                                    <td>@n.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td class="text-muted small">@n.Detalle</td>
                                    <td>
                                        @if (n.Entidad == "inc")
                                        {
                                            <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => EliminarIncidenciaPorId(n.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                        else if (n.EsPrimerDiaVac)
                                        {
                                            @if (novConfirmEliminar == n.Id)
                                            {
                                                <button type="button" class="btn btn-sm btn-danger" @onclick="() => ConfirmarEliminarVacacion(n.Id)">
                                                    Confirmar
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => novConfirmEliminar = 0">
                                                    <i class="bi bi-x"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => novConfirmEliminar = n.Id"
                                                        title="Eliminar todas las vacaciones de este periodo">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <small class="text-muted">@GetNovedadesFiltradas().Count registros</small>
                }
            }

            @* ===== TAB: MOVIL ===== *@
            @if (activeTab == "movil" && IsEdit && mobileHabilitado)
            {
                <h6 class="text-muted mb-3"><i class="bi bi-phone me-1"></i>Dispositivo Movil</h6>

                @if (terminalMovil != null)
                {
                    <div class="card border-success mb-3">
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-between">
                                <div>
                                    <h6 class="mb-1"><i class="bi bi-check-circle-fill text-success me-1"></i>Dispositivo registrado</h6>
                                    <dl class="row mb-0 small">
                                        <dt class="col-sm-4">Dispositivo</dt>
                                        <dd class="col-sm-8">@(terminalMovil.Nombre ?? "(sin nombre)")</dd>
                                        <dt class="col-sm-4">Plataforma</dt>
                                        <dd class="col-sm-8"><span class="badge bg-info">@(terminalMovil.Plataforma ?? "-")</span></dd>
                                        <dt class="col-sm-4">Registrado</dt>
                                        <dd class="col-sm-8">@terminalMovil.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</dd>
                                        <dt class="col-sm-4">Ultimo uso</dt>
                                        <dd class="col-sm-8">@(terminalMovil.UltimoUso?.ToString("dd/MM/yyyy HH:mm") ?? "Nunca")</dd>
                                        <dt class="col-sm-4">Estado</dt>
                                        <dd class="col-sm-8">
                                            <span class="badge @(terminalMovil.Activo ? "bg-success" : "bg-danger")">
                                                @(terminalMovil.Activo ? "Activo" : "Inactivo")
                                            </span>
                                        </dd>
                                    </dl>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary mb-3">
                        <i class="bi bi-phone me-1"></i>Este legajo no tiene dispositivo movil registrado.
                    </div>
                }

                @if (!model.MobileHabilitado)
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-1"></i>El acceso movil no esta habilitado para este legajo. Activelo en la pestaña Datos.
                    </div>
                }
                else
                {
                    <div class="card mb-3">
                        <div class="card-body">
                            <h6 class="mb-2">Generar codigo de activacion</h6>
                            <p class="text-muted small mb-3">
                                Genera un codigo de activacion para que el empleado registre su dispositivo movil.
                                @if (!string.IsNullOrWhiteSpace(model.Email))
                                {
                                    <span>Se enviara automaticamente a <strong>@model.Email</strong>.</span>
                                }
                                else
                                {
                                    <span class="text-warning">El legajo no tiene email. Debera compartir el codigo manualmente.</span>
                                }
                            </p>
                            <button type="button" class="btn btn-primary btn-sm" @onclick="GenerarCodigoActivacion" disabled="@generandoCodigo">
                                @if (generandoCodigo)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <i class="bi bi-qr-code me-1"></i>Generar codigo
                            </button>

                            @if (codigoActivacionGenerado != null)
                            {
                                <div class="mt-3 p-3 bg-warning bg-opacity-10 border border-warning rounded text-center">
                                    <div class="text-muted small mb-1">Codigo de activacion:</div>
                                    <span style="font-family: monospace; font-size: 1.8rem; font-weight: bold; letter-spacing: 4px;">@codigoActivacionGenerado</span>
                                    <div class="text-muted small mt-1">Valido por 24 horas</div>
                                </div>
                            }

                            @if (movilEmailEnviado)
                            {
                                <div class="alert alert-success small mt-2 mb-0 py-1 d-flex align-items-center justify-content-between">
                                    <span><i class="bi bi-check-circle me-1"></i>Email enviado a <strong>@model.Email</strong></span>
                                    <button type="button" class="btn btn-sm btn-outline-success ms-2" @onclick="ReenviarEmail" disabled="@reenviandoEmail">
                                        @if (reenviandoEmail) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                        <i class="bi bi-arrow-repeat me-1"></i>Reenviar
                                    </button>
                                </div>
                            }
                            @if (movilEmailError != null)
                            {
                                <div class="alert alert-warning small mt-2 mb-0 py-1 d-flex align-items-center justify-content-between">
                                    <span><i class="bi bi-exclamation-triangle me-1"></i>@movilEmailError</span>
                                    @if (codigoActivacionGenerado != null && !string.IsNullOrWhiteSpace(model.Email))
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-warning ms-2" @onclick="ReenviarEmail" disabled="@reenviandoEmail">
                                            @if (reenviandoEmail) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                            <i class="bi bi-arrow-repeat me-1"></i>Reintentar
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            }

            @* ===== BOTONES ===== *@
            <div class="mt-4 pt-3 border-top">
                <button type="submit" class="btn btn-primary me-2"><i class="bi bi-check-lg me-1"></i>Guardar</button>
                <a href="legajos" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </div>
    </div>
</EditForm>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}

@* Modal crear/editar fichada (fuera del EditForm para evitar conflictos de submit) *@
@if (ficShowModal)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(ficEditando != null ? "Editar" : "Nueva") Fichada</h5>
                    <button type="button" class="btn-close" @onclick="() => ficShowModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Fecha</label>
                            <input type="date" class="form-control" @bind="ficModalFecha" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Hora</label>
                            <input type="time" class="form-control" step="1" @bind="ficModalHora" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Tipo</label>
                            <select class="form-select" @bind="ficModalTipo">
                                <option value="E">Entrada</option>
                                <option value="S">Salida</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Sucursal</label>
                            <select class="form-select" @bind="ficModalSucursalId">
                                @foreach (var s in ficSucursales)
                                {
                                    <option value="@s.Id">@s.Nombre</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="() => ficShowModal = false">Cancelar</button>
                    <button class="btn btn-primary btn-sm" @onclick="GuardarFichada">
                        <i class="bi bi-check-lg me-1"></i>Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private bool IsEdit => Id > 0;
    private Legajo model = new() { IsActive = true };
    private List<Sector> sectores = new();
    private List<Categoria> categorias = new();
    private List<Horario> horarios = new();
    private string? errorMessage;
    private string activeTab = "datos";
    private bool mobileHabilitado;

    // Domicilio
    private string? domCalle;
    private string? domAltura;
    private string? domPiso;
    private string? domBarrio;
    private string? domLocalidad;
    private string? domProvincia;
    private string? domCodigoPostal;

    // Sucursales
    private List<LegajoSucursal> legajoSucursales = new();
    private List<Sucursal> SucursalesAsignadas => legajoSucursales.Select(ls => ls.Sucursal).ToList();
    private List<Sucursal> sucursalesDisponibles = new();

    // Huellas
    private List<LegajoHuella> huellas = new();

    // Calendario
    private List<EventoCalendario> eventosCalendario = new();
    private List<EventoCalendario> eventosEliminados = new();
    private DateOnly calMes = DateOnly.FromDateTime(DateTime.Today);
    private bool calShowModal;
    private EventoCalendario? calEditando;
    private DateOnly calModalDesde = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly calModalHasta = DateOnly.FromDateTime(DateTime.Today);
    private TimeOnly calModalHoraDesde = new(9, 0);
    private TimeOnly calModalHoraHasta = new(18, 0);
    private string? calModalNota;
    private int? calModalSucursalId;

    // Movil
    private TerminalMovil? terminalMovil;
    private string? codigoActivacionGenerado;
    private bool generandoCodigo;
    private bool movilEmailEnviado;
    private string? movilEmailError;
    private bool reenviandoEmail;

    // Fichadas
    private List<Fichada>? ficItems;
    private List<IncidenciaLegajo> ficIncidencias = new();
    private List<Sucursal> ficSucursales = new();
    private DateTime ficDesde = DateTime.Today.AddDays(-7);
    private DateTime ficHasta = DateTime.Today;
    private bool ficCargando;
    private int ficConfirmEliminar;
    private string? ficMensaje;
    private bool ficMensajeOk;
    private bool ficShowModal;
    private Fichada? ficEditando;
    private DateOnly ficModalFecha = DateOnly.FromDateTime(DateTime.Today);
    private TimeOnly ficModalHora = TimeOnly.FromDateTime(DateTime.Now);
    private string ficModalTipo = "E";
    private int ficModalSucursalId;

    // Incidencias individuales
