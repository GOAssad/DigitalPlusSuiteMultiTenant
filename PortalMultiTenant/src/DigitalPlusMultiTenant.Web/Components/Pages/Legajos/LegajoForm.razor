    private async Task CargarFichadas()
    {
        ficCargando = true;
        ficMensaje = null;
        StateHasChanged();

        try
        {
            var desde = ficDesde.Date;
            var hasta = ficHasta.Date.AddDays(1);

            ficItems = await Db.Fichadas
                .Include(f => f.Sucursal)
                .Where(f => f.LegajoId == model.Id && f.FechaHora >= desde && f.FechaHora < hasta)
                .OrderByDescending(f => f.FechaHora)
                .ToListAsync();

            var desdeOnly = DateOnly.FromDateTime(ficDesde);
            var hastaOnly = DateOnly.FromDateTime(ficHasta);
            ficIncidencias = await Db.IncidenciaLegajos
                .Include(il => il.Incidencia)
                .Where(il => il.LegajoId == model.Id && il.Fecha >= desdeOnly && il.Fecha <= hastaOnly)
                .OrderByDescending(il => il.Fecha)
                .ToListAsync();
        }
        finally
        {
            ficCargando = false;
        }
    }

