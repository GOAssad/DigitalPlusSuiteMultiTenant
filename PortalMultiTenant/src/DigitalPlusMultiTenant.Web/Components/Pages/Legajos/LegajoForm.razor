    // --- Incidencias individuales ---
    private async Task AgregarIncidencia()
    {
        incMensaje = null;
        if (incIndividualId == 0)
        {
            incMensaje = "Seleccione una incidencia.";
            incMensajeOk = false;
            return;
        }
        if (incDesde > incHasta)
        {
            incMensaje = "La fecha desde no puede ser mayor a la fecha hasta.";
            incMensajeOk = false;
            return;
        }

        var empresaId = model.EmpresaId;
        var now = DateTime.UtcNow;
        var createdBy = Tenant.UserName ?? "portal";
        int insertados = 0;

        for (var fecha = incDesde; fecha <= incHasta; fecha = fecha.AddDays(1))
        {
            var existe = await Db.IncidenciaLegajos
                .AnyAsync(il => il.IncidenciaId == incIndividualId
                            && il.LegajoId == model.Id
                            && il.Fecha == fecha);
            if (!existe)
            {
                var nuevo = new IncidenciaLegajo
                {
                    EmpresaId = empresaId,
                    IncidenciaId = incIndividualId,
                    LegajoId = model.Id,
                    Fecha = fecha,
                    Detalle = incDetalle,
                    CreatedAt = now,
                    CreatedBy = createdBy
                };
                Db.IncidenciaLegajos.Add(nuevo);
                insertados++;
            }
        }

        await Db.SaveChangesAsync();

        // Recargar lista
        incidenciasLegajo = await Db.IncidenciaLegajos
            .Include(il => il.Incidencia)
            .Where(il => il.LegajoId == model.Id)
            .OrderByDescending(il => il.Fecha)
            .Take(200)
            .ToListAsync();

        var dias = incHasta.DayNumber - incDesde.DayNumber + 1;
        incMensaje = $"Registrado: {insertados} dias de {incidenciasDisponibles.FirstOrDefault(i => i.Id == incIndividualId)?.Nombre}.";
        incMensajeOk = true;
        incIndividualId = 0;
        incDetalle = null;
    }

    private record NovedadRow(DateOnly Fecha, string Tipo, string Nombre, string Color, string? Detalle,
        int Id, string Entidad, string? RangoTexto = null, bool EsPrimerDiaVac = false);

    private List<NovedadRow> GetNovedadesFiltradas()
    {
        var all = GetNovedades();
        var filtered = all.Where(n => n.Fecha >= novDesde && n.Fecha <= novHasta);
        if (novFiltroTipo == "inc") filtered = filtered.Where(n => n.Entidad == "inc");
        else if (novFiltroTipo == "vac") filtered = filtered.Where(n => n.Entidad == "vac");
        return filtered.ToList();
    }

    private List<NovedadRow> GetNovedades()
    {
        var novedades = new List<NovedadRow>();
        foreach (var il in incidenciasLegajo)
            novedades.Add(new NovedadRow(il.Fecha, "Incidencia", il.Incidencia?.Nombre ?? "—",
                il.Incidencia?.Color ?? "", il.Detalle, il.Id, "inc"));
        foreach (var v in vacacionesLegajo)
        {
            var rango = $"{v.FechaDesde:dd/MM} al {v.FechaHasta:dd/MM}";
            var primera = true;
            for (var d = v.FechaDesde; d <= v.FechaHasta; d = d.AddDays(1))
            {
                novedades.Add(new NovedadRow(d, "Vacaciones", "Vacaciones", "#2563EB",
                    v.Nota, v.Id, "vac", rango, primera));
                primera = false;
            }
        }
        return novedades.OrderByDescending(n => n.Fecha).ToList();
    }

