    private async Task CalGuardarEvento()
    {
        if (calModalDesde > calModalHasta) return;

        if (calEditando != null)
        {
            calEditando.FechaDesde = calModalDesde;
            calEditando.FechaHasta = calModalHasta;
            calEditando.HoraDesde = calModalHoraDesde;
            calEditando.HoraHasta = calModalHoraHasta;
            calEditando.Nota = calModalNota;
            calEditando.SucursalId = calModalSucursalId;
            if (calEditando.Id > 0)
            {
                var tracked = await Db.EventosCalendario.FindAsync(calEditando.Id);
                if (tracked != null)
                {
                    tracked.FechaDesde = calModalDesde;
                    tracked.FechaHasta = calModalHasta;
                    tracked.HoraDesde = calModalHoraDesde;
                    tracked.HoraHasta = calModalHoraHasta;
                    tracked.Nota = calModalNota;
                    tracked.SucursalId = calModalSucursalId;
                    await Db.SaveChangesAsync();
                }
            }
        }
        else
        {
            var nuevo = new EventoCalendario
            {
                LegajoId = model.Id,
                EmpresaId = model.EmpresaId,
                FechaDesde = calModalDesde,
                FechaHasta = calModalHasta,
                HoraDesde = calModalHoraDesde,
                HoraHasta = calModalHoraHasta,
                Nota = calModalNota,
                SucursalId = calModalSucursalId
            };
            Db.EventosCalendario.Add(nuevo);
            await Db.SaveChangesAsync();
            eventosCalendario.Add(nuevo);
        }
        calShowModal = false;
    }

