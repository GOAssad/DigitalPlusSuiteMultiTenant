    private async Task GuardarFichada()
    {
        ficMensaje = null;
        var fechaHora = ficModalFecha.ToDateTime(ficModalHora);

        if (ficEditando != null)
        {
            // Editar existente
            ficEditando.FechaHora = fechaHora;
            ficEditando.Tipo = ficModalTipo;
            ficEditando.SucursalId = ficModalSucursalId;
            ficEditando.ModificadoPor = Tenant.UserName;
            ficEditando.ModificadoAt = DateTime.UtcNow;
            ficMensaje = "Fichada modificada.";
        }
        else
        {
            // Validar limite de fichadas del plan
            var hace30d = DateTime.UtcNow.AddDays(-30);
            var fichadasUlt30d = await Db.Fichadas.CountAsync(f => f.FechaHora >= hace30d);
            var (ficPermitido, ficLimMensaje) = await LicenciaService.PuedeRegistrarFichadaAsync(Tenant.EmpresaId, fichadasUlt30d);
            if (!ficPermitido)
            {
                ficMensaje = ficLimMensaje;
                ficMensajeOk = false;
                return;
            }

            // Nueva fichada manual
            Db.Fichadas.Add(new Fichada
            {
                EmpresaId = model.EmpresaId,
                LegajoId = model.Id,
                SucursalId = ficModalSucursalId,
                FechaHora = fechaHora,
                Tipo = ficModalTipo,
                Origen = nameof(Domain.Enums.OrigenFichada.Manual),
                CreatedAt = DateTime.UtcNow,
                CreatedBy = Tenant.UserName
            });
            ficMensaje = "Fichada manual registrada.";
        }

        await Db.SaveChangesAsync();
        ficMensajeOk = true;
        ficShowModal = false;
        await CargarFichadas();
    }

