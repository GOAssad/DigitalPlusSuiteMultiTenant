    private void CalMesAnterior() => calMes = calMes.AddMonths(-1);
    private void CalMesSiguiente() => calMes = calMes.AddMonths(1);
    private void CalMesHoy() => calMes = DateOnly.FromDateTime(DateTime.Today);

    private List<DateOnly?> GetCalDias()
    {
        var primero = new DateOnly(calMes.Year, calMes.Month, 1);
        var diasEnMes = DateTime.DaysInMonth(calMes.Year, calMes.Month);
        // Lunes=0 ... Domingo=6
        var offset = ((int)primero.DayOfWeek + 6) % 7;
        var celdas = new List<DateOnly?>();
        for (int i = 0; i < offset; i++) celdas.Add(null);
        for (int d = 1; d <= diasEnMes; d++) celdas.Add(new DateOnly(calMes.Year, calMes.Month, d));
        while (celdas.Count % 7 != 0) celdas.Add(null);
        return celdas;
    }

    private List<EventoCalendario> GetEventosDia(DateOnly dia)
        => eventosCalendario.Where(e => dia >= e.FechaDesde && dia <= e.FechaHasta).ToList();

    private HorarioDetalle? GetHorarioDia(DateOnly dia)
    {
        if (model.Horario?.Detalles == null) return null;
        var diaSemana = dia.DayOfWeek switch
        {
            DayOfWeek.Sunday => Domain.Enums.DiaSemana.Domingo,
            DayOfWeek.Monday => Domain.Enums.DiaSemana.Lunes,
            DayOfWeek.Tuesday => Domain.Enums.DiaSemana.Martes,
            DayOfWeek.Wednesday => Domain.Enums.DiaSemana.Miercoles,
            DayOfWeek.Thursday => Domain.Enums.DiaSemana.Jueves,
            DayOfWeek.Friday => Domain.Enums.DiaSemana.Viernes,
            DayOfWeek.Saturday => Domain.Enums.DiaSemana.Sabado,
            _ => Domain.Enums.DiaSemana.Lunes
        };
        return model.Horario.Detalles.FirstOrDefault(d => d.DiaSemana == diaSemana && !d.IsCerrado);
    }

