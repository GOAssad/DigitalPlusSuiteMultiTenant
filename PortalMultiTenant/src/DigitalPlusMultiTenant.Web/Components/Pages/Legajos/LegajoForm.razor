@page "/legajos/crear"
@page "/legajos/editar/{Id:int}"
@inherits DigitalPlusMultiTenant.Web.Components.DbComponentBase
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize]
@rendermode InteractiveServer

@inject NavigationManager Nav

<PageTitle>@(IsEdit ? "Editar" : "Nuevo") Legajo - DigitalPlus</PageTitle>

<div class="d-flex align-items-center mb-3">
    <a href="legajos" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">@(IsEdit ? "Editar" : "Nuevo") Legajo</h4>
    @if (IsEdit)
    {
        <span class="badge bg-light text-muted ms-2 fs-6">#@model.NumeroLegajo</span>
    }
</div>

<EditForm Model="model" OnValidSubmit="Save" FormName="legajoForm">
    <DataAnnotationsValidator />

    @* ===== TABS ===== *@
    <ul class="nav nav-tabs mb-0" role="tablist">
        <li class="nav-item">
            <button type="button" class="nav-link @(activeTab == "datos" ? "active" : "")"
                    @onclick='() => activeTab = "datos"'>
                <i class="bi bi-person me-1"></i>Datos
            </button>
        </li>
        @if (IsEdit)
        {
            <li class="nav-item">
                <button type="button" class="nav-link @(activeTab == "sucursales" ? "active" : "")"
                        @onclick='() => activeTab = "sucursales"'>
                    <i class="bi bi-building me-1"></i>Sucursales
                    <span class="badge bg-primary ms-1">@sucursalesAsignadas.Count</span>
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link @(activeTab == "huellas" ? "active" : "")"
                        @onclick='() => activeTab = "huellas"'>
                    <i class="bi bi-fingerprint me-1"></i>Huellas
                    <span class="badge bg-primary ms-1">@huellas.Count</span>
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link @(activeTab == "calendario" ? "active" : "")"
                        @onclick='() => activeTab = "calendario"'>
                    <i class="bi bi-calendar-week me-1"></i>Calendario
                </button>
            </li>
        }
    </ul>

    <div class="card border-0 shadow-sm border-top-0 rounded-top-0">
        <div class="card-body">

            @* ===== TAB: DATOS ===== *@
            @if (activeTab == "datos")
            {
                <h6 class="text-muted mb-3"><i class="bi bi-person me-1"></i>Datos personales</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-3">
                        <label class="form-label">Nro. Legajo</label>
                        <InputText @bind-Value="model.NumeroLegajo" class="form-control" />
                        <ValidationMessage For="() => model.NumeroLegajo" class="text-danger small" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Apellido</label>
                        <InputText @bind-Value="model.Apellido" class="form-control" />
                        <ValidationMessage For="() => model.Apellido" class="text-danger small" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Nombre</label>
                        <InputText @bind-Value="model.Nombre" class="form-control" />
                        <ValidationMessage For="() => model.Nombre" class="text-danger small" />
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label class="form-label">Email</label>
                        <InputText @bind-Value="model.Email" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Telefono</label>
                        <InputText @bind-Value="model.Telefono" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Fecha ingreso</label>
                        <InputDate @bind-Value="model.FechaIngreso" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Fecha egreso</label>
                        <InputDate @bind-Value="model.FechaEgreso" class="form-control" />
                    </div>
                </div>

                <h6 class="text-muted mb-3"><i class="bi bi-building me-1"></i>Organizacion</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label class="form-label">Sector</label>
                        <InputSelect @bind-Value="model.SectorId" class="form-select">
                            <option value="0">-- Seleccionar --</option>
                            @foreach (var s in sectores)
                            {
                                <option value="@s.Id">@s.Nombre</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Categoria</label>
                        <InputSelect @bind-Value="model.CategoriaId" class="form-select">
                            <option value="0">-- Seleccionar --</option>
                            @foreach (var c in categorias)
                            {
                                <option value="@c.Id">@c.Nombre</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Horario</label>
                        <InputSelect @bind-Value="model.HorarioId" class="form-select">
                            <option value="">-- Sin horario --</option>
                            @foreach (var h in horarios)
                            {
                                <option value="@h.Id">@h.Nombre</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-3">
                        <label class="form-label">Estado</label>
                        <div class="form-check form-switch mt-2">
                            <InputCheckbox @bind-Value="model.IsActive" class="form-check-input" />
                            <label class="form-check-label">Activo</label>
                        </div>
                    </div>
                </div>
            }

            @* ===== TAB: SUCURSALES ===== *@
            @if (activeTab == "sucursales" && IsEdit)
            {
                <h6 class="text-muted mb-3"><i class="bi bi-building me-1"></i>Sucursales asignadas</h6>
                <div class="row">
                    <div class="col-md-5">
                        <div class="card">
                            <div class="card-header py-2 bg-light">
                                <small class="fw-semibold">Disponibles</small>
                            </div>
                            <div class="list-group list-group-flush" style="max-height: 300px; overflow-y: auto;">
                                @if (sucursalesDisponibles.Count == 0)
                                {
                                    <div class="list-group-item text-muted small">Todas las sucursales estan asignadas</div>
                                }
                                @foreach (var s in sucursalesDisponibles)
                                {
                                    <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                            @onclick="() => AsignarSucursal(s)">
                                        @s.Nombre
                                        <i class="bi bi-arrow-right text-success"></i>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-2 d-flex align-items-center justify-content-center">
                        <i class="bi bi-arrow-left-right text-muted fs-4"></i>
                    </div>
                    <div class="col-md-5">
                        <div class="card border-success">
                            <div class="card-header py-2 bg-success bg-opacity-10">
                                <small class="fw-semibold text-success">Asignadas (@sucursalesAsignadas.Count)</small>
                            </div>
                            <div class="list-group list-group-flush" style="max-height: 300px; overflow-y: auto;">
                                @if (sucursalesAsignadas.Count == 0)
                                {
                                    <div class="list-group-item text-muted small">Sin sucursales asignadas</div>
                                }
                                @foreach (var s in sucursalesAsignadas)
                                {
                                    <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                            @onclick="() => DesasignarSucursal(s)">
                                        <span><i class="bi bi-check-circle-fill text-success me-1"></i>@s.Nombre</span>
                                        <i class="bi bi-x text-danger"></i>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <small class="text-muted mt-2 d-block">Click en una sucursal para moverla. Los cambios se guardan con el boton Guardar.</small>
            }

            @* ===== TAB: HUELLAS ===== *@
            @if (activeTab == "huellas" && IsEdit)
            {
                <h6 class="text-muted mb-3"><i class="bi bi-fingerprint me-1"></i>Huellas registradas</h6>
                @if (huellas.Count == 0)
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-1"></i>
                        Este legajo no tiene huellas registradas. Las huellas se registran desde la aplicacion de escritorio (Fichador).
                    </div>
                }
                else
                {
                    <div class="row g-3">
                        @for (int i = 0; i < 10; i++)
                        {
                            var dedoId = i;
                            var tieneHuella = huellas.Any(h => h.DedoId == dedoId);
                            <div class="col-auto">
                                <div class="text-center p-3 rounded border @(tieneHuella ? "border-success bg-success bg-opacity-10" : "border-light bg-light")">
                                    <i class="bi @(tieneHuella ? "bi-fingerprint text-success" : "bi-dash text-muted") fs-3 d-block mb-1"></i>
                                    <small class="@(tieneHuella ? "text-success fw-semibold" : "text-muted")">@NombreDedo(dedoId)</small>
                                </div>
                            </div>
                        }
                    </div>
                    <small class="text-muted mt-3 d-block">
                        <i class="bi bi-info-circle me-1"></i>
                        @huellas.Count de 10 dedos registrados. Las huellas se gestionan desde la aplicacion de escritorio.
                    </small>
                }
            }

            @* ===== TAB: CALENDARIO ===== *@
            @if (activeTab == "calendario" && IsEdit)
            {
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="form-check form-switch">
                            <InputCheckbox @bind-Value="model.HasCalendarioPersonalizado" class="form-check-input" />
                            <label class="form-check-label fw-semibold">Calendario personalizado</label>
                        </div>
                        <small class="text-muted">
                            @if (model.HasCalendarioPersonalizado)
                            {
                                <span>Este legajo usa un calendario personalizado en lugar del horario general.</span>
                            }
                            else
                            {
                                <span>El legajo sigue el horario general asignado en la pestaña Datos.</span>
                            }
                        </small>
                    </div>
                </div>

                @if (model.HasCalendarioPersonalizado)
                {
                    <hr />
                    <h6 class="text-muted mb-3"><i class="bi bi-calendar-event me-1"></i>Eventos del calendario</h6>

                    <div class="row g-3 mb-3 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label">Fecha desde</label>
                            <input type="date" class="form-control" @bind="nuevoEventoDesde" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Fecha hasta</label>
                            <input type="date" class="form-control" @bind="nuevoEventoHasta" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Nota</label>
                            <input type="text" class="form-control" @bind="nuevoEventoNota" placeholder="Motivo..." />
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn btn-outline-primary w-100" @onclick="AgregarEvento">
                                <i class="bi bi-plus-lg me-1"></i>Agregar
                            </button>
                        </div>
                    </div>

                    @if (eventosCalendario.Count == 0)
                    {
                        <div class="alert alert-info small">No hay eventos personalizados para este legajo.</div>
                    }
                    else
                    {
                        <table class="table table-sm table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Desde</th>
                                    <th>Hasta</th>
                                    <th>Nota</th>
                                    <th style="width:60px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ev in eventosCalendario.OrderBy(e => e.FechaDesde))
                                {
                                    <tr>
                                        <td>@ev.FechaDesde.ToString("dd/MM/yyyy")</td>
                                        <td>@ev.FechaHasta.ToString("dd/MM/yyyy")</td>
                                        <td>@ev.Nota</td>
                                        <td>
                                            <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => EliminarEvento(ev)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                }
            }

            @* ===== BOTONES ===== *@
            <div class="mt-4 pt-3 border-top">
                <button type="submit" class="btn btn-primary me-2"><i class="bi bi-check-lg me-1"></i>Guardar</button>
                <a href="legajos" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </div>
    </div>
</EditForm>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}

@code {
    [Parameter] public int Id { get; set; }
    private bool IsEdit => Id > 0;
    private Legajo model = new() { IsActive = true };
    private List<Sector> sectores = new();
    private List<Categoria> categorias = new();
    private List<Horario> horarios = new();
    private string? errorMessage;
    private string activeTab = "datos";

    // Sucursales
    private List<Sucursal> sucursalesAsignadas = new();
    private List<Sucursal> sucursalesDisponibles = new();

    // Huellas
    private List<LegajoHuella> huellas = new();

    // Calendario
    private List<EventoCalendario> eventosCalendario = new();
    private DateOnly nuevoEventoDesde = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly nuevoEventoHasta = DateOnly.FromDateTime(DateTime.Today);
    private string? nuevoEventoNota;
    private List<EventoCalendario> eventosEliminados = new();

    protected override async Task OnInitializedAsync()
    {
        sectores = await Db.Sectores.Where(s => s.IsActive).OrderBy(s => s.Nombre).ToListAsync();
        categorias = await Db.Categorias.Where(c => c.IsActive).OrderBy(c => c.Nombre).ToListAsync();
        horarios = await Db.Horarios.Where(h => h.IsActive).OrderBy(h => h.Nombre).ToListAsync();

        if (IsEdit)
        {
            var entity = await Db.Legajos
                .Include(l => l.LegajoSucursales).ThenInclude(ls => ls.Sucursal)
                .Include(l => l.Huellas)
                .Include(l => l.EventosCalendario)
                .FirstOrDefaultAsync(l => l.Id == Id);

            if (entity == null) { Nav.NavigateTo("legajos"); return; }
            model = entity;

            // Sucursales
            sucursalesAsignadas = entity.LegajoSucursales
                .Select(ls => ls.Sucursal)
                .OrderBy(s => s.Nombre)
                .ToList();

            var asignadasIds = sucursalesAsignadas.Select(s => s.Id).ToHashSet();
            sucursalesDisponibles = await Db.Sucursales
                .Where(s => s.IsActive && !asignadasIds.Contains(s.Id))
                .OrderBy(s => s.Nombre)
                .ToListAsync();

            // Huellas
            huellas = entity.Huellas.ToList();

            // Calendario
            eventosCalendario = entity.EventosCalendario.ToList();
        }
    }

    // --- Sucursales ---
    private void AsignarSucursal(Sucursal s)
    {
        sucursalesDisponibles.Remove(s);
        sucursalesAsignadas.Add(s);
        sucursalesAsignadas = sucursalesAsignadas.OrderBy(x => x.Nombre).ToList();
    }

    private void DesasignarSucursal(Sucursal s)
    {
        sucursalesAsignadas.Remove(s);
        sucursalesDisponibles.Add(s);
        sucursalesDisponibles = sucursalesDisponibles.OrderBy(x => x.Nombre).ToList();
    }

    // --- Calendario ---
    private void AgregarEvento()
    {
        if (nuevoEventoDesde > nuevoEventoHasta) return;

        eventosCalendario.Add(new EventoCalendario
        {
            LegajoId = model.Id,
            EmpresaId = model.EmpresaId,
            FechaDesde = nuevoEventoDesde,
            FechaHasta = nuevoEventoHasta,
            Nota = nuevoEventoNota
        });

        nuevoEventoDesde = DateOnly.FromDateTime(DateTime.Today);
        nuevoEventoHasta = DateOnly.FromDateTime(DateTime.Today);
        nuevoEventoNota = null;
    }

    private void EliminarEvento(EventoCalendario ev)
    {
        eventosCalendario.Remove(ev);
        if (ev.Id > 0) eventosEliminados.Add(ev);
    }

    // --- Guardar ---
    private async Task Save()
    {
        try
        {
            if (IsEdit)
            {
                // Sucursales: sincronizar
                var existentes = await Db.LegajoSucursales
                    .Where(ls => ls.LegajoId == model.Id)
                    .ToListAsync();
                Db.LegajoSucursales.RemoveRange(existentes);

                foreach (var s in sucursalesAsignadas)
                {
                    Db.LegajoSucursales.Add(new LegajoSucursal
                    {
                        LegajoId = model.Id,
                        SucursalId = s.Id
                    });
                }

                // Calendario: eliminar removidos
                foreach (var ev in eventosEliminados)
                {
                    var tracked = await Db.EventosCalendario.FindAsync(ev.Id);
                    if (tracked != null) Db.EventosCalendario.Remove(tracked);
                }

                // Calendario: agregar nuevos
                foreach (var ev in eventosCalendario.Where(e => e.Id == 0))
                {
                    Db.EventosCalendario.Add(ev);
                }
            }
            else
            {
                Db.Legajos.Add(model);
            }

            await Db.SaveChangesAsync();
            Nav.NavigateTo("legajos");
        }
        catch (DbUpdateException ex)
        {
            errorMessage = ex.InnerException?.Message ?? ex.Message;
        }
    }

    private static string NombreDedo(int dedoId) => dedoId switch
    {
        0 => "Pulgar Der.",
        1 => "Indice Der.",
        2 => "Medio Der.",
        3 => "Anular Der.",
        4 => "Meñique Der.",
        5 => "Pulgar Izq.",
        6 => "Indice Izq.",
        7 => "Medio Izq.",
        8 => "Anular Izq.",
        9 => "Meñique Izq.",
        _ => $"Dedo {dedoId}"
    };
}
