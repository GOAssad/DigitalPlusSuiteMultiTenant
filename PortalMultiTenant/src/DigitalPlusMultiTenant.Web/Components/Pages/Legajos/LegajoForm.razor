        movilEmailEnviado = false;
        StateHasChanged();

        try
        {
            var baseUrl = Nav.BaseUri.TrimEnd('/');
            var link = $"{baseUrl}/mobile/?code={codigoActivacionGenerado}";
            var nombre = model.Nombre ?? model.Apellido ?? "empleado";

            var html = $@"
                <div style='font-family: Segoe UI, Arial, sans-serif; max-width: 480px; margin: 0 auto;'>
                    <div style='background: #0B1120; padding: 20px; text-align: center; border-radius: 8px 8px 0 0;'>
