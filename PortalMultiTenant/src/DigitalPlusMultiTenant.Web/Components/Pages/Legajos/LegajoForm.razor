        }
    }

    private static string GenerarCodigoAleatorio(int longitud)
    {
        const string chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
        var bytes = RandomNumberGenerator.GetBytes(longitud);
        var result = new char[longitud];
        for (int i = 0; i < longitud; i++)
            result[i] = chars[bytes[i] % chars.Length];
        return new string(result);
    }

    // --- Guardar ---
    private async Task Save()
    {
        try
        {
            // Validar sucursal obligatoria
            if (!SucursalesAsignadas.Any())
            {
                errorMessage = "Debe asignar al menos una sucursal al legajo.";
                activeTab = "sucursales";
                return;
            }

            // Validar limite de licencia al crear
            if (!IsEdit)
            {
                var totalLegajos = await Db.Legajos.CountAsync();
                var (permitido, mensaje) = await LicenciaService.PuedeCrearLegajoAsync(Tenant.EmpresaId, totalLegajos);
                if (!permitido)
                {
                    errorMessage = mensaje;
                    return;
                }
            }

            // Domicilio: sincronizar
            var tieneDomicilio = !string.IsNullOrWhiteSpace(domCalle) || !string.IsNullOrWhiteSpace(domAltura)
                || !string.IsNullOrWhiteSpace(domLocalidad) || !string.IsNullOrWhiteSpace(domProvincia);

            if (IsEdit)
            {
                var domExistente = await Db.LegajoDomicilios.FirstOrDefaultAsync(d => d.LegajoId == model.Id);
                if (tieneDomicilio)
                {
                    if (domExistente == null)
                    {
                        domExistente = new LegajoDomicilio { LegajoId = model.Id };
                        Db.LegajoDomicilios.Add(domExistente);
                    }
                    domExistente.Calle = domCalle;
                    domExistente.Altura = domAltura;
                    domExistente.Piso = domPiso;
                    domExistente.Barrio = domBarrio;
                    domExistente.Localidad = domLocalidad;
                    domExistente.Provincia = domProvincia;
                    domExistente.CodigoPostal = domCodigoPostal;
                }
                else if (domExistente != null)
                {
                    Db.LegajoDomicilios.Remove(domExistente);
                }

                // Sucursales: sincronizar
                var existentes = await Db.LegajoSucursales
                    .Where(ls => ls.LegajoId == model.Id)
                    .ToListAsync();
                Db.LegajoSucursales.RemoveRange(existentes);

                foreach (var ls in legajoSucursales)
                {
                    Db.LegajoSucursales.Add(new LegajoSucursal
                    {
                        LegajoId = model.Id,
                        SucursalId = ls.SucursalId,
                        PermiteHuella = ls.PermiteHuella,
                        PermitePin = ls.PermitePin,
                        PermiteQr = ls.PermiteQr,
                        PermiteMovil = ls.PermiteMovil,
                        PermiteKiosko = ls.PermiteKiosko
                    });
                }

                // Calendario: eliminar removidos
                foreach (var ev in eventosEliminados)
                {
                    var tracked = await Db.EventosCalendario.FindAsync(ev.Id);
                    if (tracked != null) Db.EventosCalendario.Remove(tracked);
                }

                // Calendario: agregar nuevos
                foreach (var ev in eventosCalendario.Where(e => e.Id == 0))
                {
                    Db.EventosCalendario.Add(ev);
                }

                // Calendario: actualizar editados
                foreach (var ev in eventosCalendario.Where(e => e.Id > 0))
                {
                    var tracked = await Db.EventosCalendario.FindAsync(ev.Id);
                    if (tracked != null)
                    {
                        tracked.FechaDesde = ev.FechaDesde;
                        tracked.FechaHasta = ev.FechaHasta;
                        tracked.HoraDesde = ev.HoraDesde;
                        tracked.HoraHasta = ev.HoraHasta;
                        tracked.Nota = ev.Nota;
                        tracked.SucursalId = ev.SucursalId;
                    }
                }
            }
            else
            {
                if (tieneDomicilio)
                {
                    model.Domicilio = new LegajoDomicilio
                    {
                        Calle = domCalle,
                        Altura = domAltura,
                        Piso = domPiso,
                        Barrio = domBarrio,
                        Localidad = domLocalidad,
                        Provincia = domProvincia,
                        CodigoPostal = domCodigoPostal
                    };
                }
                // Asignar sucursales al nuevo legajo
                model.LegajoSucursales = legajoSucursales.Select(ls => new LegajoSucursal
                {
                    SucursalId = ls.SucursalId,
                    PermiteHuella = ls.PermiteHuella,
                    PermitePin = ls.PermitePin,
                    PermiteQr = ls.PermiteQr,
                    PermiteMovil = ls.PermiteMovil,
                    PermiteKiosko = ls.PermiteKiosko
                }).ToList();
                // Auto-generar QrToken
                model.QrToken = Guid.NewGuid().ToString("N");
                Db.Legajos.Add(model);
            }

            await Db.SaveChangesAsync();
            Nav.NavigateTo("legajos");
        }
        catch (DbUpdateException ex)
        {
            errorMessage = ex.InnerException?.Message ?? ex.Message;
        }
    }

