@page "/legajos"
@inherits DigitalPlusMultiTenant.Web.Components.DbComponentBase
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize]
@rendermode InteractiveServer

@inject IJSRuntime JS
@inject ITenantService Tenant
@using DigitalPlusMultiTenant.Web.Helpers
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Legajos - DigitalPlus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-people me-2"></i>Legajos</h4>
    <div>
        <button class="btn btn-outline-secondary btn-sm me-2" @onclick="CargarDatos" title="Actualizar"><i class="bi bi-arrow-clockwise"></i></button>
        @if (legajos?.Any() == true)
        {
            <button class="btn btn-outline-dark btn-sm me-1" @onclick="ImprimirTodosQR" title="Imprimir credenciales QR de todos los legajos visibles"><i class="bi bi-qr-code me-1"></i>Imprimir QR</button>
            <button class="btn btn-outline-success btn-sm me-1" @onclick="ExportarExcel"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
            <button class="btn btn-outline-secondary btn-sm me-1" @onclick="ExportarCsv"><i class="bi bi-filetype-csv me-1"></i>CSV</button>
        }
        <AuthorizeView Roles="SuperAdmin,AdminEmpresa,Operador">
            <button class="btn btn-outline-primary btn-sm me-1" @onclick="DescargarPlantilla" title="Descargar plantilla Excel para importación"><i class="bi bi-download me-1"></i>Plantilla</button>
            <button class="btn btn-warning btn-sm me-2" @onclick="() => mostrarImportar = true"><i class="bi bi-upload me-1"></i>Importar</button>
            <a href="legajos/crear" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Nuevo Legajo</a>
        </AuthorizeView>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small mb-1">Buscar</label>
                <input type="text" class="form-control form-control-sm" placeholder="Nombre, apellido o nro legajo..."
                       @bind="filtro" @bind:event="oninput" @bind:after="BuscarDebounce" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Sector</label>
                <select class="form-select form-select-sm" @bind="filtroSector" @bind:after="Buscar">
                    <option value="0">Todos</option>
                    @foreach (var s in sectores)
                    {
                        <option value="@s.Id">@s.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Categoria</label>
                <select class="form-select form-select-sm" @bind="filtroCategoria" @bind:after="Buscar">
                    <option value="0">Todas</option>
                    @foreach (var c in categorias)
                    {
                        <option value="@c.Id">@c.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Estado</label>
                <select class="form-select form-select-sm" @bind="filtroActivo" @bind:after="Buscar">
                    <option value="">Todos</option>
                    <option value="true">Activos</option>
                    <option value="false">Inactivos</option>
                </select>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th role="button" @onclick='() => SetOrden("legajo")'>
                            Legajo @SortIcon("legajo")
                        </th>
                        <th role="button" @onclick='() => SetOrden("nombre")'>
                            Apellido y Nombre @SortIcon("nombre")
                        </th>
                        <th role="button" @onclick='() => SetOrden("sector")'>
                            Sector @SortIcon("sector")
                        </th>
                        <th role="button" @onclick='() => SetOrden("categoria")'>
                            Categoria @SortIcon("categoria")
                        </th>
                        <th role="button" @onclick='() => SetOrden("horario")'>
                            Horario @SortIcon("horario")
                        </th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (legajos == null)
                    {
                        <tr><td colspan="7" class="text-center py-4"><DigitalPlusMultiTenant.Web.Components.Shared.LoadingIndicator Small="true" Message="" /></td></tr>
                    }
                    else if (!legajos.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>No hay legajos</td></tr>
                    }
                    else
                    {
                        @foreach (var l in legajos)
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@l.NumeroLegajo</span></td>
                                <td class="d-flex align-items-center gap-2">
                                    @if (l.Foto != null && l.Foto.Length > 0)
                                    {
                                        <img src="data:image/jpeg;base64,@Convert.ToBase64String(l.Foto)"
                                             class="rounded-circle" style="width:28px;height:28px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <span class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center"
                                              style="width:28px;height:28px;"><i class="bi bi-person text-muted"></i></span>
                                    }
                                    <span><strong>@l.Apellido</strong>, @l.Nombre</span>
                                </td>
                                <td>@l.Sector?.Nombre</td>
                                <td>@l.Categoria?.Nombre</td>
                                <td>@l.Horario?.Nombre</td>
                                <td><span class="badge @(l.IsActive ? "bg-success" : "bg-danger")">@(l.IsActive ? "Activo" : "Inactivo")</span></td>
                                <td class="text-end">
                                    <AuthorizeView Roles="SuperAdmin,AdminEmpresa,Operador">
                                        <button class="btn btn-sm btn-outline-dark me-1" @onclick="() => MostrarQR(l)"
                                                title="Ver QR">
                                            <i class="bi bi-qr-code"></i>
                                        </button>
                                        <a href="legajos/editar/@l.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ToggleActive(l)">
                                            <i class="bi @(l.IsActive ? "bi-x-circle" : "bi-check-circle")"></i>
                                        </button>
                                    </AuthorizeView>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (totalRegistros > 0)
    {
        <div class="card-footer d-flex justify-content-between align-items-center">
            <span class="text-muted small">
                Mostrando @((pagina - 1) * pageSize + 1)-@Math.Min(pagina * pageSize, totalRegistros) de @totalRegistros.ToString("N0")
            </span>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(pagina <= 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => IrPagina(1)" disabled="@(pagina <= 1)">
                            <i class="bi bi-chevron-double-left"></i>
                        </button>
                    </li>
                    <li class="page-item @(pagina <= 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => IrPagina(pagina - 1)" disabled="@(pagina <= 1)">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                    </li>

                    @foreach (var p in GetPaginasVisibles())
                    {
                        <li class="page-item @(p == pagina ? "active" : "")">
                            <button class="page-link" @onclick="() => IrPagina(p)">@p</button>
                        </li>
                    }

                    <li class="page-item @(pagina >= totalPaginas ? "disabled" : "")">
                        <button class="page-link" @onclick="() => IrPagina(pagina + 1)" disabled="@(pagina >= totalPaginas)">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </li>
                    <li class="page-item @(pagina >= totalPaginas ? "disabled" : "")">
                        <button class="page-link" @onclick="() => IrPagina(totalPaginas)" disabled="@(pagina >= totalPaginas)">
                            <i class="bi bi-chevron-double-right"></i>
                        </button>
                    </li>

                    <li class="page-item disabled ms-2">
                        <span class="page-link bg-transparent border-0 text-muted">
                            Pag @pagina de @totalPaginas
                        </span>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

@* ===== MODAL: IMPORTAR EXCEL ===== *@
@if (mostrarImportar)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-upload me-2"></i>Importar Legajos desde Excel</h5>
                    <button type="button" class="btn-close" @onclick="CerrarImportar" disabled="@importando"></button>
                </div>
                <div class="modal-body">
                    @if (importRows == null)
                    {
                        @* Step 1: Upload file *@
                        <div class="text-center py-4">
                            <i class="bi bi-file-earmark-excel fs-1 text-success d-block mb-3"></i>
                            <p class="text-muted mb-3">Seleccioná un archivo Excel (.xlsx) con los legajos a importar.<br/>
                            <small>Podés descargar la <a href="#" @onclick="DescargarPlantilla" @onclick:preventDefault>plantilla</a> con los valores válidos.</small></p>
                            <InputFile OnChange="OnArchivoSeleccionado" accept=".xlsx" class="form-control w-auto d-inline-block" disabled="@cargandoArchivo" />
                            @if (cargandoArchivo)
                            {
                                <div class="mt-3"><div class="spinner-border spinner-border-sm text-primary"></div> Leyendo archivo...</div>
                            }
                            @if (importError != null)
                            {
                                <div class="alert alert-danger mt-3 text-start">@importError</div>
                            }
                        </div>
                    }
                    else
                    {
                        @* Step 2: Preview *@
                        var validos = importRows.Count(r => r.IsValid);
                        var errores = importRows.Count(r => !r.IsValid);
                        var skipped = importRows.Count(r => r.Errores.Any(e => e == "Legajo ya existe"));

                        <div class="d-flex gap-3 mb-3">
                            <span class="badge bg-success fs-6 px-3 py-2"><i class="bi bi-check-circle me-1"></i>@validos válidos</span>
                            @if (errores > 0)
                            {
                                <span class="badge bg-danger fs-6 px-3 py-2"><i class="bi bi-x-circle me-1"></i>@errores con errores</span>
                            }
                            @if (skipped > 0)
                            {
                                <span class="badge bg-secondary fs-6 px-3 py-2"><i class="bi bi-skip-forward me-1"></i>@skipped ya existentes</span>
                            }
                        </div>

                        @if (importResultado != null)
                        {
                            <div class="alert alert-success"><i class="bi bi-check2-all me-1"></i>@importResultado</div>
                        }

                        <div class="table-responsive" style="max-height: 400px;">
                            <table class="table table-sm table-bordered mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th style="width:40px">Fila</th>
                                        <th>Legajo</th>
                                        <th>Apellido</th>
                                        <th>Nombre</th>
                                        <th>Sector</th>
                                        <th>Categoría</th>
                                        <th>Horario</th>
                                        <th>Sucursales</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in importRows)
                                    {
                                        <tr class="@(row.IsValid ? "" : "table-danger")">
                                            <td class="text-muted small">@row.Fila</td>
                                            <td>@row.NumeroLegajo</td>
                                            <td>@row.Apellido</td>
                                            <td>@row.Nombre</td>
                                            <td>@row.SectorNombre</td>
                                            <td>@row.CategoriaNombre</td>
                                            <td>@row.HorarioNombre</td>
                                            <td>@row.SucursalesTexto</td>
                                            <td>
                                                @if (row.IsValid)
                                                {
                                                    <i class="bi bi-check-circle text-success" title="OK"></i>
                                                }
                                                else
                                                {
                                                    <span class="text-danger small" title="@string.Join("; ", row.Errores)">
                                                        <i class="bi bi-x-circle"></i> @row.Errores.First()
                                                        @if (row.Errores.Count > 1) { <span> (+@(row.Errores.Count - 1))</span> }
                                                    </span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    @if (importRows != null && importResultado == null)
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="ResetImportar" disabled="@importando">
                            <i class="bi bi-arrow-left me-1"></i>Cambiar archivo
                        </button>
                    }
                    <button class="btn btn-secondary btn-sm" @onclick="CerrarImportar" disabled="@importando">Cerrar</button>
                    @if (importRows != null && importRows.Any(r => r.IsValid) && importResultado == null)
                    {
                        <button class="btn btn-success btn-sm" @onclick="EjecutarImportacion" disabled="@importando">
                            @if (importando)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            <i class="bi bi-check-lg me-1"></i>Importar @importRows.Count(r => r.IsValid) legajos
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* ===== MODAL: VER QR ===== *@
@if (qrLegajo != null)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-qr-code me-2"></i>Credencial QR</h5>
                    <button type="button" class="btn-close" @onclick="CerrarQR"></button>
                </div>
                <div class="modal-body text-center">
                    @if (qrLegajo.Foto != null && qrLegajo.Foto.Length > 0)
                    {
                        <img src="data:image/jpeg;base64,@Convert.ToBase64String(qrLegajo.Foto)"
                             class="rounded-circle mb-2" style="width:64px;height:64px;object-fit:cover;" />
                    }
                    <div class="fw-bold">@qrLegajo.Apellido, @qrLegajo.Nombre</div>
                    <div class="text-muted small mb-3">Legajo: @qrLegajo.NumeroLegajo</div>
                    <div id="qr-container" class="d-flex justify-content-center mb-2"></div>
                    <div class="text-muted small">@qrLegajo.QrToken</div>
                </div>
                <div class="modal-footer justify-content-between">
                    <button class="btn btn-outline-dark btn-sm" @onclick="() => ImprimirQRIndividual(qrLegajo)">
                        <i class="bi bi-printer me-1"></i>Imprimir
                    </button>
                    <button class="btn btn-primary btn-sm" @onclick="CerrarQR">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Legajo>? legajos;
    private List<Sector> sectores = new();
    private List<Categoria> categorias = new();
    private string filtro = "";
    private int filtroSector;
    private int filtroCategoria;
    private string filtroActivo = "true";

    // Paginacion
    private const int pageSize = 50;
    private int pagina = 1;
    private int totalRegistros;
    private int totalPaginas;

    // Ordenamiento
    private string ordenColumna = "nombre";
    private bool ordenDesc;

    // Debounce
    private CancellationTokenSource? _debounceToken;
    private bool _cargando;

    protected override async Task OnInitializedAsync()
    {
        sectores = await Db.Sectores.Where(s => s.IsActive).OrderBy(s => s.Nombre).ToListAsync();
        categorias = await Db.Categorias.Where(c => c.IsActive).OrderBy(c => c.Nombre).ToListAsync();
        await CargarDatos();
    }

    private async Task BuscarDebounce()
    {
        _debounceToken?.Cancel();
        _debounceToken = new CancellationTokenSource();
        try
        {
            await Task.Delay(400, _debounceToken.Token);
            pagina = 1;
            await CargarDatos();
        }
        catch (TaskCanceledException) { }
    }

    private async Task Buscar()
    {
        _debounceToken?.Cancel();
        pagina = 1;
        await CargarDatos();
    }

    private async Task IrPagina(int p)
    {
        pagina = p;
        await CargarDatos();
    }

    private async Task SetOrden(string columna)
    {
        if (ordenColumna == columna)
            ordenDesc = !ordenDesc;
        else
        {
            ordenColumna = columna;
            ordenDesc = false;
        }
        pagina = 1;
        await CargarDatos();
    }

    private MarkupString SortIcon(string columna)
    {
        if (ordenColumna != columna)
            return new MarkupString("<i class=\"bi bi-chevron-expand text-muted small\"></i>");
        return ordenDesc
            ? new MarkupString("<i class=\"bi bi-sort-down\"></i>")
            : new MarkupString("<i class=\"bi bi-sort-up\"></i>");
    }

    private async Task CargarDatos()
    {
        if (_cargando) return;
        _cargando = true;
        try
        {
        var query = Db.Legajos
            .Include(l => l.Sector)
            .Include(l => l.Categoria)
            .Include(l => l.Horario)
            .AsQueryable();

        if (!string.IsNullOrWhiteSpace(filtro))
        {
            var f = filtro.Trim().ToLower();
            query = query.Where(l => l.Apellido.ToLower().Contains(f)
                || l.Nombre.ToLower().Contains(f)
                || l.NumeroLegajo.ToLower().Contains(f));
        }
        if (filtroSector > 0)
            query = query.Where(l => l.SectorId == filtroSector);
        if (filtroCategoria > 0)
            query = query.Where(l => l.CategoriaId == filtroCategoria);
        if (filtroActivo == "true")
            query = query.Where(l => l.IsActive);
        else if (filtroActivo == "false")
            query = query.Where(l => !l.IsActive);

        totalRegistros = await query.CountAsync();
        totalPaginas = Math.Max(1, (int)Math.Ceiling(totalRegistros / (double)pageSize));
        if (pagina > totalPaginas) pagina = totalPaginas;

        var ordered = ordenColumna switch
        {
            "legajo" => ordenDesc ? query.OrderByDescending(l => l.NumeroLegajo) : query.OrderBy(l => l.NumeroLegajo),
            "sector" => ordenDesc ? query.OrderByDescending(l => l.Sector!.Nombre) : query.OrderBy(l => l.Sector!.Nombre),
            "categoria" => ordenDesc ? query.OrderByDescending(l => l.Categoria!.Nombre) : query.OrderBy(l => l.Categoria!.Nombre),
            "horario" => ordenDesc ? query.OrderByDescending(l => l.Horario!.Nombre) : query.OrderBy(l => l.Horario!.Nombre),
            _ => ordenDesc ? query.OrderByDescending(l => l.Apellido).ThenByDescending(l => l.Nombre) : query.OrderBy(l => l.Apellido).ThenBy(l => l.Nombre),
        };

        legajos = await ordered
            .Skip((pagina - 1) * pageSize)
            .Take(pageSize)
            .ToListAsync();
        }
        finally { _cargando = false; }
    }

    private async Task ExportarExcel()
    {
        if (legajos == null) return;
        var filtros = new List<string>();
        if (!string.IsNullOrWhiteSpace(filtro)) filtros.Add($"Busqueda: {filtro}");
        if (filtroSector > 0) filtros.Add($"Sector: {sectores.FirstOrDefault(s => s.Id == filtroSector)?.Nombre}");
        if (filtroCategoria > 0) filtros.Add($"Categoria: {categorias.FirstOrDefault(c => c.Id == filtroCategoria)?.Nombre}");
        if (filtroActivo == "true") filtros.Add("Estado: Activos");
        else if (filtroActivo == "false") filtros.Add("Estado: Inactivos");
        var bytes = ExcelExporter.Generar(legajos,
            new ExcelExportConfig { Titulo = "Legajos", NombreEmpresa = Tenant.EmpresaNombre, Filtros = filtros,
                Encabezados = ["Legajo", "Apellido", "Nombre", "Sector", "Categoria", "Horario", "Estado"] },
            l => [l.NumeroLegajo, l.Apellido, l.Nombre, l.Sector?.Nombre ?? "", l.Categoria?.Nombre ?? "",
                  l.Horario?.Nombre ?? "", l.IsActive ? "Activo" : "Inactivo"]);
        await JS.InvokeVoidAsync("downloadFile", "legajos.xlsx", Convert.ToBase64String(bytes), "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    private async Task ExportarCsv()
    {
        if (legajos == null) return;
        var bytes = CsvExporter.ToCsvBytes(legajos,
            ["Legajo", "Apellido", "Nombre", "Sector", "Categoria", "Horario", "Estado"],
            l => [l.NumeroLegajo, l.Apellido, l.Nombre, l.Sector?.Nombre ?? "", l.Categoria?.Nombre ?? "",
                  l.Horario?.Nombre ?? "", l.IsActive ? "Activo" : "Inactivo"]);
        await JS.InvokeVoidAsync("downloadFile", "legajos.csv", Convert.ToBase64String(bytes), "text/csv");
    }

    private async Task ToggleActive(Legajo l)
    {
        l.IsActive = !l.IsActive;
        await Db.SaveChangesAsync();
        await CargarDatos();
    }

    private IEnumerable<int> GetPaginasVisibles()
    {
        var start = Math.Max(1, pagina - 2);
        var end = Math.Min(totalPaginas, pagina + 2);
        if (end - start < 4)
        {
            if (start == 1) end = Math.Min(totalPaginas, start + 4);
            else start = Math.Max(1, end - 4);
        }
        for (var i = start; i <= end; i++)
            yield return i;
    }

    // --- QR ---
    private Legajo? qrLegajo;

    private async Task MostrarQR(Legajo legajo)
    {
        // Auto-generar QrToken si no tiene
        if (string.IsNullOrEmpty(legajo.QrToken))
        {
            legajo.QrToken = Guid.NewGuid().ToString("N");
            await Db.SaveChangesAsync();
        }
        qrLegajo = legajo;
        StateHasChanged();
        // Renderizar QR después del render
        await Task.Delay(50);
        await JS.InvokeVoidAsync("qrHelper.render", "qr-container", legajo.QrToken, 5);
    }

    private void CerrarQR() => qrLegajo = null;

    private async Task ImprimirQRIndividual(Legajo legajo)
    {
        var data = new[]
        {
            new
            {
                qrToken = legajo.QrToken,
                nombre = $"{legajo.Apellido}, {legajo.Nombre}",
                numeroLegajo = legajo.NumeroLegajo,
                foto = legajo.Foto != null ? Convert.ToBase64String(legajo.Foto) : (string?)null
            }
        };
        await JS.InvokeVoidAsync("qrHelper.printCredenciales", (object)data);
    }

    private async Task ImprimirTodosQR()
    {
        if (legajos == null || !legajos.Any()) return;

        // Asegurar que todos tengan QrToken
        var sinToken = legajos.Where(l => string.IsNullOrEmpty(l.QrToken)).ToList();
        foreach (var l in sinToken)
            l.QrToken = Guid.NewGuid().ToString("N");
        if (sinToken.Any())
            await Db.SaveChangesAsync();

        var data = legajos.Select(l => new
        {
            qrToken = l.QrToken,
            nombre = $"{l.Apellido}, {l.Nombre}",
            numeroLegajo = l.NumeroLegajo,
            foto = l.Foto != null ? Convert.ToBase64String(l.Foto) : (string?)null
        }).ToArray();

        await JS.InvokeVoidAsync("qrHelper.printCredenciales", (object)data);
    }

    // ===== IMPORTAR EXCEL =====
    private bool mostrarImportar;
    private bool cargandoArchivo;
    private bool importando;
    private string? importError;
    private string? importResultado;
    private List<ImportRow>? importRows;

    private async Task DescargarPlantilla()
    {
        var allSectores = await Db.Sectores.Where(s => s.IsActive).OrderBy(s => s.Nombre).ToListAsync();
        var allCategorias = await Db.Categorias.Where(c => c.IsActive).OrderBy(c => c.Nombre).ToListAsync();
        var allHorarios = await Db.Horarios.Where(h => h.IsActive).OrderBy(h => h.Nombre).ToListAsync();
        var allSucursales = await Db.Sucursales.Where(s => s.IsActive).OrderBy(s => s.Nombre).ToListAsync();

        var bytes = ExcelImporter.GenerarPlantilla(allSectores, allCategorias, allHorarios, allSucursales);
        await JS.InvokeVoidAsync("downloadFile", "plantilla_legajos.xlsx", Convert.ToBase64String(bytes),
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    private async Task OnArchivoSeleccionado(InputFileChangeEventArgs e)
    {
        importError = null;
        importRows = null;
        importResultado = null;
        cargandoArchivo = true;
        StateHasChanged();

        try
        {
            var file = e.File;
            if (file.Size > 5 * 1024 * 1024)
            {
                importError = "El archivo es demasiado grande (máximo 5 MB).";
                return;
            }
            if (!file.Name.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
            {
                importError = "Solo se aceptan archivos .xlsx";
                return;
            }

            using var ms = new MemoryStream();
            await file.OpenReadStream(5 * 1024 * 1024).CopyToAsync(ms);
            var fileBytes = ms.ToArray();

            var allSectores = await Db.Sectores.Where(s => s.IsActive).OrderBy(s => s.Nombre).ToListAsync();
            var allCategorias = await Db.Categorias.Where(c => c.IsActive).OrderBy(c => c.Nombre).ToListAsync();
            var allHorarios = await Db.Horarios.Where(h => h.IsActive).OrderBy(h => h.Nombre).ToListAsync();
            var allSucursales = await Db.Sucursales.Where(s => s.IsActive).OrderBy(s => s.Nombre).ToListAsync();

            var existentes = await Db.Legajos.Select(l => l.NumeroLegajo).ToListAsync();
            var existentesSet = new HashSet<string>(existentes, StringComparer.OrdinalIgnoreCase);

            importRows = ExcelImporter.ParsearExcel(fileBytes, allSectores, allCategorias, allHorarios, allSucursales, existentesSet);

            if (importRows.Count == 0)
            {
                importError = "No se encontraron filas con datos en el archivo.";
                importRows = null;
                return;
            }

        }
        catch (Exception ex)
        {
            importError = $"Error al leer el archivo: {ex.Message}";
        }
        finally
        {
            cargandoArchivo = false;
            StateHasChanged();
        }
    }

    private async Task EjecutarImportacion()
    {
        if (importRows == null || importando) return;

        var validos = importRows.Where(r => r.IsValid).ToList();
        if (validos.Count == 0) return;

        importando = true;
        StateHasChanged();

        try
        {
            var count = 0;
            foreach (var row in validos)
            {
                var legajo = new Legajo
                {
                    NumeroLegajo = row.NumeroLegajo,
                    Apellido = row.Apellido,
                    Nombre = row.Nombre,
                    SectorId = row.SectorId!.Value,
                    CategoriaId = row.CategoriaId!.Value,
                    HorarioId = row.HorarioId,
                    Email = row.Email,
                    Telefono = row.Telefono,
                    FechaIngreso = row.FechaIngreso,
                    IsActive = true,
                    MobileHabilitado = false,
                    QrToken = Guid.NewGuid().ToString("N"),
                    LegajoSucursales = row.SucursalIds.Select(sid => new LegajoSucursal { SucursalId = sid }).ToList()
                };
                Db.Legajos.Add(legajo);
                count++;
            }

            await Db.SaveChangesAsync();
            importResultado = $"Se importaron {count} legajos correctamente.";

            // Refresh the list
            await CargarDatos();
        }
        catch (Exception ex)
        {
            importError = $"Error al importar: {ex.Message}";
        }
        finally
        {
            importando = false;
            StateHasChanged();
        }
    }

    private void ResetImportar()
    {
        importRows = null;
        importError = null;
        importResultado = null;
    }

    private void CerrarImportar()
    {
        mostrarImportar = false;
        ResetImportar();
    }
}
