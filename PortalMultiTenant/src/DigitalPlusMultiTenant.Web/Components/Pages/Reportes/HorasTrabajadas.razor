@page "/reportes/horas-trabajadas"
@inherits DigitalPlusMultiTenant.Web.Components.DbComponentBase
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize]
@rendermode InteractiveServer

@inject IJSRuntime JS
@inject ITenantService Tenant
@using DigitalPlusMultiTenant.Web.Helpers

<PageTitle>Horas Trabajadas - DigitalPlus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-hourglass-split me-2"></i>Horas Trabajadas</h4>
    <div>
        <button class="btn btn-outline-secondary btn-sm me-2" @onclick="Generar" title="Actualizar"><i class="bi bi-arrow-clockwise"></i></button>
        @if (items?.Any() == true)
        {
            <button class="btn btn-outline-success btn-sm me-1" @onclick="ExportarExcel"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="ExportarCsv"><i class="bi bi-filetype-csv me-1"></i>CSV</button>
        }
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small mb-1">Desde</label>
                <input type="date" class="form-control form-control-sm" @bind="fechaDesde" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Hasta</label>
                <input type="date" class="form-control form-control-sm" @bind="fechaHasta" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Sucursal</label>
                <select class="form-select form-select-sm" @bind="filtroSucursal">
                    <option value="0">Todas</option>
                    @foreach (var s in sucursales)
                    {
                        <option value="@s.Id">@s.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Sector</label>
                <select class="form-select form-select-sm" @bind="filtroSector">
                    <option value="0">Todos</option>
                    @foreach (var s in sectores)
                    {
                        <option value="@s.Id">@s.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Buscar</label>
                <input type="text" class="form-control form-control-sm" placeholder="Legajo..." @bind="filtroLegajo" />
            </div>
            <div class="col-md-2 d-flex gap-1">
                <button class="btn btn-primary btn-sm" @onclick="Generar" disabled="@cargando">
                    @if (cargando)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    <i class="bi bi-search me-1"></i>Generar
                </button>
                @if (cargando)
                {
                    <button class="btn btn-outline-danger btn-sm" @onclick="Cancelar">
                        <i class="bi bi-x-circle me-1"></i>Cancelar
                    </button>
                }
            </div>
        </div>
        @if (!string.IsNullOrEmpty(mensajeError))
        {
            <div class="alert alert-danger py-1 mt-2 mb-0 small">@mensajeError</div>
        }
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th role="button" @onclick='() => SetOrden("legajo")'>Legajo @SortIcon("legajo")</th>
                        <th role="button" @onclick='() => SetOrden("nombre")'>Apellido y Nombre @SortIcon("nombre")</th>
                        <th>Sector</th>
                        <th role="button" @onclick='() => SetOrden("presentes")'>Dias Presente @SortIcon("presentes")</th>
                        <th role="button" @onclick='() => SetOrden("ausentes")'>Dias Ausente @SortIcon("ausentes")</th>
                        <th role="button" @onclick='() => SetOrden("total")'>Horas Total @SortIcon("total")</th>
                        <th role="button" @onclick='() => SetOrden("promedio")'>Promedio Diario @SortIcon("promedio")</th>
                        <th role="button" @onclick='() => SetOrden("tardes")'>Llegadas Tarde @SortIcon("tardes")</th>
                        <th role="button" @onclick='() => SetOrden("huella")'>Huella @SortIcon("huella")</th>
                        <th role="button" @onclick='() => SetOrden("pin")'>PIN @SortIcon("pin")</th>
                    </tr>
                </thead>
                <tbody>
                    @if (items == null)
                    {
                        <tr><td colspan="10" class="text-center text-muted py-4"><i class="bi bi-bar-chart fs-3 d-block mb-2"></i>Seleccione rango de fechas y presione Generar</td></tr>
                    }
                    else if (!items.Any())
                    {
                        <tr><td colspan="10" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>Sin resultados para el rango seleccionado</td></tr>
                    }
                    else
                    {
                        @foreach (var r in items)
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@r.NumeroLegajo</span></td>
                                <td><strong>@r.Apellido</strong>, @r.Nombre</td>
                                <td>@r.Sector</td>
                                <td>
                                    <span class="badge bg-success">@r.DiasPresente</span>
                                    <span class="text-muted small">/ @r.DiasLaborables</span>
                                </td>
                                <td>
                                    @if (r.DiasAusente > 0)
                                    {
                                        <span class="badge bg-danger">@r.DiasAusente</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted">0</span>
                                    }
                                </td>
                                <td>
                                    <strong>@FormatHoras(r.HorasTotal)</strong>
                                </td>
                                <td>
                                    @if (r.DiasPresente > 0)
                                    {
                                        var promedio = r.HorasTotal.TotalHours / r.DiasPresente;
                                        <span class="@(promedio < 6 ? "text-warning fw-bold" : "")">@($"{promedio:F1}") hs</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (r.LlegadasTarde > 0)
                                    {
                                        <span class="badge bg-warning text-dark">@r.LlegadasTarde</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted">0</span>
                                    }
                                </td>
                                <td>
                                    @if (r.FichadasHuella > 0)
                                    {
                                        <span class="badge bg-primary">@r.FichadasHuella</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted">0</span>
                                    }
                                </td>
                                <td>
                                    @if (r.FichadasPin > 0)
                                    {
                                        <span class="badge bg-warning text-dark">@r.FichadasPin</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted">0</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (items != null && items.Any())
    {
        <div class="card-footer text-muted small">
            @items.Count empleados &mdash;
            Total horas: @FormatHoras(TimeSpan.FromHours(items.Sum(r => r.HorasTotal.TotalHours))) &mdash;
            Promedio general: @($"{(items.Where(r => r.DiasPresente > 0).Any() ? items.Where(r => r.DiasPresente > 0).Average(r => r.HorasTotal.TotalHours / r.DiasPresente) : 0):F1}") hs/dia
        </div>
    }
</div>

@code {
    private List<HorasRow>? items;
    private List<Sucursal> sucursales = new();
    private List<Sector> sectores = new();
    private DateTime fechaDesde = Clock.Today.AddDays(1 - Clock.Today.Day);
    private DateTime fechaHasta = Clock.Today;
    private int filtroSucursal;
    private int filtroSector;
    private string filtroLegajo = "";
    private bool cargando;
    private string ordenColumna = "nombre";
    private bool ordenDesc;
    private string mensajeError = "";
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        sucursales = await Db.Sucursales.Where(s => s.IsActive).OrderBy(s => s.Nombre).ToListAsync();
        sectores = await Db.Sectores.Where(s => s.IsActive).OrderBy(s => s.Nombre).ToListAsync();
    }

    private string FormatHoras(TimeSpan ts) => $"{(int)ts.TotalHours}:{ts.Minutes:D2}";

    private async Task Generar()
    {
        mensajeError = "";
        if (fechaDesde > fechaHasta) { mensajeError = "La fecha Desde no puede ser posterior a Hasta."; return; }
        if ((fechaHasta - fechaDesde).TotalDays > 366) { mensajeError = "El rango maximo permitido es de 1 ano (366 dias)."; return; }

        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        cargando = true;
        StateHasChanged();
        try
        {
            var desde = DateOnly.FromDateTime(fechaDesde);
            var hasta = DateOnly.FromDateTime(fechaHasta);
            var hoy = Clock.TodayDate;
            if (hasta > hoy) hasta = hoy;

            var legajosQuery = Db.Legajos
                .Include(l => l.Horario).ThenInclude(h => h!.Detalles)
                .Include(l => l.Sector)
                .Where(l => l.IsActive);

            if (filtroSector > 0)
                legajosQuery = legajosQuery.Where(l => l.SectorId == filtroSector);

            if (!string.IsNullOrWhiteSpace(filtroLegajo))
            {
                var f = filtroLegajo.Trim().ToLower();
                legajosQuery = legajosQuery.Where(l => l.Apellido.ToLower().Contains(f)
                    || l.Nombre.ToLower().Contains(f)
                    || l.NumeroLegajo.ToLower().Contains(f));
            }

            var legajos = await legajosQuery.ToListAsync(token);
            token.ThrowIfCancellationRequested();

            var fichadasQuery = Db.Fichadas
                .Where(f => f.FechaHora >= fechaDesde.Date && f.FechaHora < fechaHasta.Date.AddDays(1));

            if (filtroSucursal > 0)
                fichadasQuery = fichadasQuery.Where(f => f.SucursalId == filtroSucursal);

            var fichadas = await fichadasQuery.ToListAsync(token);
            token.ThrowIfCancellationRequested();

            var feriados = await Db.Feriados
                .Where(f => f.Fecha >= desde && f.Fecha <= hasta)
                .Select(f => f.Fecha)
                .ToListAsync(token);

            var vacaciones = await Db.Vacaciones
                .Where(v => v.FechaDesde <= hasta && v.FechaHasta >= desde)
                .ToListAsync(token);

            var eventosCalendario = await Db.EventosCalendario
                .Where(e => e.FechaDesde <= hasta && e.FechaHasta >= desde)
                .ToListAsync(token);

            token.ThrowIfCancellationRequested();
            var resultado = new List<HorasRow>();

            foreach (var leg in legajos)
            {
                token.ThrowIfCancellationRequested();
                var fichadasLeg = fichadas.Where(f => f.LegajoId == leg.Id).ToList();
                int diasPresente = 0, diasAusente = 0, diasLaborables = 0, llegadasTarde = 0;
                var horasTotal = TimeSpan.Zero;

                for (var dia = desde; dia <= hasta; dia = dia.AddDays(1))
                {
                    if (feriados.Contains(dia)) continue;
                    var diaSemana = (int)dia.DayOfWeek + 1;
                    var horarioDia = leg.Horario?.Detalles?.FirstOrDefault(d => (int)d.DiaSemana == diaSemana);
                    if (horarioDia == null || horarioDia.IsCerrado) continue;

                    var enVacaciones = vacaciones.Any(v => v.LegajoId == leg.Id && v.FechaDesde <= dia && v.FechaHasta >= dia);
                    if (enVacaciones) continue;

                    var tieneEvento = eventosCalendario.Any(e => e.LegajoId == leg.Id && e.FechaDesde <= dia && e.FechaHasta >= dia);
                    if (tieneEvento) continue;

                    diasLaborables++;

                    var fichasDia = fichadasLeg.Where(f => DateOnly.FromDateTime(f.FechaHora) == dia).ToList();
                    var entrada = fichasDia.Where(f => f.Tipo == "E").OrderBy(f => f.FechaHora).FirstOrDefault();
                    var salida = fichasDia.Where(f => f.Tipo == "S").OrderByDescending(f => f.FechaHora).FirstOrDefault();

                    if (entrada != null)
                    {
                        diasPresente++;

                        var horaEntrada = TimeOnly.FromDateTime(entrada.FechaHora);
                        if (horaEntrada > horarioDia.HoraDesde.AddMinutes(5))
                            llegadasTarde++;

                        if (salida != null && salida.FechaHora > entrada.FechaHora)
                            horasTotal += salida.FechaHora - entrada.FechaHora;
                    }
                    else
                    {
                        diasAusente++;
                    }
                }

                resultado.Add(new HorasRow
                {
                    NumeroLegajo = leg.NumeroLegajo,
                    Apellido = leg.Apellido,
                    Nombre = leg.Nombre,
                    Sector = leg.Sector?.Nombre ?? "",
                    DiasPresente = diasPresente,
                    DiasAusente = diasAusente,
                    DiasLaborables = diasLaborables,
                    HorasTotal = horasTotal,
                    LlegadasTarde = llegadasTarde,
                    FichadasHuella = fichadasLeg.Count(f => f.Origen == "Huella" || f.Origen == null),
                    FichadasPin = fichadasLeg.Count(f => f.Origen == "PIN")
                });
            }

            items = Ordenar(resultado);
        }
        catch (OperationCanceledException)
        {
            mensajeError = "Consulta cancelada.";
        }
        finally
        {
            cargando = false;
        }
    }

    private void Cancelar()
    {
        _cts?.Cancel();
    }

    public override async ValueTask DisposeAsync()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        await base.DisposeAsync();
    }

    private void SetOrden(string columna)
    {
        if (ordenColumna == columna) ordenDesc = !ordenDesc;
        else { ordenColumna = columna; ordenDesc = false; }
        if (items != null) items = Ordenar(items);
    }

    private List<HorasRow> Ordenar(List<HorasRow> data)
    {
        return (ordenColumna switch
        {
            "legajo" => ordenDesc ? data.OrderByDescending(r => r.NumeroLegajo) : data.OrderBy(r => r.NumeroLegajo),
            "presentes" => ordenDesc ? data.OrderByDescending(r => r.DiasPresente) : data.OrderBy(r => r.DiasPresente),
            "ausentes" => ordenDesc ? data.OrderByDescending(r => r.DiasAusente) : data.OrderBy(r => r.DiasAusente),
            "total" => ordenDesc ? data.OrderByDescending(r => r.HorasTotal) : data.OrderBy(r => r.HorasTotal),
            "promedio" => ordenDesc
                ? data.OrderByDescending(r => r.DiasPresente > 0 ? r.HorasTotal.TotalHours / r.DiasPresente : 0)
                : data.OrderBy(r => r.DiasPresente > 0 ? r.HorasTotal.TotalHours / r.DiasPresente : 0),
            "tardes" => ordenDesc ? data.OrderByDescending(r => r.LlegadasTarde) : data.OrderBy(r => r.LlegadasTarde),
            "huella" => ordenDesc ? data.OrderByDescending(r => r.FichadasHuella) : data.OrderBy(r => r.FichadasHuella),
            "pin" => ordenDesc ? data.OrderByDescending(r => r.FichadasPin) : data.OrderBy(r => r.FichadasPin),
            _ => ordenDesc ? data.OrderByDescending(r => r.Apellido).ThenByDescending(r => r.Nombre) : data.OrderBy(r => r.Apellido).ThenBy(r => r.Nombre),
        }).ToList();
    }

    private MarkupString SortIcon(string columna)
    {
        if (ordenColumna != columna)
            return new MarkupString("<i class=\"bi bi-chevron-expand text-muted small\"></i>");
        return ordenDesc
            ? new MarkupString("<i class=\"bi bi-sort-down\"></i>")
            : new MarkupString("<i class=\"bi bi-sort-up\"></i>");
    }

    private async Task ExportarExcel()
    {
        if (items == null) return;
        var filtros = new List<string>();
        if (filtroSucursal > 0) filtros.Add($"Sucursal: {sucursales.FirstOrDefault(s => s.Id == filtroSucursal)?.Nombre}");
        if (filtroSector > 0) filtros.Add($"Sector: {sectores.FirstOrDefault(s => s.Id == filtroSector)?.Nombre}");
        if (!string.IsNullOrWhiteSpace(filtroLegajo)) filtros.Add($"Legajo: {filtroLegajo}");
        var bytes = ExcelExporter.Generar(items,
            new ExcelExportConfig { Titulo = "Reporte de Horas Trabajadas", NombreEmpresa = Tenant.EmpresaNombre,
                FechaDesde = fechaDesde.ToString("dd/MM/yyyy"), FechaHasta = fechaHasta.ToString("dd/MM/yyyy"),
                Filtros = filtros,
                Encabezados = ["Legajo", "Apellido", "Nombre", "Sector", "Dias Presente", "Dias Ausente", "Dias Laborables", "Horas Total", "Promedio Diario", "Llegadas Tarde", "Fichadas Huella", "Fichadas PIN"],
                Formatos = [ExcelColFormat.Texto, ExcelColFormat.Texto, ExcelColFormat.Texto, ExcelColFormat.Texto,
                           ExcelColFormat.Numero, ExcelColFormat.Numero, ExcelColFormat.Numero, ExcelColFormat.Texto, ExcelColFormat.Decimal, ExcelColFormat.Numero, ExcelColFormat.Numero, ExcelColFormat.Numero] },
            r => [r.NumeroLegajo, r.Apellido, r.Nombre, r.Sector, r.DiasPresente, r.DiasAusente,
                  r.DiasLaborables, FormatHoras(r.HorasTotal),
                  r.DiasPresente > 0 ? (object)Math.Round(r.HorasTotal.TotalHours / r.DiasPresente, 1) : 0.0, r.LlegadasTarde,
                  r.FichadasHuella, r.FichadasPin]);
        await JS.InvokeVoidAsync("downloadFile", "horas_trabajadas.xlsx", Convert.ToBase64String(bytes), "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    private async Task ExportarCsv()
    {
        if (items == null) return;
        var bytes = CsvExporter.ToCsvBytes(items,
            ["Legajo", "Apellido", "Nombre", "Sector", "Dias Presente", "Dias Ausente", "Dias Laborables", "Horas Total", "Promedio Diario", "Llegadas Tarde", "Fichadas Huella", "Fichadas PIN"],
            r => [r.NumeroLegajo, r.Apellido, r.Nombre, r.Sector, r.DiasPresente.ToString(), r.DiasAusente.ToString(),
                  r.DiasLaborables.ToString(), FormatHoras(r.HorasTotal),
                  r.DiasPresente > 0 ? $"{r.HorasTotal.TotalHours / r.DiasPresente:F1}" : "0", r.LlegadasTarde.ToString(),
                  r.FichadasHuella.ToString(), r.FichadasPin.ToString()]);
        await JS.InvokeVoidAsync("downloadFile", "horas_trabajadas.csv", Convert.ToBase64String(bytes), "text/csv");
    }

    private class HorasRow
    {
        public string NumeroLegajo { get; set; } = "";
        public string Apellido { get; set; } = "";
        public string Nombre { get; set; } = "";
        public string Sector { get; set; } = "";
        public int DiasPresente { get; set; }
        public int DiasAusente { get; set; }
        public int DiasLaborables { get; set; }
        public TimeSpan HorasTotal { get; set; }
        public int LlegadasTarde { get; set; }
        public int FichadasHuella { get; set; }
        public int FichadasPin { get; set; }
    }
}
