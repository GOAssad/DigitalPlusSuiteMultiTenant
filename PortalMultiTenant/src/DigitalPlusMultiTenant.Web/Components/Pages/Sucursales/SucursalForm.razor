@page "/sucursales/crear"
@page "/sucursales/editar/{Id:int}"
@inherits DigitalPlusMultiTenant.Web.Components.DbComponentBase
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@using System.Text.Json
@attribute [Authorize(Roles = "SuperAdmin,AdminEmpresa")]
@rendermode InteractiveServer
@implements IAsyncDisposable

@inject NavigationManager Nav
@inject ITenantService Tenant
@inject IJSRuntime JS

<PageTitle>@(IsEdit ? "Editar" : "Nueva") Sucursal - DigitalPlus</PageTitle>

@if (Tenant.MobileHabilitado)
{
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="/js/leaflet-map.js"></script>
}

<div class="d-flex align-items-center mb-3">
    <a href="sucursales" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">@(IsEdit ? "Editar" : "Nueva") Sucursal</h4>
</div>

@* ====== DATOS GENERALES ====== *@
<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white">
        <h6 class="mb-0"><i class="bi bi-building me-2"></i>Datos Generales</h6>
    </div>
    <div class="card-body">
        <EditForm Model="model" OnValidSubmit="Save" FormName="sucursalForm">
            <DataAnnotationsValidator />
            <div class="row g-3">
                <div class="col-md-2">
                    <label class="form-label">Código</label>
                    <InputText @bind-Value="model.Codigo" class="form-control" />
                    <ValidationMessage For="() => model.Codigo" class="text-danger small" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">Nombre</label>
                    <InputText @bind-Value="model.Nombre" class="form-control" />
                    <ValidationMessage For="() => model.Nombre" class="text-danger small" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Teléfono</label>
                    <InputText @bind-Value="model.Telefono" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Estado</label>
                    <div class="form-check form-switch mt-2">
                        <InputCheckbox @bind-Value="model.IsActive" class="form-check-input" />
                        <label class="form-check-label">Activa</label>
                    </div>
                </div>
            </div>
            <div class="row g-3 mt-0">
                <div class="col-md-5">
                    <label class="form-label">Dirección</label>
                    <InputText @bind-Value="model.Direccion" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Localidad</label>
                    <InputText @bind-Value="model.Localidad" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Provincia</label>
                    <InputText @bind-Value="model.Provincia" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Email</label>
                    <InputText @bind-Value="model.Email" class="form-control" />
                </div>
            </div>

            @* ====== UBICACIÓN GPS ====== *@
            @if (Tenant.MobileHabilitado)
            {
                <hr class="my-4" />
                <h6 class="mb-3"><i class="bi bi-geo-alt me-2"></i>Ubicación para Fichado Móvil</h6>

                @* Search bar *@
                <div class="row g-2 mb-3">
                    <div class="col">
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" class="form-control" placeholder="Buscar dirección... (ej: Av. Corrientes 1234, Buenos Aires)"
                                   @bind="searchQuery" @bind:event="oninput"
                                   @onkeydown="HandleSearchKeydown" />
                            <button type="button" class="btn btn-outline-primary" @onclick="SearchAddress">Buscar</button>
                        </div>
                    </div>
                </div>

                @* Search results dropdown *@
                @if (searchResults.Count > 0)
                {
                    <div class="list-group mb-3 shadow-sm" style="max-height: 200px; overflow-y: auto;">
                        @foreach (var r in searchResults)
                        {
                            <button type="button" class="list-group-item list-group-item-action small py-2"
                                    @onclick="() => SelectSearchResult(r)">
                                <i class="bi bi-geo-alt text-primary me-1"></i>@r.DisplayName
                            </button>
                        }
                    </div>
                }

                @* Map *@
                <div id="sucursal-map" style="height: 350px; border-radius: 8px; border: 1px solid #dee2e6; margin-bottom: 1rem;"></div>

                @* GPS fields *@
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Latitud</label>
                        <input type="number" step="0.0000001" class="form-control" @bind="geoLatitud"
                               @bind:after="OnCoordsManualChange" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Longitud</label>
                        <input type="number" step="0.0000001" class="form-control" @bind="geoLongitud"
                               @bind:after="OnCoordsManualChange" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Radio (metros)</label>
                        <input type="number" class="form-control" @bind="geoRadio"
                               @bind:after="OnRadioChange" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Fichado GPS</label>
                        <div class="form-check form-switch mt-2">
                            <input class="form-check-input" type="checkbox" @bind="geoActivo" />
                            <label class="form-check-label small">@(geoActivo ? "Activo" : "Inactivo")</label>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <p class="text-muted small mt-4 mb-0">
                            <i class="bi bi-info-circle me-1"></i>
                            Click en el mapa o busque una dirección. Arrastre el marcador para ajustar.
                        </p>
                    </div>
                </div>
            }

            <div class="mt-4">
                <button type="submit" class="btn btn-primary me-2"><i class="bi bi-check-lg me-1"></i>Guardar</button>
                <a href="sucursales" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </EditForm>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    private bool IsEdit => Id > 0;
    private Sucursal model = new() { IsActive = true };
    private string? errorMessage;

    // Geoconfig fields
    private SucursalGeoconfig? geoconfig;
    private string geoMetodo = "SoloGPS";
    private double? geoLatitud;
    private double? geoLongitud;
    private int geoRadio = 100;
    private bool geoActivo = true;
    // WiFi fields preserved for backwards compat but not shown in UI
    private string? geoBssid;
    private string? geoSsid;

    // Map search
    private string searchQuery = "";
    private List<SearchResult> searchResults = new();
    private DotNetObjectReference<SucursalForm>? dotnetRef;
    private bool mapInitialized;

    protected override async Task OnInitializedAsync()
    {
        if (IsEdit)
        {
            var entity = await Db.Sucursales
                .Include(s => s.Geoconfig)
                .FirstOrDefaultAsync(s => s.Id == Id);

            if (entity == null)
            {
                Nav.NavigateTo("sucursales");
                return;
            }
            model = entity;

            if (entity.Geoconfig != null)
            {
                geoconfig = entity.Geoconfig;
                geoMetodo = geoconfig.MetodoValidacion;
                geoLatitud = geoconfig.Latitud.HasValue ? (double)geoconfig.Latitud.Value : null;
                geoLongitud = geoconfig.Longitud.HasValue ? (double)geoconfig.Longitud.Value : null;
                geoRadio = geoconfig.RadioMetros;
                geoActivo = geoconfig.Activo;
                geoBssid = geoconfig.WifiBSSID;
                geoSsid = geoconfig.WifiSSID;
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Tenant.MobileHabilitado)
        {
            // Small delay to let Leaflet JS load
            await Task.Delay(300);
            dotnetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("LeafletMap.init", "sucursal-map", dotnetRef,
                geoLatitud, geoLongitud, geoRadio);
            mapInitialized = true;
        }
    }

    // Called from JS when user clicks/drags on the map
    [JSInvokable]
    public void OnMapPositionChanged(double lat, double lng)
    {
        geoLatitud = Math.Round(lat, 7);
        geoLongitud = Math.Round(lng, 7);
        InvokeAsync(StateHasChanged);
    }

    // Called from JS with reverse geocoding results
    [JSInvokable]
    public void OnReverseGeocode(string json)
    {
        try
        {
            var info = JsonSerializer.Deserialize<GeoInfo>(json,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (info != null)
            {
                if (!string.IsNullOrEmpty(info.Direccion)) model.Direccion = info.Direccion;
                if (!string.IsNullOrEmpty(info.Localidad)) model.Localidad = info.Localidad;
                if (!string.IsNullOrEmpty(info.Provincia)) model.Provincia = info.Provincia;
                InvokeAsync(StateHasChanged);
            }
        }
        catch { }
    }

    // Called from JS with search results
    [JSInvokable]
    public void OnSearchResults(string json)
    {
        try
        {
            var items = JsonSerializer.Deserialize<List<SearchResultJson>>(json,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            searchResults = items?.Select(i => new SearchResult
            {
                DisplayName = i.DisplayName ?? "",
                Lat = i.Lat,
                Lng = i.Lng
            }).ToList() ?? new();
            InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    private async Task SearchAddress()
    {
        if (string.IsNullOrWhiteSpace(searchQuery) || !mapInitialized) return;
        searchResults.Clear();
        await JS.InvokeVoidAsync("LeafletMap.searchAddress", searchQuery);
    }

    private async Task HandleSearchKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchAddress();
        }
    }

    private async Task SelectSearchResult(SearchResult r)
    {
        searchResults.Clear();
        searchQuery = "";
        geoLatitud = Math.Round(r.Lat, 7);
        geoLongitud = Math.Round(r.Lng, 7);
        if (mapInitialized)
        {
            await JS.InvokeVoidAsync("LeafletMap.selectResult", r.Lat, r.Lng);
        }
    }

    private async Task OnCoordsManualChange()
    {
        if (geoLatitud.HasValue && geoLongitud.HasValue && mapInitialized)
        {
            await JS.InvokeVoidAsync("LeafletMap.setPosition", geoLatitud.Value, geoLongitud.Value);
        }
    }

    private async Task OnRadioChange()
    {
        if (mapInitialized)
        {
            await JS.InvokeVoidAsync("LeafletMap.updateRadius", geoRadio);
        }
    }

    private async Task Save()
    {
        errorMessage = null;

        try
        {
            if (!IsEdit)
            {
                Db.Sucursales.Add(model);
                await Db.SaveChangesAsync();
            }

            if (Tenant.MobileHabilitado)
            {
                bool hasGeoData = geoLatitud.HasValue || geoLongitud.HasValue
                    || !string.IsNullOrWhiteSpace(geoBssid);

                if (hasGeoData || geoconfig != null)
                {
                    if (geoconfig == null)
                    {
                        geoconfig = new SucursalGeoconfig
                        {
                            SucursalId = model.Id,
                            EmpresaId = model.EmpresaId,
                        };
                        Db.SucursalGeoconfigs.Add(geoconfig);
                    }

                    geoconfig.MetodoValidacion = "SoloGPS";
                    geoconfig.Latitud = geoLatitud.HasValue ? (decimal)geoLatitud.Value : null;
                    geoconfig.Longitud = geoLongitud.HasValue ? (decimal)geoLongitud.Value : null;
                    geoconfig.RadioMetros = geoRadio;
                    geoconfig.Activo = geoActivo;
                    geoconfig.WifiBSSID = string.IsNullOrWhiteSpace(geoBssid) ? null : geoBssid.Trim();
                    geoconfig.WifiSSID = string.IsNullOrWhiteSpace(geoSsid) ? null : geoSsid.Trim();
                }
            }

            await Db.SaveChangesAsync();
            Nav.NavigateTo("sucursales");
        }
        catch (DbUpdateException ex)
        {
            errorMessage = ex.InnerException?.Message ?? ex.Message;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (mapInitialized)
        {
            try { await JS.InvokeVoidAsync("LeafletMap.dispose"); } catch { }
        }
        dotnetRef?.Dispose();
    }

    // DTOs
    private record GeoInfo(string? Direccion, string? Localidad, string? Provincia);
    private record SearchResultJson(string? DisplayName, double Lat, double Lng);
    private class SearchResult
    {
        public string DisplayName { get; set; } = "";
        public double Lat { get; set; }
        public double Lng { get; set; }
    }
}
