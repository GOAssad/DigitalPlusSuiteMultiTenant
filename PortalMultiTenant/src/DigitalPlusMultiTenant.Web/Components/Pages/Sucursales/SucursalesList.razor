@page "/sucursales"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize]
@rendermode InteractiveServer

@inject IApplicationDbContext Db
@inject NavigationManager Nav

<PageTitle>Sucursales - DigitalPlus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-building me-2"></i>Sucursales</h4>
    <a href="sucursales/crear" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Nueva Sucursal</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Codigo</th>
                    <th>Nombre</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (sucursales == null)
                {
                    <tr><td colspan="4" class="text-center py-4"><div class="spinner-border spinner-border-sm"></div> Cargando...</td></tr>
                }
                else if (!sucursales.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>No hay sucursales</td></tr>
                }
                else
                {
                    @foreach (var s in sucursales)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">@s.Codigo</span></td>
                            <td>@s.Nombre</td>
                            <td>
                                <span class="badge @(s.IsActive ? "bg-success" : "bg-danger")">
                                    @(s.IsActive ? "Activa" : "Inactiva")
                                </span>
                            </td>
                            <td class="text-end">
                                <a href="sucursales/editar/@s.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ToggleActive(s)">
                                    <i class="bi @(s.IsActive ? "bi-x-circle" : "bi-check-circle")"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<Sucursal>? sucursales;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        sucursales = await Db.Sucursales.OrderBy(s => s.Nombre).ToListAsync();
    }

    private async Task ToggleActive(Sucursal s)
    {
        s.IsActive = !s.IsActive;
        await Db.SaveChangesAsync();
        await LoadData();
    }
}
