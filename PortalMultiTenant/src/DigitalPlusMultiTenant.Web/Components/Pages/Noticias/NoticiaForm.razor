@page "/noticias/crear"
@page "/noticias/editar/{Id:int}"
@inherits DigitalPlusMultiTenant.Web.Components.DbComponentBase
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize]
@rendermode InteractiveServer

@inject NavigationManager Nav

<PageTitle>@(IsEdit ? "Editar" : "Nueva") Noticia - DigitalPlus</PageTitle>

<div class="d-flex align-items-center mb-3">
    <a href="noticias" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">@(IsEdit ? "Editar" : "Nueva") Noticia</h4>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <EditForm Model="model" OnValidSubmit="Save" FormName="noticiaForm">
            <DataAnnotationsValidator />
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label">Titulo</label>
                    <InputText @bind-Value="model.Titulo" class="form-control" />
                    <ValidationMessage For="() => model.Titulo" class="text-danger small" />
                </div>
                <div class="col-md-12">
                    <label class="form-label">Contenido</label>
                    <InputTextArea @bind-Value="model.Contenido" class="form-control" rows="4" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Desde</label>
                    <InputDate @bind-Value="model.FechaDesde" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Hasta</label>
                    <InputDate @bind-Value="model.FechaHasta" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Visibilidad</label>
                    <div class="form-check form-switch mt-2">
                        <InputCheckbox @bind-Value="model.IsPrivada" class="form-check-input" />
                        <label class="form-check-label">Privada</label>
                    </div>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary me-2"><i class="bi bi-check-lg me-1"></i>Guardar</button>
                <a href="noticias" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </EditForm>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    private bool IsEdit => Id > 0;
    private Noticia model = new() { FechaDesde = DateOnly.FromDateTime(DateTime.Today), FechaHasta = DateOnly.FromDateTime(DateTime.Today.AddDays(30)) };
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (IsEdit) { var e = await Db.Noticias.FindAsync(Id); if (e == null) { Nav.NavigateTo("noticias"); return; } model = e; }
    }

    private async Task Save()
    {
        try { if (!IsEdit) Db.Noticias.Add(model); await Db.SaveChangesAsync(); Nav.NavigateTo("noticias"); }
        catch (DbUpdateException ex) { errorMessage = ex.InnerException?.Message ?? ex.Message; }
    }
}
