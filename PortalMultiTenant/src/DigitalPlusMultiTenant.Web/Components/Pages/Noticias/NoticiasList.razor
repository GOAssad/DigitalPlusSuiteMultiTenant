@page "/noticias"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize]
@rendermode InteractiveServer

@inject IApplicationDbContext Db

<PageTitle>Noticias - DigitalPlus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-megaphone me-2"></i>Noticias</h4>
    <a href="noticias/crear" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Nueva Noticia</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Titulo</th>
                    <th>Desde</th>
                    <th>Hasta</th>
                    <th>Vigente</th>
                    <th>Privada</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (items == null)
                {
                    <tr><td colspan="6" class="text-center py-4"><div class="spinner-border spinner-border-sm"></div></td></tr>
                }
                else if (!items.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>No hay noticias</td></tr>
                }
                else
                {
                    var hoy = DateOnly.FromDateTime(DateTime.Today);
                    @foreach (var n in items)
                    {
                        var vigente = n.FechaDesde <= hoy && n.FechaHasta >= hoy;
                        <tr class="@(!vigente ? "table-secondary" : "")">
                            <td>@n.Titulo</td>
                            <td>@n.FechaDesde.ToString("dd/MM/yyyy")</td>
                            <td>@n.FechaHasta.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge @(vigente ? "bg-success" : "bg-secondary")">@(vigente ? "Si" : "No")</span></td>
                            <td>@(n.IsPrivada ? "Si" : "No")</td>
                            <td class="text-end">
                                <a href="noticias/editar/@n.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => Eliminar(n)"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<Noticia>? items;

    protected override async Task OnInitializedAsync() => items = await Db.Noticias.OrderByDescending(n => n.FechaDesde).ToListAsync();

    private async Task Eliminar(Noticia n) { Db.Noticias.Remove(n); await Db.SaveChangesAsync(); items = await Db.Noticias.OrderByDescending(x => x.FechaDesde).ToListAsync(); }
}
