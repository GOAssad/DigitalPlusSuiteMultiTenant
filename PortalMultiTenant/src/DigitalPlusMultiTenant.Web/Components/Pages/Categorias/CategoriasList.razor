@page "/categorias"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize]
@rendermode InteractiveServer

@inject IApplicationDbContext Db

<PageTitle>Categorias - DigitalPlus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-tags me-2"></i>Categorias</h4>
    <a href="categorias/crear" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Nueva Categoria</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Legajos</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (categorias == null)
                {
                    <tr><td colspan="4" class="text-center py-4"><div class="spinner-border spinner-border-sm"></div></td></tr>
                }
                else if (!categorias.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>No hay categorias</td></tr>
                }
                else
                {
                    @foreach (var c in categorias)
                    {
                        <tr>
                            <td>@c.Nombre</td>
                            <td><span class="badge bg-info">@c.Legajos.Count</span></td>
                            <td><span class="badge @(c.IsActive ? "bg-success" : "bg-danger")">@(c.IsActive ? "Activa" : "Inactiva")</span></td>
                            <td class="text-end">
                                <a href="categorias/editar/@c.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ToggleActive(c)">
                                    <i class="bi @(c.IsActive ? "bi-x-circle" : "bi-check-circle")"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<Categoria>? categorias;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        categorias = await Db.Categorias.Include(c => c.Legajos).OrderBy(c => c.Nombre).ToListAsync();
    }

    private async Task ToggleActive(Categoria c)
    {
        c.IsActive = !c.IsActive;
        await Db.SaveChangesAsync();
        await LoadData();
    }
}
