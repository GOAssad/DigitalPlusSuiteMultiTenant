@page "/terminales/crear"
@page "/terminales/editar/{Id:int}"
@inherits DigitalPlusMultiTenant.Web.Components.DbComponentBase
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize]
@rendermode InteractiveServer

@inject NavigationManager Nav

<PageTitle>@(IsEdit ? "Editar" : "Nueva") Terminal - DigitalPlus</PageTitle>

<div class="d-flex align-items-center mb-3">
    <a href="terminales" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">@(IsEdit ? "Editar" : "Nueva") Terminal</h4>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <EditForm Model="model" OnValidSubmit="Save" FormName="terminalForm">
            <DataAnnotationsValidator />
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Nombre</label>
                    <InputText @bind-Value="model.Nombre" class="form-control" />
                    <ValidationMessage For="() => model.Nombre" class="text-danger small" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Sucursal</label>
                    <InputSelect @bind-Value="model.SucursalId" class="form-select">
                        <option value="0">-- Seleccionar --</option>
                        @foreach (var s in sucursales)
                        {
                            <option value="@s.Id">@s.Nombre</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Estado</label>
                    <div class="form-check form-switch mt-2">
                        <InputCheckbox @bind-Value="model.IsActive" class="form-check-input" />
                        <label class="form-check-label">Activa</label>
                    </div>
                </div>
                <div class="col-md-8">
                    <label class="form-label">Descripcion</label>
                    <InputText @bind-Value="model.Descripcion" class="form-control" />
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary me-2"><i class="bi bi-check-lg me-1"></i>Guardar</button>
                <a href="terminales" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </EditForm>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    private bool IsEdit => Id > 0;
    private Terminal model = new() { IsActive = true };
    private List<Sucursal> sucursales = new();
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        sucursales = await Db.Sucursales.Where(s => s.IsActive).OrderBy(s => s.Nombre).ToListAsync();
        if (IsEdit)
        {
            var entity = await Db.Terminales.FindAsync(Id);
            if (entity == null) { Nav.NavigateTo("terminales"); return; }
            model = entity;
        }
    }

    private async Task Save()
    {
        try
        {
            if (!IsEdit) Db.Terminales.Add(model);
            await Db.SaveChangesAsync();
            Nav.NavigateTo("terminales");
        }
        catch (DbUpdateException ex)
        {
            errorMessage = ex.InnerException?.Message ?? ex.Message;
        }
    }
}
