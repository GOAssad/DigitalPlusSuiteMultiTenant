@page "/terminales"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize]
@rendermode InteractiveServer

@inject IApplicationDbContext Db

<PageTitle>Terminales - DigitalPlus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-pc-display me-2"></i>Terminales</h4>
    <a href="terminales/crear" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Nueva Terminal</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Sucursal</th>
                    <th>Descripcion</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (terminales == null)
                {
                    <tr><td colspan="5" class="text-center py-4"><div class="spinner-border spinner-border-sm"></div></td></tr>
                }
                else if (!terminales.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>No hay terminales</td></tr>
                }
                else
                {
                    @foreach (var t in terminales)
                    {
                        <tr>
                            <td>@t.Nombre</td>
                            <td><span class="badge bg-secondary">@t.Sucursal.Nombre</span></td>
                            <td class="text-muted">@t.Descripcion</td>
                            <td><span class="badge @(t.IsActive ? "bg-success" : "bg-danger")">@(t.IsActive ? "Activa" : "Inactiva")</span></td>
                            <td class="text-end">
                                <a href="terminales/editar/@t.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ToggleActive(t)">
                                    <i class="bi @(t.IsActive ? "bi-x-circle" : "bi-check-circle")"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<Terminal>? terminales;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        terminales = await Db.Terminales.Include(t => t.Sucursal).OrderBy(t => t.Nombre).ToListAsync();
    }

    private async Task ToggleActive(Terminal t)
    {
        t.IsActive = !t.IsActive;
        await Db.SaveChangesAsync();
        await LoadData();
    }
}
