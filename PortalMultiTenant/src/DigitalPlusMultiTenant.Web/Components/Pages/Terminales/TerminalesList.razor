@page "/terminales"
@inherits DigitalPlusMultiTenant.Web.Components.DbComponentBase
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize]
@rendermode InteractiveServer

@inject IJSRuntime JS
@inject ITenantService Tenant
@using DigitalPlusMultiTenant.Web.Helpers

<PageTitle>Terminales - DigitalPlus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-pc-display me-2"></i>Terminales</h4>
    <div>
        <button class="btn btn-outline-secondary btn-sm me-2" @onclick="CargarDatos" title="Actualizar"><i class="bi bi-arrow-clockwise"></i></button>
        @if (items?.Any() == true)
        {
            <button class="btn btn-outline-success btn-sm me-1" @onclick="ExportarExcel"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
            <button class="btn btn-outline-secondary btn-sm me-2" @onclick="ExportarCsv"><i class="bi bi-filetype-csv me-1"></i>CSV</button>
        }
        <AuthorizeView Roles="SuperAdmin,AdminEmpresa">
            <a href="terminales/crear" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Nueva Terminal</a>
        </AuthorizeView>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small mb-1">Buscar</label>
                <input type="text" class="form-control form-control-sm" placeholder="Nombre o descripcion..."
                       @bind="filtro" @bind:event="oninput" @bind:after="BuscarDebounce" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Sucursal</label>
                <select class="form-select form-select-sm" @bind="filtroSucursal" @bind:after="Buscar">
                    <option value="0">Todas</option>
                    @foreach (var s in sucursales)
                    {
                        <option value="@s.Id">@s.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Estado</label>
                <select class="form-select form-select-sm" @bind="filtroActivo" @bind:after="Buscar">
                    <option value="">Todos</option>
                    <option value="true">Activos</option>
                    <option value="false">Inactivos</option>
                </select>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th role="button" @onclick='() => SetOrden("nombre")'>
                            Nombre @SortIcon("nombre")
                        </th>
                        <th role="button" @onclick='() => SetOrden("sucursal")'>
                            Sucursal @SortIcon("sucursal")
                        </th>
                        <th role="button" @onclick='() => SetOrden("descripcion")'>
                            Descripcion @SortIcon("descripcion")
                        </th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (items == null)
                    {
                        <tr><td colspan="5" class="text-center py-4"><DigitalPlusMultiTenant.Web.Components.Shared.LoadingIndicator Small="true" Message="" /></td></tr>
                    }
                    else if (!items.Any())
                    {
                        <tr><td colspan="5" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>No hay terminales</td></tr>
                    }
                    else
                    {
                        @foreach (var t in items)
                        {
                            <tr>
                                <td>@t.Nombre</td>
                                <td><span class="badge bg-secondary">@t.Sucursal.Nombre</span></td>
                                <td class="text-muted">@t.Descripcion</td>
                                <td><span class="badge @(t.IsActive ? "bg-success" : "bg-danger")">@(t.IsActive ? "Activa" : "Inactiva")</span></td>
                                <td class="text-end">
                                    <AuthorizeView Roles="SuperAdmin,AdminEmpresa">
                                        <a href="terminales/editar/@t.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ToggleActive(t)">
                                            <i class="bi @(t.IsActive ? "bi-x-circle" : "bi-check-circle")"></i>
                                        </button>
                                    </AuthorizeView>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<Terminal>? items;
    private List<Sucursal> sucursales = new();
    private string filtro = "";
    private int filtroSucursal;
    private string filtroActivo = "true";
    private string ordenColumna = "nombre";
    private bool ordenDesc;
    private CancellationTokenSource? _debounceToken;

    protected override async Task OnInitializedAsync()
    {
        sucursales = await Db.Sucursales.Where(s => s.IsActive).OrderBy(s => s.Nombre).ToListAsync();
        await CargarDatos();
    }

    private async Task BuscarDebounce()
    {
        _debounceToken?.Cancel();
        _debounceToken = new CancellationTokenSource();
        try { await Task.Delay(300, _debounceToken.Token); await CargarDatos(); }
        catch (TaskCanceledException) { }
    }

    private async Task Buscar() => await CargarDatos();

    private async Task SetOrden(string columna)
    {
        if (ordenColumna == columna) ordenDesc = !ordenDesc;
        else { ordenColumna = columna; ordenDesc = false; }
        await CargarDatos();
    }

    private MarkupString SortIcon(string columna)
    {
        if (ordenColumna != columna)
            return new MarkupString("<i class=\"bi bi-chevron-expand text-muted small\"></i>");
        return ordenDesc
            ? new MarkupString("<i class=\"bi bi-sort-down\"></i>")
            : new MarkupString("<i class=\"bi bi-sort-up\"></i>");
    }

    private async Task CargarDatos()
    {
        var query = Db.Terminales.Include(t => t.Sucursal).AsQueryable();

        if (!string.IsNullOrWhiteSpace(filtro))
        {
            var f = filtro.Trim().ToLower();
            query = query.Where(t => t.Nombre.ToLower().Contains(f)
                || (t.Descripcion != null && t.Descripcion.ToLower().Contains(f)));
        }
        if (filtroSucursal > 0)
            query = query.Where(t => t.SucursalId == filtroSucursal);
        if (filtroActivo == "true") query = query.Where(t => t.IsActive);
        else if (filtroActivo == "false") query = query.Where(t => !t.IsActive);

        var ordered = ordenColumna switch
        {
            "sucursal" => ordenDesc ? query.OrderByDescending(t => t.Sucursal.Nombre) : query.OrderBy(t => t.Sucursal.Nombre),
            "descripcion" => ordenDesc ? query.OrderByDescending(t => t.Descripcion) : query.OrderBy(t => t.Descripcion),
            _ => ordenDesc ? query.OrderByDescending(t => t.Nombre) : query.OrderBy(t => t.Nombre),
        };

        items = await ordered.ToListAsync();
    }

    private async Task ExportarExcel()
    {
        if (items == null) return;
        var filtros = new List<string>();
        if (!string.IsNullOrWhiteSpace(filtro)) filtros.Add($"Busqueda: {filtro}");
        if (filtroSucursal > 0) filtros.Add($"Sucursal: {sucursales.FirstOrDefault(s => s.Id == filtroSucursal)?.Nombre}");
        if (filtroActivo == "true") filtros.Add("Estado: Activos");
        else if (filtroActivo == "false") filtros.Add("Estado: Inactivos");
        var bytes = ExcelExporter.Generar(items,
            new ExcelExportConfig { Titulo = "Terminales", NombreEmpresa = Tenant.EmpresaNombre, Filtros = filtros,
                Encabezados = ["Nombre", "Sucursal", "Descripcion", "Estado"] },
            t => [t.Nombre, t.Sucursal?.Nombre ?? "", t.Descripcion ?? "", t.IsActive ? "Activa" : "Inactiva"]);
        await JS.InvokeVoidAsync("downloadFile", "terminales.xlsx", Convert.ToBase64String(bytes), "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    private async Task ExportarCsv()
    {
        if (items == null) return;
        var bytes = CsvExporter.ToCsvBytes(items,
            ["Nombre", "Sucursal", "Descripcion", "Estado"],
            t => [t.Nombre, t.Sucursal?.Nombre ?? "", t.Descripcion ?? "", t.IsActive ? "Activa" : "Inactiva"]);
        await JS.InvokeVoidAsync("downloadFile", "terminales.csv", Convert.ToBase64String(bytes), "text/csv");
    }

    private async Task ToggleActive(Terminal t)
    {
        t.IsActive = !t.IsActive;
        await Db.SaveChangesAsync();
        await CargarDatos();
    }
}
