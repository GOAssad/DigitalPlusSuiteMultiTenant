@page "/sectores"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize]
@rendermode InteractiveServer

@inject IApplicationDbContext Db

<PageTitle>Sectores - DigitalPlus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-diagram-3 me-2"></i>Sectores</h4>
    <a href="sectores/crear" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Nuevo Sector</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Legajos</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (sectores == null)
                {
                    <tr><td colspan="4" class="text-center py-4"><div class="spinner-border spinner-border-sm"></div></td></tr>
                }
                else if (!sectores.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>No hay sectores</td></tr>
                }
                else
                {
                    @foreach (var s in sectores)
                    {
                        <tr>
                            <td>@s.Nombre</td>
                            <td><span class="badge bg-info">@s.Legajos.Count</span></td>
                            <td><span class="badge @(s.IsActive ? "bg-success" : "bg-danger")">@(s.IsActive ? "Activo" : "Inactivo")</span></td>
                            <td class="text-end">
                                <a href="sectores/editar/@s.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ToggleActive(s)">
                                    <i class="bi @(s.IsActive ? "bi-x-circle" : "bi-check-circle")"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<Sector>? sectores;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        sectores = await Db.Sectores.Include(s => s.Legajos).OrderBy(s => s.Nombre).ToListAsync();
    }

    private async Task ToggleActive(Sector s)
    {
        s.IsActive = !s.IsActive;
        await Db.SaveChangesAsync();
        await LoadData();
    }
}
