@page "/incidencias/crear"
@page "/incidencias/editar/{Id:int}"
@inherits DigitalPlusMultiTenant.Web.Components.DbComponentBase
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize]
@rendermode InteractiveServer

@inject NavigationManager Nav

<PageTitle>@(IsEdit ? "Editar" : "Nueva") Incidencia - DigitalPlus</PageTitle>

<div class="d-flex align-items-center mb-3">
    <a href="incidencias" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">@(IsEdit ? "Editar" : "Nueva") Incidencia</h4>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <EditForm Model="model" OnValidSubmit="Save" FormName="incidenciaForm">
            <DataAnnotationsValidator />
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Nombre</label>
                    <InputText @bind-Value="model.Nombre" class="form-control" />
                    <ValidationMessage For="() => model.Nombre" class="text-danger small" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Abreviatura</label>
                    <InputText @bind-Value="model.Abreviatura" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Color</label>
                    <input type="color" class="form-control form-control-color" @bind="model.Color" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Estado</label>
                    <div class="form-check form-switch mt-2">
                        <InputCheckbox @bind-Value="model.IsActive" class="form-check-input" />
                        <label class="form-check-label">Activa</label>
                    </div>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary me-2"><i class="bi bi-check-lg me-1"></i>Guardar</button>
                <a href="incidencias" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </EditForm>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    private bool IsEdit => Id > 0;
    private Incidencia model = new() { IsActive = true };
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (IsEdit) { var e = await Db.Incidencias.FindAsync(Id); if (e == null) { Nav.NavigateTo("incidencias"); return; } model = e; }
    }

    private async Task Save()
    {
        try { if (!IsEdit) Db.Incidencias.Add(model); await Db.SaveChangesAsync(); Nav.NavigateTo("incidencias"); }
        catch (DbUpdateException ex) { errorMessage = ex.InnerException?.Message ?? ex.Message; }
    }
}
