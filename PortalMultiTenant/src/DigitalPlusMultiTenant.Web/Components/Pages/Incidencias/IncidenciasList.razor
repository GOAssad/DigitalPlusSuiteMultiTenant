@page "/incidencias"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize]
@rendermode InteractiveServer

@inject IApplicationDbContext Db

<PageTitle>Incidencias - DigitalPlus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Incidencias</h4>
    <a href="incidencias/crear" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Nueva Incidencia</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Abreviatura</th>
                    <th>Color</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (items == null)
                {
                    <tr><td colspan="5" class="text-center py-4"><div class="spinner-border spinner-border-sm"></div></td></tr>
                }
                else if (!items.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>No hay incidencias</td></tr>
                }
                else
                {
                    @foreach (var i in items)
                    {
                        <tr>
                            <td>@i.Nombre</td>
                            <td><span class="badge bg-secondary">@i.Abreviatura</span></td>
                            <td>
                                @if (!string.IsNullOrEmpty(i.Color))
                                {
                                    <span class="d-inline-block rounded" style="width:24px;height:24px;background-color:@i.Color"></span>
                                }
                            </td>
                            <td><span class="badge @(i.IsActive ? "bg-success" : "bg-danger")">@(i.IsActive ? "Activa" : "Inactiva")</span></td>
                            <td class="text-end">
                                <a href="incidencias/editar/@i.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ToggleActive(i)">
                                    <i class="bi @(i.IsActive ? "bi-x-circle" : "bi-check-circle")"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<Incidencia>? items;

    protected override async Task OnInitializedAsync() => items = await Db.Incidencias.OrderBy(i => i.Nombre).ToListAsync();

    private async Task ToggleActive(Incidencia i) { i.IsActive = !i.IsActive; await Db.SaveChangesAsync(); items = await Db.Incidencias.OrderBy(x => x.Nombre).ToListAsync(); }
}
