@page "/horarios"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize]
@rendermode InteractiveServer

@inject IApplicationDbContext Db

<PageTitle>Horarios - DigitalPlus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-clock me-2"></i>Horarios</h4>
    <a href="horarios/crear" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Nuevo Horario</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Legajos</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (horarios == null)
                {
                    <tr><td colspan="4" class="text-center py-4"><div class="spinner-border spinner-border-sm"></div></td></tr>
                }
                else if (!horarios.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>No hay horarios</td></tr>
                }
                else
                {
                    @foreach (var h in horarios)
                    {
                        <tr>
                            <td>@h.Nombre</td>
                            <td><span class="badge bg-info">@h.Legajos.Count</span></td>
                            <td><span class="badge @(h.IsActive ? "bg-success" : "bg-danger")">@(h.IsActive ? "Activo" : "Inactivo")</span></td>
                            <td class="text-end">
                                <a href="horarios/editar/@h.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ToggleActive(h)">
                                    <i class="bi @(h.IsActive ? "bi-x-circle" : "bi-check-circle")"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<Horario>? horarios;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        horarios = await Db.Horarios.Include(h => h.Legajos).OrderBy(h => h.Nombre).ToListAsync();
    }

    private async Task ToggleActive(Horario h)
    {
        h.IsActive = !h.IsActive;
        await Db.SaveChangesAsync();
        await LoadData();
    }
}
