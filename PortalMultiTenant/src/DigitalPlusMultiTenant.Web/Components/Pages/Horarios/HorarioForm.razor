@page "/horarios/crear"
@page "/horarios/editar/{Id:int}"
@inherits DigitalPlusMultiTenant.Web.Components.DbComponentBase
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@using DigitalPlusMultiTenant.Domain.Enums
@attribute [Authorize(Roles = "SuperAdmin,AdminEmpresa")]
@rendermode InteractiveServer

@inject NavigationManager Nav

<PageTitle>@(IsEdit ? "Editar" : "Nuevo") Horario - DigitalPlus</PageTitle>

<div class="d-flex align-items-center mb-3">
    <a href="horarios" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0">@(IsEdit ? "Editar" : "Nuevo") Horario</h4>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <EditForm Model="model" OnValidSubmit="Save" FormName="horarioForm">
            <DataAnnotationsValidator />
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label">Nombre</label>
                    <InputText @bind-Value="model.Nombre" class="form-control" />
                    <ValidationMessage For="() => model.Nombre" class="text-danger small" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Estado</label>
                    <div class="form-check form-switch mt-2">
                        <InputCheckbox @bind-Value="model.IsActive" class="form-check-input" />
                        <label class="form-check-label">Activo</label>
                    </div>
                </div>
            </div>

            <h6>Detalle por dia</h6>
            <table class="table table-sm">
                <thead class="table-light">
                    <tr>
                        <th>Dia</th>
                        <th>Desde</th>
                        <th>Hasta</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in detalles)
                    {
                        <tr class="@(!d.Habilitado ? "table-secondary" : "")">
                            <td>@GetDiaName(d.DiaSemana)</td>
                            <td><InputText @bind-Value="d.DesdeStr" class="form-control form-control-sm" placeholder="HH:mm" disabled="@(!d.Habilitado)" /></td>
                            <td><InputText @bind-Value="d.HastaStr" class="form-control form-control-sm" placeholder="HH:mm" disabled="@(!d.Habilitado)" /></td>
                            <td>
                                <div class="form-check">
                                    <InputCheckbox @bind-Value="d.Habilitado" class="form-check-input" />
                                    <label class="form-check-label small">Laboral</label>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary me-2"><i class="bi bi-check-lg me-1"></i>Guardar</button>
                <a href="horarios" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </EditForm>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    private bool IsEdit => Id > 0;
    private Horario model = new() { IsActive = true };
    private List<DetalleModel> detalles = new();
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (IsEdit)
        {
            model = await Db.Horarios.Include(h => h.Detalles).FirstOrDefaultAsync(h => h.Id == Id)
                ?? new Horario { IsActive = true };
            if (model.Id == 0) { Nav.NavigateTo("horarios"); return; }
        }

        // Init 7 dias (Lunes a Domingo)
        foreach (DiaSemana dia in Enum.GetValues<DiaSemana>())
        {
            var existing = model.Detalles.FirstOrDefault(d => d.DiaSemana == dia);
            detalles.Add(new DetalleModel
            {
                DiaSemana = dia,
                DesdeStr = existing?.HoraDesde.ToString("HH:mm") ?? "09:00",
                HastaStr = existing?.HoraHasta.ToString("HH:mm") ?? "18:00",
                Habilitado = existing != null && !existing.IsCerrado
            });
        }
    }

    private async Task Save()
    {
        try
        {
            // Remove existing detalles
            if (IsEdit)
            {
                var existingDetalles = await Db.HorarioDetalles.Where(d => d.HorarioId == model.Id).ToListAsync();
                foreach (var d in existingDetalles)
                    Db.HorarioDetalles.Remove(d);
            }

            // Add new
            model.Detalles.Clear();
            foreach (var d in detalles)
            {
                if (TimeOnly.TryParse(d.DesdeStr, out var desde) && TimeOnly.TryParse(d.HastaStr, out var hasta))
                {
                    model.Detalles.Add(new HorarioDetalle
                    {
                        DiaSemana = d.DiaSemana,
                        HoraDesde = desde,
                        HoraHasta = hasta,
                        IsCerrado = !d.Habilitado
                    });
                }
            }

            if (!IsEdit) Db.Horarios.Add(model);
            await Db.SaveChangesAsync();
            Nav.NavigateTo("horarios");
        }
        catch (DbUpdateException ex)
        {
            errorMessage = ex.InnerException?.Message ?? ex.Message;
        }
    }

    private string GetDiaName(DiaSemana dia) => dia switch
    {
        DiaSemana.Lunes => "Lunes",
        DiaSemana.Martes => "Martes",
        DiaSemana.Miercoles => "Miercoles",
        DiaSemana.Jueves => "Jueves",
        DiaSemana.Viernes => "Viernes",
        DiaSemana.Sabado => "Sabado",
        DiaSemana.Domingo => "Domingo",
        _ => dia.ToString()
    };

    private class DetalleModel
    {
        public DiaSemana DiaSemana { get; set; }
        public string DesdeStr { get; set; } = "09:00";
        public string HastaStr { get; set; } = "18:00";
        public bool Habilitado { get; set; }
    }
}
