@page "/vacaciones"
@inherits DigitalPlusMultiTenant.Web.Components.DbComponentBase
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize]
@rendermode InteractiveServer

@inject IJSRuntime JS
@inject ITenantService Tenant
@using DigitalPlusMultiTenant.Web.Helpers

<PageTitle>Vacaciones - DigitalPlus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-sun me-2"></i>Vacaciones</h4>
    <div>
        @if (items?.Any() == true)
        {
            <button class="btn btn-outline-success btn-sm me-1" @onclick="ExportarExcel"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
            <button class="btn btn-outline-secondary btn-sm me-2" @onclick="ExportarCsv"><i class="bi bi-filetype-csv me-1"></i>CSV</button>
        }
        <AuthorizeView Roles="SuperAdmin,AdminEmpresa,Operador">
            <a href="vacaciones/crear" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Nueva Vacacion</a>
        </AuthorizeView>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small mb-1">Buscar</label>
                <input type="text" class="form-control form-control-sm" placeholder="Nombre o nro legajo..."
                       @bind="filtro" @bind:event="oninput" @bind:after="BuscarDebounce" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Año</label>
                <input type="number" class="form-control form-control-sm" @bind="anio" @bind:after="Buscar" />
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th role="button" @onclick='() => SetOrden("legajo")'>
                            Legajo @SortIcon("legajo")
                        </th>
                        <th role="button" @onclick='() => SetOrden("nombre")'>
                            Apellido y Nombre @SortIcon("nombre")
                        </th>
                        <th role="button" @onclick='() => SetOrden("desde")'>
                            Desde @SortIcon("desde")
                        </th>
                        <th role="button" @onclick='() => SetOrden("hasta")'>
                            Hasta @SortIcon("hasta")
                        </th>
                        <th role="button" @onclick='() => SetOrden("dias")'>
                            Dias @SortIcon("dias")
                        </th>
                        <th>Nota</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (items == null)
                    {
                        <tr><td colspan="7" class="text-center py-4"><DigitalPlusMultiTenant.Web.Components.Shared.LoadingIndicator Small="true" Message="" /></td></tr>
                    }
                    else if (!items.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>No hay vacaciones registradas</td></tr>
                    }
                    else
                    {
                        @foreach (var v in items)
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@v.Legajo?.NumeroLegajo</span></td>
                                <td><strong>@v.Legajo?.Apellido</strong>, @v.Legajo?.Nombre</td>
                                <td>@v.FechaDesde.ToString("dd/MM/yyyy")</td>
                                <td>@v.FechaHasta.ToString("dd/MM/yyyy")</td>
                                <td><span class="badge bg-info">@(v.FechaHasta.DayNumber - v.FechaDesde.DayNumber + 1)</span></td>
                                <td class="text-muted">@v.Nota</td>
                                <td class="text-end">
                                    <AuthorizeView Roles="SuperAdmin,AdminEmpresa,Operador">
                                        <a href="vacaciones/editar/@v.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                    </AuthorizeView>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<Vacacion>? items;
    private string filtro = "";
    private int anio = Clock.Today.Year;
    private string ordenColumna = "desde";
    private bool ordenDesc = true;
    private CancellationTokenSource? _debounceToken;

    protected override async Task OnInitializedAsync() => await CargarDatos();

    private async Task BuscarDebounce()
    {
        _debounceToken?.Cancel();
        _debounceToken = new CancellationTokenSource();
        try { await Task.Delay(300, _debounceToken.Token); await CargarDatos(); }
        catch (TaskCanceledException) { }
    }

    private async Task Buscar() => await CargarDatos();

    private async Task SetOrden(string columna)
    {
        if (ordenColumna == columna) ordenDesc = !ordenDesc;
        else { ordenColumna = columna; ordenDesc = false; }
        await CargarDatos();
    }

    private MarkupString SortIcon(string columna)
    {
        if (ordenColumna != columna)
            return new MarkupString("<i class=\"bi bi-chevron-expand text-muted small\"></i>");
        return ordenDesc
            ? new MarkupString("<i class=\"bi bi-sort-down\"></i>")
            : new MarkupString("<i class=\"bi bi-sort-up\"></i>");
    }

    private async Task CargarDatos()
    {
        var query = Db.Vacaciones.Include(v => v.Legajo).AsQueryable();

        if (anio > 0)
        {
            var desde = new DateOnly(anio, 1, 1);
            var hasta = new DateOnly(anio, 12, 31);
            query = query.Where(v => v.FechaDesde <= hasta && v.FechaHasta >= desde);
        }

        if (!string.IsNullOrWhiteSpace(filtro))
        {
            var f = filtro.Trim().ToLower();
            query = query.Where(v => v.Legajo!.Apellido.ToLower().Contains(f)
                || v.Legajo!.Nombre.ToLower().Contains(f)
                || v.Legajo!.NumeroLegajo.ToLower().Contains(f));
        }

        var ordered = ordenColumna switch
        {
            "legajo" => ordenDesc ? query.OrderByDescending(v => v.Legajo!.NumeroLegajo) : query.OrderBy(v => v.Legajo!.NumeroLegajo),
            "nombre" => ordenDesc ? query.OrderByDescending(v => v.Legajo!.Apellido).ThenByDescending(v => v.Legajo!.Nombre) : query.OrderBy(v => v.Legajo!.Apellido).ThenBy(v => v.Legajo!.Nombre),
            "hasta" => ordenDesc ? query.OrderByDescending(v => v.FechaHasta) : query.OrderBy(v => v.FechaHasta),
            "dias" => ordenDesc ? query.OrderByDescending(v => v.FechaHasta.DayNumber - v.FechaDesde.DayNumber) : query.OrderBy(v => v.FechaHasta.DayNumber - v.FechaDesde.DayNumber),
            _ => ordenDesc ? query.OrderByDescending(v => v.FechaDesde) : query.OrderBy(v => v.FechaDesde),
        };

        items = await ordered.Take(200).ToListAsync();
    }

    private async Task ExportarExcel()
    {
        if (items == null) return;
        var filtros = new List<string>();
        if (!string.IsNullOrWhiteSpace(filtro)) filtros.Add($"Busqueda: {filtro}");
        var bytes = ExcelExporter.Generar(items,
            new ExcelExportConfig { Titulo = "Vacaciones", NombreEmpresa = Tenant.EmpresaNombre, FechaDesde = $"Año {anio}", Filtros = filtros,
                Encabezados = ["Legajo", "Apellido", "Nombre", "Desde", "Hasta", "Dias", "Nota"],
                Formatos = [ExcelColFormat.Texto, ExcelColFormat.Texto, ExcelColFormat.Texto, ExcelColFormat.Fecha, ExcelColFormat.Fecha, ExcelColFormat.Numero, ExcelColFormat.Texto] },
            v => [v.Legajo?.NumeroLegajo ?? "", v.Legajo?.Apellido ?? "", v.Legajo?.Nombre ?? "",
                  v.FechaDesde, v.FechaHasta, v.FechaHasta.DayNumber - v.FechaDesde.DayNumber + 1, v.Nota ?? ""]);
        await JS.InvokeVoidAsync("downloadFile", "vacaciones.xlsx", Convert.ToBase64String(bytes), "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    private async Task ExportarCsv()
    {
        if (items == null) return;
        var bytes = CsvExporter.ToCsvBytes(items,
            ["Legajo", "Apellido", "Nombre", "Desde", "Hasta", "Dias", "Nota"],
            v => [v.Legajo?.NumeroLegajo ?? "", v.Legajo?.Apellido ?? "", v.Legajo?.Nombre ?? "",
                  v.FechaDesde.ToString("dd/MM/yyyy"), v.FechaHasta.ToString("dd/MM/yyyy"),
                  (v.FechaHasta.DayNumber - v.FechaDesde.DayNumber + 1).ToString(), v.Nota ?? ""]);
        await JS.InvokeVoidAsync("downloadFile", "vacaciones.csv", Convert.ToBase64String(bytes), "text/csv");
    }
}
