@page "/vacaciones"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DigitalPlusMultiTenant.Application.Interfaces
@using DigitalPlusMultiTenant.Domain.Entities
@attribute [Authorize]
@rendermode InteractiveServer

@inject IApplicationDbContext Db

<PageTitle>Vacaciones - DigitalPlus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-sun me-2"></i>Vacaciones</h4>
    <a href="vacaciones/crear" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Nueva Vacacion</a>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small mb-1">Legajo</label>
                <input type="text" class="form-control form-control-sm" placeholder="Nombre o nro legajo..." @bind="filtro" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Año</label>
                <input type="number" class="form-control form-control-sm" @bind="anio" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary btn-sm" @onclick="Buscar"><i class="bi bi-search me-1"></i>Buscar</button>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Legajo</th>
                    <th>Apellido y Nombre</th>
                    <th>Desde</th>
                    <th>Hasta</th>
                    <th>Dias</th>
                    <th>Nota</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (items == null || !items.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>
                        @(items == null ? "Presione Buscar" : "No hay vacaciones registradas")</td></tr>
                }
                else
                {
                    @foreach (var v in items)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">@v.Legajo?.NumeroLegajo</span></td>
                            <td><strong>@v.Legajo?.Apellido</strong>, @v.Legajo?.Nombre</td>
                            <td>@v.FechaDesde.ToString("dd/MM/yyyy")</td>
                            <td>@v.FechaHasta.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge bg-info">@(v.FechaHasta.DayNumber - v.FechaDesde.DayNumber + 1)</span></td>
                            <td class="text-muted">@v.Nota</td>
                            <td class="text-end">
                                <a href="vacaciones/editar/@v.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<Vacacion>? items;
    private string filtro = "";
    private int anio = DateTime.Today.Year;

    private async Task Buscar()
    {
        var query = Db.Vacaciones.Include(v => v.Legajo).AsQueryable();

        if (anio > 0)
        {
            var desde = new DateOnly(anio, 1, 1);
            var hasta = new DateOnly(anio, 12, 31);
            query = query.Where(v => v.FechaDesde <= hasta && v.FechaHasta >= desde);
        }

        if (!string.IsNullOrWhiteSpace(filtro))
        {
            var f = filtro.Trim().ToLower();
            query = query.Where(v => v.Legajo!.Apellido.ToLower().Contains(f)
                || v.Legajo!.Nombre.ToLower().Contains(f)
                || v.Legajo!.NumeroLegajo.ToLower().Contains(f));
        }

        items = await query.OrderByDescending(v => v.FechaDesde).Take(200).ToListAsync();
    }
}
