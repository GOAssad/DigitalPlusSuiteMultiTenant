@implements IDisposable
@inject NavigationManager NavigationManager
@inject DigitalPlusMultiTenant.Application.Interfaces.ITenantService Tenant
@inject DigitalPlusMultiTenant.Application.Interfaces.ILicenciaService LicenciaService
@inject IDbContextFactory<DigitalPlusMultiTenant.Persistence.ApplicationDbContext> DbFactory
@using Microsoft.EntityFrameworkCore

<div class="sidebar-brand">
    <i class="bi bi-fingerprint"></i>
    <span>DIGITAL ONE</span>
    @if (licenciaInfo != null)
    {
        <a href="/configuracion/planes" class="badge ms-2 @PlanBadgeClass text-decoration-none" style="font-size: 0.65rem; vertical-align: middle;">@licenciaInfo.PlanDisplay</a>
    }
</div>

<nav class="sidebar-nav">
    <AuthorizeView>
        <Authorized>
            <NavLink class="sidebar-link" href="/" Match="NavLinkMatch.All">
                <i class="bi bi-speedometer2"></i> Dashboard
            </NavLink>

            <div class="nav-group">
                <button class="nav-group-toggle @(IsGroupOpen("estructura") ? "open" : "")"
                        @onclick='() => ToggleGroup("estructura")'>
                    <i class="bi bi-building"></i>
                    <span>Estructura</span>
                    <i class="bi bi-chevron-down nav-chevron"></i>
                </button>
                <div class="nav-group-items @(IsGroupOpen("estructura") ? "show" : "")">
                    <NavLink class="sidebar-link sub" href="sucursales">
                        <i class="bi bi-building"></i> Sucursales
                    </NavLink>
                    <NavLink class="sidebar-link sub" href="sectores">
                        <i class="bi bi-diagram-3"></i> Sectores
                    </NavLink>
                    <NavLink class="sidebar-link sub" href="categorias">
                        <i class="bi bi-tags"></i> Categorias
                    </NavLink>
                    <NavLink class="sidebar-link sub" href="horarios">
                        <i class="bi bi-clock"></i> Horarios
                    </NavLink>
                    <NavLink class="sidebar-link sub" href="terminales">
                        <i class="bi bi-pc-display"></i> Terminales
                    </NavLink>
                    @if (mobileHab || kioskoHab)
                    {
                        <NavLink class="sidebar-link sub" href="terminales-moviles">
                            <i class="bi bi-phone"></i> Terminales Moviles
                        </NavLink>
                    }
                    @if (mobileHab)
                    {
                        <NavLink class="sidebar-link sub" href="fichado-movil">
                            <i class="bi bi-geo-alt"></i> Fichado Movil
                        </NavLink>
                    }
                </div>
            </div>

            <div class="nav-group">
                <button class="nav-group-toggle @(IsGroupOpen("personal") ? "open" : "")"
                        @onclick='() => ToggleGroup("personal")'>
                    <i class="bi bi-people"></i>
                    <span>Personal</span>
                    <i class="bi bi-chevron-down nav-chevron"></i>
                </button>
                <div class="nav-group-items @(IsGroupOpen("personal") ? "show" : "")">
                    <NavLink class="sidebar-link sub" href="legajos">
                        <i class="bi bi-person-badge"></i> Legajos
                    </NavLink>
                    <NavLink class="sidebar-link sub" href="fichadas">
                        <i class="bi bi-card-checklist"></i> Fichadas
                    </NavLink>
                </div>
            </div>

            <div class="nav-group">
                <button class="nav-group-toggle @(IsGroupOpen("reportes") ? "open" : "")"
                        @onclick='() => ToggleGroup("reportes")'>
                    <i class="bi bi-bar-chart-line"></i>
                    <span>Reportes</span>
                    <i class="bi bi-chevron-down nav-chevron"></i>
                </button>
                <div class="nav-group-items @(IsGroupOpen("reportes") ? "show" : "")">
                    <NavLink class="sidebar-link sub" href="reportes/asistencia">
                        <i class="bi bi-calendar-check"></i> Asistencia Diaria
                    </NavLink>
                    <NavLink class="sidebar-link sub" href="reportes/llegadas-tarde">
                        <i class="bi bi-alarm"></i> Llegadas Tarde
                    </NavLink>
                    <NavLink class="sidebar-link sub" href="reportes/ausencias">
                        <i class="bi bi-person-x"></i> Ausencias
                    </NavLink>
                    <NavLink class="sidebar-link sub" href="reportes/horas-trabajadas">
                        <i class="bi bi-hourglass-split"></i> Horas Trabajadas
                    </NavLink>
                </div>
            </div>

            <div class="nav-group">
                <button class="nav-group-toggle @(IsGroupOpen("operacion") ? "open" : "")"
                        @onclick='() => ToggleGroup("operacion")'>
                    <i class="bi bi-clipboard2-data"></i>
                    <span>Operacion</span>
                    <i class="bi bi-chevron-down nav-chevron"></i>
                </button>
                <div class="nav-group-items @(IsGroupOpen("operacion") ? "show" : "")">
                    <NavLink class="sidebar-link sub" href="incidencias">
                        <i class="bi bi-exclamation-triangle"></i> Incidencias
                    </NavLink>
                    <NavLink class="sidebar-link sub" href="vacaciones">
                        <i class="bi bi-sun"></i> Vacaciones
                    </NavLink>
                    <NavLink class="sidebar-link sub" href="feriados">
                        <i class="bi bi-calendar-event"></i> Feriados
                    </NavLink>
                    <NavLink class="sidebar-link sub" href="noticias">
                        <i class="bi bi-megaphone"></i> Noticias
                    </NavLink>
                </div>
            </div>

            <AuthorizeView Roles="SuperAdmin,AdminEmpresa" Context="adminContext">
                <div class="nav-group">
                    <button class="nav-group-toggle @(IsGroupOpen("admin") ? "open" : "")"
                            @onclick='() => ToggleGroup("admin")'>
                        <i class="bi bi-shield-lock"></i>
                        <span>Administracion</span>
                        <i class="bi bi-chevron-down nav-chevron"></i>
                    </button>
                    <div class="nav-group-items @(IsGroupOpen("admin") ? "show" : "")">
                        <NavLink class="sidebar-link sub" href="configuracion/empresa">
                            <i class="bi bi-building-gear"></i> Empresa
                        </NavLink>
                        <NavLink class="sidebar-link sub" href="configuracion/planes">
                            <i class="bi bi-gem"></i> Planes
                        </NavLink>
                        <NavLink class="sidebar-link sub" href="usuarios">
                            <i class="bi bi-person-lock"></i> Usuarios
                        </NavLink>
                        <NavLink class="sidebar-link sub" href="configuracion" Match="NavLinkMatch.All">
                            <i class="bi bi-gear"></i> Variables
                        </NavLink>
                        <NavLink class="sidebar-link sub" href="auditoria">
                            <i class="bi bi-shield-check"></i> Auditoría
                        </NavLink>
                    </div>
                </div>
            </AuthorizeView>
        </Authorized>
        <NotAuthorized>
            <div class="nav-section-title">Acceso</div>
            <NavLink class="sidebar-link" href="Account/Login">
                <i class="bi bi-box-arrow-in-right"></i> Iniciar sesion
            </NavLink>
        </NotAuthorized>
    </AuthorizeView>
    <a class="sidebar-link" href="https://integraia.tech/digital-one-help.html" target="_blank" rel="noopener"
       style="margin-top: 0.5rem; border-top: 1px solid rgba(255,255,255,0.08); padding-top: 0.75rem; color: #8a8f9c;">
        <i class="bi bi-question-circle"></i> Ayuda
    </a>
    <div class="sidebar-version">
        <small class="text-muted">v@(DigitalPlusMultiTenant.Web.BuildInfo.FullVersion)</small>
    </div>
</nav>

@code {
    private string? currentUrl;
    private HashSet<string> openGroups = new();
    private DigitalPlusMultiTenant.Application.Interfaces.LicenciaInfo? licenciaInfo;
    private bool mobileHab;
    private bool kioskoHab;

    private string PlanBadgeClass => licenciaInfo?.Plan switch
    {
        "free" => "bg-secondary",
        "basic" => "bg-info",
        "pro" => "bg-primary",
        "enterprise" => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    // Mapa de rutas a grupos para auto-expandir
    private static readonly Dictionary<string, string> routeToGroup = new()
    {
        ["sucursales"] = "estructura",
        ["sectores"] = "estructura",
        ["categorias"] = "estructura",
        ["horarios"] = "estructura",
        ["terminales"] = "estructura",
        ["terminales-moviles"] = "estructura",
        ["fichado-movil"] = "estructura",
        ["legajos"] = "personal",
        ["fichadas"] = "personal",
        ["reportes/asistencia"] = "reportes",
        ["reportes/llegadas-tarde"] = "reportes",
        ["reportes/ausencias"] = "reportes",
        ["reportes/horas-trabajadas"] = "reportes",
        ["incidencias"] = "operacion",
        ["vacaciones"] = "operacion",
        ["feriados"] = "operacion",
        ["noticias"] = "operacion",
        ["usuarios"] = "admin",
        ["configuracion/empresa"] = "admin",
        ["configuracion/planes"] = "admin",
        ["configuracion"] = "admin",
        ["auditoria"] = "admin",
    };

    protected override async Task OnInitializedAsync()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        AutoExpandGroup(currentUrl);
        NavigationManager.LocationChanged += OnLocationChanged;

        if (Tenant.EmpresaId > 0)
        {
            try { licenciaInfo = await LicenciaService.GetLicenciaInfoAsync(Tenant.EmpresaId); }
            catch { /* no bloquear si falla */ }

            try
            {
                await using var db = await DbFactory.CreateDbContextAsync();
                var empresa = await db.Empresas.AsNoTracking()
                    .Where(e => e.Id == Tenant.EmpresaId)
                    .Select(e => new { e.MobileHabilitado, e.KioskoHabilitado })
                    .FirstOrDefaultAsync();
                if (empresa != null)
                {
                    mobileHab = empresa.MobileHabilitado;
                    kioskoHab = empresa.KioskoHabilitado;
                }
            }
            catch { }
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        AutoExpandGroup(currentUrl);
        StateHasChanged();
    }

    private void AutoExpandGroup(string? url)
    {
        if (url == null) return;
        // Buscar el grupo que corresponde a la URL actual
        foreach (var kvp in routeToGroup)
        {
            if (url.StartsWith(kvp.Key, StringComparison.OrdinalIgnoreCase))
            {
                openGroups.Add(kvp.Value);
                break;
            }
        }
    }

    private void ToggleGroup(string group)
    {
        if (!openGroups.Remove(group))
            openGroups.Add(group);
    }

    private bool IsGroupOpen(string group) => openGroups.Contains(group);

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
