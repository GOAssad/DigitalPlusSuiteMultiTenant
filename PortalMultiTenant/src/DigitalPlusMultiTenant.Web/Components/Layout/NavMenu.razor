@implements IDisposable
@inject NavigationManager NavigationManager

<div class="sidebar-brand">
    <i class="bi bi-fingerprint"></i>
    <span>DigitalPlus</span>
</div>

<nav class="sidebar-nav">
    <AuthorizeView>
        <Authorized>
            <div class="nav-section-title">Principal</div>
            <NavLink class="sidebar-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-speedometer2"></i> Dashboard
            </NavLink>

            <div class="nav-section-title">Estructura</div>
            <NavLink class="sidebar-link" href="sucursales">
                <i class="bi bi-building"></i> Sucursales
            </NavLink>
            <NavLink class="sidebar-link" href="sectores">
                <i class="bi bi-diagram-3"></i> Sectores
            </NavLink>
            <NavLink class="sidebar-link" href="categorias">
                <i class="bi bi-tags"></i> Categorias
            </NavLink>
            <NavLink class="sidebar-link" href="horarios">
                <i class="bi bi-clock"></i> Horarios
            </NavLink>
            <NavLink class="sidebar-link" href="terminales">
                <i class="bi bi-pc-display"></i> Terminales
            </NavLink>

            <div class="nav-section-title">Personal</div>
            <NavLink class="sidebar-link" href="legajos">
                <i class="bi bi-people"></i> Legajos
            </NavLink>
            <NavLink class="sidebar-link" href="fichadas">
                <i class="bi bi-card-checklist"></i> Fichadas
            </NavLink>

            <div class="nav-section-title">Operacion</div>
            <NavLink class="sidebar-link" href="incidencias">
                <i class="bi bi-exclamation-triangle"></i> Incidencias
            </NavLink>
            <NavLink class="sidebar-link" href="vacaciones">
                <i class="bi bi-sun"></i> Vacaciones
            </NavLink>
            <NavLink class="sidebar-link" href="feriados">
                <i class="bi bi-calendar-event"></i> Feriados
            </NavLink>
            <NavLink class="sidebar-link" href="noticias">
                <i class="bi bi-megaphone"></i> Noticias
            </NavLink>

            <AuthorizeView Roles="SuperAdmin,AdminEmpresa" Context="adminContext">
                <div class="nav-section-title">Administracion</div>
                <NavLink class="sidebar-link" href="usuarios">
                    <i class="bi bi-person-lock"></i> Usuarios
                </NavLink>
                <NavLink class="sidebar-link" href="configuracion">
                    <i class="bi bi-gear"></i> Configuracion
                </NavLink>
            </AuthorizeView>
        </Authorized>
        <NotAuthorized>
            <div class="nav-section-title">Acceso</div>
            <NavLink class="sidebar-link" href="Account/Login">
                <i class="bi bi-box-arrow-in-right"></i> Iniciar sesion
            </NavLink>
        </NotAuthorized>
    </AuthorizeView>
</nav>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
