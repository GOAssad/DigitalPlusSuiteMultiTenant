@inherits LayoutComponentBase
@inject DigitalPlusMultiTenant.Application.Interfaces.ITenantService TenantService

<div class="app-layout">
    <nav class="sidebar">
        <NavMenu @rendermode="InteractiveServer" />
    </nav>

    <div class="main-content">
        <header class="top-bar">
            <div class="top-bar-left d-flex align-items-center">
                <button class="btn btn-link sidebar-toggle d-md-none" @onclick="ToggleSidebar">
                    <i class="bi bi-list fs-4"></i>
                </button>
                <AuthorizeView>
                    <Authorized>
                        <img src="/api/empresa-logo" alt="" class="empresa-logo me-2"
                             onerror="this.style.display='none'" />
                        <span class="empresa-nombre fw-semibold text-dark">@context.User.FindFirst("EmpresaNombre")?.Value</span>
                    </Authorized>
                </AuthorizeView>
            </div>
            <div class="top-bar-right">
                <AuthorizeView>
                    <Authorized>
                        <span class="text-muted me-3">
                            <i class="bi bi-building me-1"></i>@context.User.FindFirst("EmpresaId")?.Value
                        </span>
                        <a id="helpBtn" href="https://integraia.tech/digital-one-help.html" target="_blank" rel="noopener"
                           class="btn btn-link text-muted me-2" title="Ayuda" style="font-size:1.1rem;">
                            <i class="bi bi-question-circle"></i>
                        </a>
                        <div class="dropdown">
                            <button class="btn btn-link dropdown-toggle text-dark text-decoration-none" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>@context.User.Identity?.Name
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="Account/Manage"><i class="bi bi-gear me-2"></i>Mi cuenta</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form action="Account/Logout" method="post">
                                        <AntiforgeryToken />
                                        <input type="hidden" name="ReturnUrl" value="" />
                                        <button type="submit" class="dropdown-item"><i class="bi bi-box-arrow-right me-2"></i>Cerrar sesion</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </Authorized>
                </AuthorizeView>
            </div>
        </header>

        <AuthorizeView>
            <Authorized>
                @if (context.User.FindFirst("EmailConfirmed")?.Value == "false")
                {
                    <div class="alert alert-warning alert-dismissible m-3 mb-0 d-flex align-items-center" role="alert">
                        <i class="bi bi-envelope-exclamation me-2 fs-5"></i>
                        <div class="flex-grow-1">
                            Su email no esta verificado. <a href="Account/VerificarEmail" class="alert-link">Verificar ahora</a>
                        </div>
                    </div>
                }
            </Authorized>
        </AuthorizeView>

        <main class="page-content">
            <ErrorBoundary @ref="errorBoundary">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="ex">
                    @if (IsTransientError(ex))
                    {
                        <div class="alert alert-warning m-3">
                            <i class="bi bi-arrow-repeat me-2"></i>Se perdio la conexion. <a href="." class="alert-link">Recargar pagina</a>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger m-3">
                            <i class="bi bi-exclamation-triangle me-2"></i>Ocurrio un error. <a href="." class="alert-link">Recargar pagina</a>
                        </div>
                    }
                </ErrorContent>
            </ErrorBoundary>
        </main>
    </div>
</div>

<DigitalPlusMultiTenant.Web.Components.Shared.SolicitudSoporteModal />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool sidebarOpen;
    private ErrorBoundary? errorBoundary;

    protected override void OnParametersSet()
    {
        // Reset error boundary on navigation
        errorBoundary?.Recover();
    }

    private void ToggleSidebar()
    {
        sidebarOpen = !sidebarOpen;
    }

    private static bool IsTransientError(Exception ex)
    {
        return ex is InvalidOperationException ioe && ioe.Message.Contains("connection", StringComparison.OrdinalIgnoreCase)
            || ex is ObjectDisposedException
            || ex.InnerException is InvalidOperationException;
    }
}
