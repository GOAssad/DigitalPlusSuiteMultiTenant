@page "/Account/Register"

@inject NavigationManager NavigationManager

<PageTitle>Registro no disponible - DigitalPlus</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card border-0 shadow">
            <div class="card-body text-center p-4">
                <i class="bi bi-shield-lock text-warning" style="font-size: 3rem;"></i>
                <h5 class="mt-3">Registro no disponible</h5>
                <p class="text-muted">El registro de usuarios esta deshabilitado. Contacte al administrador de su empresa para obtener acceso.</p>
                <a href="Account/Login" class="btn btn-primary"><i class="bi bi-box-arrow-in-right me-2"></i>Ir a Iniciar Sesion</a>
            </div>
        </div>
    </div>
</div>
