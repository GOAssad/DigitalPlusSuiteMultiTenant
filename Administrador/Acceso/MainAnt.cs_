        private void botonMenuDispositivosDatos_Click(object sender, EventArgs e)
        {
            ZKDataMngForm oForm = new ZKDataMngForm(this);
            oForm.TopLevel = false;
            if (this.panelContenedor.Controls.Count > 0)
                this.panelContenedor.Controls.RemoveAt(0);
            this.panelContenedor.Controls.Add(oForm);
            this.panelContenedor.Tag = oForm;
            oForm.Show();
        }

