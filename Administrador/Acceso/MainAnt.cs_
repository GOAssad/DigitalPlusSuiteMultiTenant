		private void CargarPerfil()
		{
			nCantBotones = 
			int.Parse(Acceso.Clases.Datos.Generales.GRALVariablesGlobalesServicios.TraerValor("GRALCantidadBotonesMenu"));

			for (int i = 0; i < nCantBotones; i++)
			{
				SumarBotones();
			}
		}

