		private void SumarBotones()
		{
			if (naviBarXuXo.NaviLayout is NaviLayoutOff)
			{
				naviBarXuXo.VisibleLargeButtons++;
			}
		}

		private void RestarBotones()
		{
			if (naviBarXuXo.NaviLayout is NaviLayoutOff)
			{
				naviBarXuXo.VisibleLargeButtons--;
			}
		}
		
		private void ActualizarVariablesGlobales()
		{
			using (Acceso.Datos.Model.AccesosEntidades db = new AccesosEntidades())
			{
				GRALVariablesGlobales oVar = db.GRALVariablesGlobales.Where(x => x.sVariableGlobalID == "GRALCantidadBotonesMenu").FirstOrDefault();
				oVar.sValor = naviBarXuXo.VisibleLargeButtons.ToString();
				db.GRALVariablesGlobales.Attach(oVar);
				db.Entry(oVar).State = System.Data.Entity.EntityState.Modified;
				db.SaveChanges();
			}
		}
