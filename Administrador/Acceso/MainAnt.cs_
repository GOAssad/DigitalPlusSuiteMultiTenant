		private void ModulosAtivados()
		{
			using (Acceso.Datos.Model.AccesosEntidades db = new Datos.Model.AccesosEntidades())
			{
				List<METAModulos> lmod = db.METAModulos.ToList();
				foreach (METAModulos item in lmod)
				{
					if (item.sCodigoActivacion != string.Empty)
					{
					//	naviBarXuXo.ActiveBand = this.naviBandInicio;

						//activado
						switch (item.sDescripcion)
						{
							case "RRHH":
								naviBandRRHH.Visible = true;
								if (item.bEsInicio)
									naviBarXuXo.ActiveBand = this.naviBandRRHH;
								break;
							case "INVENTARIO":
								naviBandInventario.Visible = true;
								if (item.bEsInicio)
									naviBarXuXo.ActiveBand = this.naviBandInventario;
								break;
							case "DISPOSITIVOS":
								naviBandDispositivos.Visible = true;
								if (item.bEsInicio)
									naviBarXuXo.ActiveBand = this.naviBandDispositivos;
								break;
							default:
								break;
						}
						this.naviBarXuXo.Refresh();
					}
				}
			}
		}

