		private void botonConfigMenuGuardar_Click(object sender, EventArgs e)
		{
			if (saveFileDialogSettings.ShowDialog() == DialogResult.OK)
			{
				try
				{
					string fileName = saveFileDialogSettings.FileName;
					NaviBarSettingsSerializer serial = new NaviBarSettingsSerializer();
					using (TextWriter w = new StreamWriter(fileName))
					{
						serial.Serialize(w, naviBarXuXo.Settings);
					}
				}
				catch (Exception ex)
				{
					MessageBox.Show(ex.Message);
				}
			}
		}

		private void botonConfigMenuCargar_Click(object sender, EventArgs e)
		{
			if (openFileDialogSettings.ShowDialog() == DialogResult.OK)
			{
				try
				{
					string fileName = openFileDialogSettings.FileName;
					NaviBarSettingsSerializer serial = new NaviBarSettingsSerializer();
					using (StreamReader reader = new StreamReader(fileName))
					{
						NaviBarSettings settings = serial.Deserialize(reader) as NaviBarSettings;
						if (settings != null)
						{
							naviBarXuXo.Settings = settings;
							naviBarXuXo.ApplySettings();
						}
					}
				}
				catch (Exception ex)
				{
					MessageBox.Show(ex.Message);
				}
			}
		}


		protected void AbrirFormEF(object formhijo)
		{
			if (this.panelContenedor.Controls.Count > 0)
				this.panelContenedor.Controls.RemoveAt(0);

			Form fh = formhijo as FrmEntidadesBase;
			fh.TopLevel = false;
			fh.Dock = DockStyle.Fill;
			this.panelContenedor.Controls.Add(fh);
			this.panelContenedor.Tag = fh;
			 
			
			if ((VerificarActivacion((FrmEntidadesBase)fh) || Acceso.Clases.Datos.Generales.sysGlobales.oUsuario.nUsuarioCategoriaID == 1))
			{
				fh.Show();
			}
				

			else
			{
				string empresa = Acceso.Clases.Datos.Generales.GRALVariablesGlobalesServicios.TraerValor("GRALEmpresaRazonSocial");
				MessageBox.Show("Esta aplicación se encuentra desactivada");
				return;
			}
				
		}

		private bool VerificarActivacion(FrmEntidadesBase frm)
		{
			// me fijo si el usuario tiene privilegios para entrar al formulario



			//31/07/2018
			//Leer las propiedades del Formulario desde la base de datos.
			using (AccesosEntidades db = new AccesosEntidades())
			{
				
				var oProp = db.METAFormularios.Where(x => x.sFormularioID == frm.Name.Trim()).FirstOrDefault();

				if (oProp == null) return false;
				if (!oProp.nActivar) return false;
			}

			return true;
		}

