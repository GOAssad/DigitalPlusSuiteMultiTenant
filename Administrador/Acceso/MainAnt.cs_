		private void comboBoxLayOut_SelectedIndexChanged(object sender, EventArgs e)
		{
			switch (comboBoxLayOut.SelectedItem.ToString())
			{
				case "Office 2003 Blue":
					naviBarXuXo.LayoutStyle = NaviLayoutStyle.Office2003Blue;
					break;
				case "Office 2003 Green":
					naviBarXuXo.LayoutStyle = NaviLayoutStyle.Office2003Green;
					break;
				case "Office 2003 Silver":
					naviBarXuXo.LayoutStyle = NaviLayoutStyle.Office2003Silver;
					break;
				case "Office 2007 Blue":
					naviBarXuXo.LayoutStyle = NaviLayoutStyle.Office2007Blue;
					break;
				case "Office 2007 Black":
					naviBarXuXo.LayoutStyle = NaviLayoutStyle.Office2007Black;
					break;
				case "Office 2007 Silver":
					naviBarXuXo.LayoutStyle = NaviLayoutStyle.Office2007Silver;
					break;
				case "Office 2010":
					break;
				case "Office Guifreaks":
					break;
			}
		}
