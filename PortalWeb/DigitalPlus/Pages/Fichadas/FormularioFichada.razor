@inject RepositorioSucursales repositorioSucursales
@inject IMostrarMensajes mostrarMensajes

<EditForm Model="Fichada" OnValidSubmit="OnValidSubmit">
    <DataAnnotationsValidator />


    <div class="form-group">
        <label>Fecha:</label>
        <div>
            <InputDate Type="InputDateType.DateTimeLocal" class="form-control" @bind-Value="Fichada.Registro" />
            <ValidationMessage For="@(() => Fichada.Registro)" />
        </div>
    </div>
   

    <div class="form-group mb-3">
        <label>Entrada / Salida:</label>
        <select class="form-control" @bind="@Fichada.EntraSale">
            <option value="E">Entrada</option>
            <option value="S">Salida</option>
        </select>
    </div>

    <div class="form-group mb-3">
        <label>Sucursal:</label>
        <select class="form-control" @bind="@Fichada.SucursalId">
            <option value="0">--Seleccione una Sucursal--</option>
            @foreach (var item in Sucursales)
            {
                <option value="@item.Id">@item.Nombre</option>
            }
        </select>
    </div>
    <button class="btn btn-success" type="submit">Guardar Cambios</button>
    <a class="btn btn-secondary" href="@ruta/@Fichada.Legajoid">Cancelar</a>
</EditForm>

@code {
    [Parameter] public Fichada Fichada { get; set; }
    [Parameter] public int OrigenId { get; set; } //1 = Fichada, 2 = Control, es para el cancelar
    [Parameter] public EventCallback OnValidSubmit { get; set; }
    [Parameter] public int LegajoId { get; set; }

    private string ruta = @"/fichadas";

    List<Sucursal> Sucursales = new List<Sucursal>();
    protected override async Task OnInitializedAsync()
    {
        //Sucursales = await repositorioSucursales.Get(string.Empty);

        //gustavo 17/01/2023 - Solo sucursales permitidas
        Sucursales = await repositorioSucursales.GetLegajosSucursalesSQL(LegajoId);

        if (OrigenId == 1) ruta = @"/fichadas";
        if (OrigenId == 2) ruta = @"/fichadas/control";
        if (OrigenId == 3) ruta = @"/legajos/dashboard";

    }

}
