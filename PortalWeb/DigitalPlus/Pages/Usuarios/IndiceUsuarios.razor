@page "/usuarios"
@attribute [Authorize(Roles = "ADMINISTRADOR")]
@inject RepositorioUsuarios repositorio
@inject IMostrarMensajes mostrarMensajes
@inject ListadoVariablesGlobales VariablesGlobales



<div class="container-fluid">
    <div class="titulo">
        <h3>Indice Usuarios: @empresa </h3>
    </div>
    <Paginacion PaginaActual="paginaActual" PaginaSeleccionada="paginaSeleccionada"
                PaginasTotales="paginasTotales"></Paginacion>

    <ListadoGenerico Listado="Usuarios">
        <HayRegistrosCompleto>
            <table class="table">
                <thead>
                    <tr>
                        <th></th>
                        <th>Usuario</th>
                        <th>Email</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var usuario in Usuarios)
                    {
                        <tr>
                            <td>
                                <a href="/usuarios/editar/@usuario.UserId" class="btn btn-success">Editar</a>
                            </td>
                            <td>
                                @usuario.UserName
                            </td>
                            <td>
                                @usuario.Email
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </HayRegistrosCompleto>
    </ListadoGenerico>
</div>
@code {
    List<UsuarioDTO> Usuarios;

    private int paginaActual = 1;
    private int paginasTotales;
    private string empresa = string.Empty;

    private async Task paginaSeleccionada(int pagina)
    {
        paginaActual = pagina;
        await Cargar(pagina);
    }

    protected override async Task OnInitializedAsync()
    {
        empresa = VariablesGlobales.Variables.Where(s => s.sId == "EMP_NOMBRE_COMPLETO").Select(x => x.Valor).FirstOrDefault();
        await Cargar();
    }

    private async Task Cargar(int pagina = 1)
    {
        var respuestaPaginada = await repositorio.Get(new DTOs.Paginacion { Pagina = pagina });
        paginasTotales = respuestaPaginada.TotalPaginas;
        Usuarios = respuestaPaginada.Registros;
    }
}