            });
        Lista.Add(new ListaMenuDTO
            {
                Id = 2,
                Nombre = "Sucursales",
                referencia = "sucursales",
                icono = "icono bi bi-hourglass-bottom"
            });
        Lista.Add(new ListaMenuDTO
            {
                Id = 3,
                Nombre = "Horarios",
                referencia = "horarios",
                icono = "icono bi-calendar2-x-fill"
            });
        Lista.Add(new ListaMenuDTO
            {
                Id = 4,
                Nombre = "Sectores",
                referencia = "sectores",
                icono = "icono bi-person-rolodex"
            });
        Lista.Add(new ListaMenuDTO
            {
                Id = 5,
                Nombre = "Terminales",
                referencia = "terminales",
                icono = "icono bi-person-rolodex"
            });

        Lista.Add(new ListaMenuDTO
            {
                Id = 6,
                Nombre = "Incidencias",
                referencia = "incidencias",
                icono = "icono bi-person-rolodex"
            });
    }
}
