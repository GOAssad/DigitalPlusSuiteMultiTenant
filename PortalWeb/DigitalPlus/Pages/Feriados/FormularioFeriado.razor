<EditForm Model="Feriado" OnValidSubmit="OnValidSubmit">
    <DataAnnotationsValidator />
    <div class="form-group">
        <label>Nombre:</label>
        <div class="mb-3">
            <InputText class="form-control" @bind-Value="@Feriado.Nombre" />
            <ValidationMessage For="@(() => Feriado.Nombre)" />
        </div>
    </div>

    <div class="form-group">
        <label>Fecha Desde:</label>
         <div class="mb-3">
            <input type="date" class="form-control" @bind-value="Feriado.Fecha" />
        </div>
    </div>

    <div class="form-group">
        <label>Fecha Hasta:</label>
         <div class="mb-3">
             <input type="date" class="form-control" @bind-value="Feriado.FechaHasta" />
        </div>
    </div>
    
    <button class="btn btn-success" type="submit">Guardar Cambios</button>
    <a class="btn btn-secondary" href="/feriados">Cancelar</a>
</EditForm>

@code {
    [Parameter] public FeriadoDTO Feriado { get; set; }
    [Parameter] public EventCallback OnValidSubmit { get; set; }





}
