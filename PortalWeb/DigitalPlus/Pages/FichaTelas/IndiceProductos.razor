@page "/Productos"
@using Microsoft.AspNetCore.Components.QuickGrid
@attribute [Authorize(Roles = "Admin_Telas")]
@inject RepositorioProductos repositorio
@inject IMostrarMensajes mostrarMensajes
@inject NavigationManager navigationManager
@inject ListadoVariablesGlobales VariablesGlobales





<div class="container">
    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-3 align-items-center mb-3">
                <div class="col-sm-4">

                    <input type="text" class="form-control" id="nombre" placeholder="Articulo..."
                           @bind-value="nombre" @bind-value:event="oninput"
                           @onkeypress="@((KeyboardEventArgs e) => NombreKeyPress(e))" />

                </div>
                <div class="col-sm-4">

                    <input type="text" class="form-control" id="descripcion" placeholder="Descripcion..."
                           @bind-value="descripcion" @bind-value:event="oninput"
                           @onkeypress="@((KeyboardEventArgs e) => NombreKeyPress(e))" />

                </div>
                <div class="col-sm-4">

                    <input type="text" class="form-control" id="proveedor" placeholder="Proveeodr..."
                           @bind-value="proveedor" @bind-value:event="oninput"
                           @onkeypress="@((KeyboardEventArgs e) => NombreKeyPress(e))" />

                </div>
            </div>
            <div class="row g-3 align-items-center mb-3">

                <div class="col">
                    <div class="form-inline">
                        <select class="form-control mb-2 mr-sm-2" @onchange="CambioProveedor">
                            <option value="0" selected>--Seleccione un proveedor--</option>
                            @foreach (var rol in proveedores)
                            {
                                <option value="@rol.VENDORID">@rol.VENDNAME</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col">
                    <div class="form-inline">
                        <select class="form-control mb-2 mr-sm-2" @onchange="CambioGrupo">
                            <option value="0" selected>--Seleccione un grupo--</option>
                            @if (grupos is not null)
                            {
                                @foreach (var rol in grupos)
                                {
                                    <option value="@rol.GRUPOID">@rol.GRUPO</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="col">
                    <div class="form-inline">
                        <select class="form-control mb-2 mr-sm-2" @onchange="CambioColores">
                            <option value="0" selected>--Seleccione un color--</option>
                            @if (colores is not null)
                            {
                                @foreach (var rol in colores)
                                {
                                    <option value="@rol.ColorID">@rol.Color</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="col">
                    <div class="form-inline">
                        <select class="form-control mb-2 mr-sm-2" @bind="filtrar">
                            <option value="0" selected>Todos</option>
                            <option value="1">Solo Existencia</option>
                        </select>
                    </div>
                </div>
                <div class="col-1 columna-imagen">
                    <button class="btn btn-sm" @onclick="ClickTraer">
                        <img class="imagen-menu" src="/imagenes/FichaProductos_Tela.png" />
                    </button>

                </div>
            </div>
        </div>
    </div>
    <div class="container-fluid">

        @* <Paginacion PaginaActual="paginaActual" PaginaSeleccionada="paginaSeleccionada"
        PaginasTotales="paginasTotales"></Paginacion> *@


        <ListadoGenerico Listado="productos">
            <HayRegistrosCompleto>
                <table class="table">
                    <thead>
                        <tr>
                            <th></th>
                            <th>ItemNmbr</th>
                            <th>Descripcion</th>
                            <th>Stock</th>
                            <th>Proveedor</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var producto in productos)
                        {
                            @if ((filtrar == "1" && producto.CANTIDAD > 0) || (filtrar == "0"))
                            {
                                <tr>
                                    <td>
                                        <a href="/productos/ficha/@producto.ITEMNMBR/@producto.ITEMDESC" class="btn btn-success">Acceder</a>
                                    </td>
                                    <td>
                                        @producto.ITEMNMBR
                                    </td>
                                    <td>
                                        @producto.ITEMDESC
                                    </td>

                                    <td>
                                        @producto.CANTIDAD

                                    </td>
                                    <td>
                                        @producto.VendName
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </HayRegistrosCompleto>
        </ListadoGenerico>
    </div>
</div>



@code {
    // 05/02/2023 - Identity
    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; }
    private AuthenticationState authenticationState;
    //------------------------------------------------------------------------

    private List<ProveedorDTO> proveedores = new List<ProveedorDTO>();
    private List<GrupoDTO> grupos = new List<GrupoDTO>();
    private List<ColorDTO> colores = new List<ColorDTO>();
    private List<ProductoDTO> productos = new List<ProductoDTO>();


    private string proveedorSeleccionado = "0";
    private string grupoSeleccionado = "0";
    private string colorSeleccionado = "0";
    private string filtrar = "0";

    string nombre = string.Empty;
    string descripcion = string.Empty;
    string proveedor = string.Empty;
    private int tipoBusqueda;

    QuickGrid<Legajo>? grid;
    bool soloActivos = true;
    int itemsperpage = 5;
    //PaginationState pagination = new PaginationState { ItemsPerPage = 10 };
    PaginationState pagination = new PaginationState();



    private int paginaActual = 1;
    private int paginasTotales;
    string textobusqueda;
    string textobusquedasector;

    bool activarCartel = false;


    protected async override Task OnInitializedAsync()
    {


        pagination.ItemsPerPage = 10;

        //////////////////////////////////////////////////////////////////
        await traigoProveedores();
        await TraigoGrupos();

    }

    private async Task paginaSeleccionada(int pagina)
    {
        paginaActual = pagina;
        await traigoProveedores();
        await TraigoGrupos();

    }

    //private async Task Cargar(int pagina = 1)
    private async Task traigoProveedores()
    {

        //5/2/2023
        if (AuthenticationStateTask is not null)
        {
            authenticationState = await AuthenticationStateTask;
            var claimsPrincipal = authenticationState.User;
            //Obtengo el ID del usuario
            string userId = claimsPrincipal.FindFirst(ClaimTypes.NameIdentifier).Value;

            //Legajos = await repositorio.GetLegajoSegunUsuario(userId, texto);

            proveedores = await repositorio.TraerProveedores();
            if (proveedores is null)
            {
                await mostrarMensajes.MostrarMensajeError(repositorio.mensaje);
                return;
            }

        }
        else
        {
            proveedores = await repositorio.TraerProveedores();
            if (proveedores is null)
            {
                await mostrarMensajes.MostrarMensajeError(repositorio.mensaje);
                return;
            }

        }
    }

    private async Task TraigoGrupos()
    {


        //5/2/2023
        if (AuthenticationStateTask is not null)
        {
            authenticationState = await AuthenticationStateTask;
            var claimsPrincipal = authenticationState.User;
            //Obtengo el ID del usuario
            string userId = claimsPrincipal.FindFirst(ClaimTypes.NameIdentifier).Value;

            //Legajos = await repositorio.GetLegajoSegunUsuario(userId, texto);


            grupos = await repositorio.TraerGrupos(proveedorSeleccionado);
            if (grupos is null)
            {
                await mostrarMensajes.MostrarMensajeError(repositorio.mensaje);
                return;
            }
        }
        else
        {

            grupos = await repositorio.TraerGrupos(proveedorSeleccionado);
            if (grupos is null)
            {
                await mostrarMensajes.MostrarMensajeError(repositorio.mensaje);
                return;
            }

        }
    }

    private async Task CambioProveedor(ChangeEventArgs e)
    {
        productos = new();
        proveedorSeleccionado = e.Value.ToString().Trim();
        await TraigoGrupos();
        //grupos = await repositorio.TraerGrupos(proveedorSeleccionado);
        await LlenoColores();

        //colores = await repositorio.TraerColores(proveedorSeleccionado, "0");

    }

    private async Task CambioGrupo(ChangeEventArgs e)
    {
        grupoSeleccionado = e.Value.ToString().Trim();
        await LlenoColores();

        tipoBusqueda = 2;
        string _SqlAyuda = CrearSQL(tipoBusqueda);
        productos = await repositorio.TraerProductos(_SqlAyuda);

        //colores = await repositorio.TraerColores(proveedorSeleccionado, grupoSeleccionado);
        //await TraerProductos(grupoSeleccionado, string.Empty);
    }

    private async Task LlenoColores()
    {

        string innerGrupos = " ";
        if (grupoSeleccionado != "0")
            innerGrupos = " and c.SGMCOD = '" + grupoSeleccionado + "' ";


        string innerProveedor = " ";
        if (proveedorSeleccionado != "0")
            innerProveedor = " inner join PRD01..IV00103 A on B.ITEMNMBR = A.ITEMNMBR AND a.VENDORID = '" + proveedorSeleccionado + "' ";


        string _SqlAyuda = "SELECT DISTINCT " +
        " h.DSCRIPTN Color, h.SGMCOD ColorID " +
        " FROM PRD01..iv00101 B " +
        " INNER JOIN    PRD01..SOL_GCA00100 C ON LEFT(b.ITEMNMBR, 2) = C.SGMCOD AND " +
        " c.ITMCLSCD = 'mp-tel' AND C.SGMTNUMB = 1 " +
        " INNER JOIN    PRD01..SOL_GCA00100 h ON SUBSTRING(b.ITEMNMBR, 13, 3) = h.SGMCOD AND " +
        " h.ITMCLSCD = 'mp-tel' AND H.SGMTNUMB = 6 " + innerProveedor +
        " WHERE B.ITMCLSCD = 'mp-tel' " + innerGrupos +
        " ORDER BY 1, 2 ";

        colores = await repositorio.TraerColores(_SqlAyuda);
    }

    private async Task ClickTraer()
    {
        if (nombre == string.Empty &
                    descripcion == string.Empty &
                        proveedor == string.Empty)
            return;
        tipoBusqueda = 1;
        string _SqlAyuda = CrearSQL(tipoBusqueda);
        productos = await repositorio.TraerProductos(_SqlAyuda);
    }

    private string CrearSQL(int tipo)
    {

        string innerleft;
        string sSQL = "";

        string where;
        where = string.Empty;


        if (tipo == 1)
        {
            if (proveedorSeleccionado == "0")
                innerleft = " INNER ";
            else
                innerleft = " LEFT ";

            sSQL = "Select distinct a.itemnmbr, a.itemdesc, isnull(d.QTYONHND,0) Cantidad, c.VENDNAME" +
                //", isnull(c.VENDORID, 's/d') VendorID, isnull(c.VENDNAME, 's/d') VendName " +
                " from PRD01..iv00101 a " +
                " left join PRD01..IV00102 d on a.itemnmbr = d.itemnmbr  " + innerleft +
                " join PRD01..iv00103 b on a.ITEMNMBR = b.ITEMNMBR " + innerleft +
                " join PRD01..PM00200 c ON B.VENDORID = C.VENDORID " +
                " WHERE " +
                " A.ITEMNMBR LIKE '" + nombre.Trim() + "%' " +
                " AND a.ITEMDESC like '%" + descripcion.Trim() + "%' " +
                " and c.VENDNAME like '%" + proveedor.Trim() + "%' " +
                " and d.locncode = 'DPT-CUY' ";

        }
        if (tipo == 2)
        {
            if (filtrar == "1")
                where = " and ISNULL(A.QTYONHND, 0) > 0";

            sSQL = "SELECT B.itemnmbr, B.ITEMDESC, ISNULL(A.QTYONHND, 0) Cantidad, '' VENDNAME " +
                    " FROM PRD01..iv00101 b " +
                    " left JOIN PRD01..IV00102 a ON A.ITEMNMBR = B.ITEMNMBR AND A.LOCNCODE = 'dpt-cuy' " +
                    " INNER JOIN    PRD01..SOL_GCA00100 C ON LEFT(B.ITEMNMBR, 2) = C.SGMCOD AND " +
                    " c.ITMCLSCD = 'mp-tel' AND C.SGMTNUMB = 1 and C.SGMCOD = '" + grupoSeleccionado.Trim() + "'" +
                    " INNER JOIN    PRD01..SOL_GCA00100 h ON SUBSTRING(B.ITEMNMBR,13,3) = h.SGMCOD AND " +
                    " h.ITMCLSCD = 'mp-tel' AND H.SGMTNUMB = 6 and H.SGMCOD = '" + colorSeleccionado.ToString().Trim() + "'" +
                    " WHERE B.ITMCLSCD = 'mp-tel' " + where +
                    " order by 1 ";
        }
        return sSQL;
    }

    private async Task CambioColores(ChangeEventArgs e)
    {
        colorSeleccionado = e.Value.ToString().Trim();
        tipoBusqueda = 2;
        string _SqlAyuda = CrearSQL(tipoBusqueda);
        productos = await repositorio.TraerProductos(_SqlAyuda);

        //await TraerProductos(grupoSeleccionado, colorSeleccionado);
    }

    private async Task TraerProductos(string grupo, string color)
    {
        productos = await repositorio.TraerProductos(grupo, color, nombre);

    }

    private async Task TraerProductos()
    {
        string sJoin = string.Empty;
        if (proveedorSeleccionado == "0")
            sJoin = " Left ";
        else
            sJoin = " Inner ";

        productos = await repositorio.TraerProductos(grupoSeleccionado, colorSeleccionado, nombre, descripcion, proveedor, sJoin);
        if (repositorio.mensaje != string.Empty)
            await mostrarMensajes.MostrarMensajeError(repositorio.mensaje);


    }

    private async Task NombreKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            tipoBusqueda = 1;
            string _SqlAyuda = CrearSQL(tipoBusqueda);
            productos = await repositorio.TraerProductos(_SqlAyuda);
        }
    }
}
