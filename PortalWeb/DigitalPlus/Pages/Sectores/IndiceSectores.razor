@page "/sectores"
@attribute [Authorize(Roles = "ADMINISTRADOR")]
@inject RepositorioSectores repositorio
@inject IMostrarMensajes mostrarMensajes
@inject NavigationManager navigationManager


<div class="container">
    <TituloPrincipal src="/imagenes/Atributos_Sector.png" Titulo="Sectores" />

    <div class="form-group">
        <BotonAgregarEntidad CrearEntidad="Crear" TextoBoton="Crear Sector"></BotonAgregarEntidad>
        <FiltroIndice Cargar="Cargar" textobusqueda="@textobusqueda"></FiltroIndice>
    </div>

    <ListadoGenerico Listado="Sectores">
        <HayRegistrosCompleto>
            <table class="table table-striped">
                <thead class="cabeceraTabla">
                    <tr>
                        <th>Acciones</th>
                        <th>Nombre</th>

                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Sectores)
                    {
                        <tr>
                            <td>
                                <a href="/sectores/editar/@item.Id" class="btn btn-success btn-sm">Editar</a>
                                <button @onclick="@(() => BorrarSectores(item))" class="btn btn-danger btn-sm">Borrar</button>
                            </td>
                            <td>@item.Nombre</td>

                        </tr>
                    }
                </tbody>
            </table>
        </HayRegistrosCompleto>
    </ListadoGenerico>
</div>
@code {
    public List<Sector> Sectores { get; set; }
    string textobusqueda;

    protected async override Task OnInitializedAsync()
    {
        await Cargar(string.Empty);
    }

    private async Task Cargar(string texto)
    {
        Sectores = await repositorio.Get(texto);
    }

    private async Task BorrarSectores(Sector objeto)
    {
        var condicion = await mostrarMensajes.MostrarMensajeBorrar(objeto.Nombre);

        if (condicion)
        {
            await mostrarMensajes.MostrarMensajeTemporal("Sector", $"{objeto.Nombre}: ...borrado");
            await repositorio.Delete(objeto.Id);
        }

        await Cargar(string.Empty);
    }
    private void Crear()
    {
        navigationManager.NavigateTo("sectores/crear");
    }
}
