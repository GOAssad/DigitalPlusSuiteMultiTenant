
<div class="row gap-3">
    <div class="col">
        <input @bind-value="textobusqueda" @bind-value:event="oninput"
               @onkeypress="@((KeyboardEventArgs e) => NombreKeyPress(e))"
               type="text" class="col-8" id="nombre" placeholder="texto a buscar" />

        @*<button type="button" class="btn btn-primary col-1" @onclick="@(()=>Cargar.InvokeAsync(Texto))">Filtrar</button>*@
        @*<button type="button" class="btn btn-danger mb-2" @onclick="LimpiarOnClick">Limpiar</button>*@
        <div class="mt-3">
            <LineaDivisoria />
        </div>
    </div>

</div>


@code {
    private string Texto { get; set; }
    [Parameter] public string textobusqueda { get; set; }
    [Parameter] public EventCallback<string> Cargar { get; set; }

    private async Task NombreKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Cargar.InvokeAsync(textobusqueda);

        }
    }


}