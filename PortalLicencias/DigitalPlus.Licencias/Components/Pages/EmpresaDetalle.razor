@page "/empresas/{Id:int}"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject DigitalPlus.Licencias.Repositorios.RepositorioLicencias Repo
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject DigitalPlus.Licencias.Services.MultiTenantProvisioningService MTService
@inject IConfiguration Config

<PageTitle>Detalle Empresa - DigitalPlus</PageTitle>

@if (empresa == null)
{
    <p>Cargando...</p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">@empresa.Nombre</h3>
        <span class="badge fs-6 @(empresa.Estado == "activa" ? "bg-success" : empresa.Estado == "suspendida" ? "bg-warning text-dark" : "bg-danger")">
            @empresa.EstadoDisplay
        </span>
    </div>

    <div class="row g-3">
        <div class="col-md-8">
            <div class="card mb-3">
                <div class="card-header">Datos generales</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Nombre</label>
                            <input type="text" class="form-control" @bind="empresa.Nombre" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Company ID</label>
                            <input type="text" class="form-control" value="@empresa.CompanyId" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Base de datos</label>
                            <input type="text" class="form-control" @bind="empresa.DatabaseName" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Estado</label>
                            <select class="form-select" @bind="empresa.Estado">
                                <option value="activa">Activa</option>
                                <option value="suspendida">Suspendida</option>
                                <option value="baja">Baja</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">URL Portal Web</label>
                            <input type="url" class="form-control" placeholder="https://digitalplusportalmt.azurewebsites.net/" @bind="empresa.UrlPortal" />
                            <small class="text-muted">URL del portal al que se redirige esta empresa para cambio de clave y gestion web</small>
                        </div>
                        <div class="col-12">
                            <h6 class="text-muted mt-2 mb-2">Modulos opcionales</h6>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" @bind="empresa.MobileHabilitado" id="chkMobile" />
                                <label class="form-check-label" for="chkMobile">Fichado Movil habilitado</label>
                            </div>
                            <small class="text-muted">Permite a los empleados fichar ingreso/egreso desde el celular</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">Datos fiscales</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Pais</label>
                            <select class="form-select" value="@selectedPaisId" @onchange="OnPaisChangedEvent">
                                <option value="">-- Seleccionar --</option>
                                @if (paises != null)
                                {
                                    @foreach (var p in paises)
                                    {
                                        <option value="@p.Id">@p.Nombre</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Tipo identificacion</label>
                            <select class="form-select" value="@selectedTipoIdFiscalId" @onchange="OnTipoIdChanged">
                                <option value="">-- Seleccionar --</option>
                                @if (tiposId != null)
                                {
                                    @foreach (var t in tiposId)
                                    {
                                        <option value="@t.Id">@t.Nombre (@t.Ejemplo)</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Identificacion fiscal</label>
                            <input type="text" class="form-control" @bind="empresa.IdentificacionFiscal" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Razon Social</label>
                            <input type="text" class="form-control" @bind="empresa.RazonSocial" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Domicilio Fiscal</label>
                            <input type="text" class="form-control" @bind="empresa.DomicilioFiscal" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">Contacto</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Contacto</label>
                            <input type="text" class="form-control" @bind="empresa.Contacto" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" @bind="empresa.Email" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Telefono</label>
                            <input type="text" class="form-control" @bind="empresa.Telefono" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Direccion</label>
                            <input type="text" class="form-control" @bind="empresa.Direccion" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">Identidad de la Empresa</div>
                <div class="card-body">
                    <div class="row align-items-center g-3 mb-3">
                        <div class="col-auto">
                            @if (empresa.Logo != null && empresa.LogoContentType != null)
                            {
                                <img src="data:@empresa.LogoContentType;base64,@Convert.ToBase64String(empresa.Logo)"
                                     alt="Logo" style="max-height:80px; max-width:200px;" class="border rounded p-1" />
                            }
                            else
                            {
                                <div class="border rounded p-3 text-muted text-center" style="width:120px;height:80px;line-height:50px;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16"><path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z"/><path d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2h-12zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1h12z"/></svg>
                                </div>
                            }
                        </div>
                        <div class="col">
                            <InputFile OnChange="OnLogoSelected" accept="image/png,image/jpeg,image/svg+xml,image/webp" class="form-control form-control-sm" />
                            <small class="text-muted">PNG, JPG, SVG o WebP. Max 500 KB.</small>
                            @if (empresa.Logo != null)
                            {
                                <button class="btn btn-sm btn-outline-danger mt-1" @onclick="QuitarLogo">Quitar logo</button>
                            }
                        </div>
                    </div>
                    <hr />
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="me-1"><path d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm7.5-6.923c-.67.204-1.335.82-1.887 1.855A7.97 7.97 0 0 0 5.145 4H7.5V1.077zM4.09 4a9.267 9.267 0 0 1 .64-1.539 6.7 6.7 0 0 1 .597-.933A7.025 7.025 0 0 0 2.255 4H4.09zm-.582 3.5c.03-.877.138-1.718.312-2.5H1.674a6.958 6.958 0 0 0-.656 2.5h2.49zM4.847 5a12.5 12.5 0 0 0-.338 2.5H7.5V5H4.847zM8.5 5v2.5h2.99a12.495 12.495 0 0 0-.337-2.5H8.5zM4.51 8.5a12.5 12.5 0 0 0 .337 2.5H7.5V8.5H4.51zm3.99 0V11h2.653c.187-.765.306-1.608.338-2.5H8.5zM5.145 12c.138.386.295.744.468 1.068.552 1.035 1.218 1.65 1.887 1.855V12H5.145zm.182 2.472a6.696 6.696 0 0 1-.597-.933A9.268 9.268 0 0 1 4.09 12H2.255a7.024 7.024 0 0 0 3.072 2.472zM3.82 11a13.652 13.652 0 0 1-.312-2.5h-2.49c.062.89.291 1.733.656 2.5H3.82zm6.853 3.472A7.024 7.024 0 0 0 13.745 12H11.91a9.27 9.27 0 0 1-.64 1.539 6.688 6.688 0 0 1-.597.933zM8.5 12v2.923c.67-.204 1.335-.82 1.887-1.855.173-.324.33-.682.468-1.068H8.5zm3.68-1h2.146c.365-.767.594-1.61.656-2.5h-2.49a13.65 13.65 0 0 1-.312 2.5zm2.802-3.5a6.959 6.959 0 0 0-.656-2.5H12.18c.174.782.282 1.623.312 2.5h2.49zM11.27 2.461c.247.464.462.98.64 1.539h1.835a7.024 7.024 0 0 0-3.072-2.472c.218.284.418.598.597.933zM10.855 4a7.966 7.966 0 0 0-.468-1.068C9.835 1.897 9.17 1.282 8.5 1.077V4h2.355z"/></svg>
                                Pagina web
                            </label>
                            <input type="url" class="form-control" placeholder="https://www.ejemplo.com" @bind="empresa.PaginaWeb" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="me-1"><path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951z"/></svg>
                                Facebook
                            </label>
                            <input type="url" class="form-control" placeholder="https://facebook.com/empresa" @bind="empresa.Facebook" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="me-1"><path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.917 3.917 0 0 0-1.417.923A3.927 3.927 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.916 3.916 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.926 3.926 0 0 0-.923-1.417A3.911 3.911 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0h.003zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599.28.28.453.546.598.92.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.47 2.47 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.478 2.478 0 0 1-.92-.598 2.48 2.48 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233 0-2.136.008-2.388.046-3.231.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92.28-.28.546-.453.92-.598.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045v.002zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92zm-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217zm0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334z"/></svg>
                                Instagram
                            </label>
                            <input type="url" class="form-control" placeholder="https://instagram.com/empresa" @bind="empresa.Instagram" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="me-1"><path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/></svg>
                                LinkedIn
                            </label>
                            <input type="url" class="form-control" placeholder="https://linkedin.com/company/empresa" @bind="empresa.LinkedIn" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="me-1"><path d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.601.75Zm-.86 13.028h1.36L4.323 2.145H2.865l8.875 11.633Z"/></svg>
                                X (Twitter)
                            </label>
                            <input type="url" class="form-control" placeholder="https://x.com/empresa" @bind="empresa.Twitter" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="me-1"><path d="M8.051 1.999h.089c.822.003 4.987.033 6.11.335a2.01 2.01 0 0 1 1.415 1.42c.101.38.172.883.22 1.402l.01.104.022.26.008.104c.065.914.073 1.77.074 1.957v.075c-.001.194-.01 1.108-.082 2.06l-.008.105-.009.104c-.05.572-.124 1.14-.235 1.558a2.007 2.007 0 0 1-1.415 1.42c-1.16.312-5.569.334-6.18.335h-.142c-.309 0-1.587-.006-2.927-.052l-.17-.006-.087-.004-.171-.007-.171-.007c-1.11-.049-2.167-.128-2.654-.26a2.007 2.007 0 0 1-1.415-1.419c-.111-.417-.185-.986-.235-1.558L.09 9.82l-.008-.104A31.4 31.4 0 0 1 0 7.68v-.123c.002-.215.01-.958.064-1.778l.007-.103.003-.052.008-.104.022-.26.01-.104c.048-.519.119-1.023.22-1.402a2.007 2.007 0 0 1 1.415-1.42c.487-.13 1.544-.21 2.654-.26l.17-.007.172-.006.086-.003.171-.007A99.788 99.788 0 0 1 7.858 2h.193zM6.4 5.209v4.818l4.157-2.408L6.4 5.209z"/></svg>
                                YouTube
                            </label>
                            <input type="url" class="form-control" placeholder="https://youtube.com/@@empresa" @bind="empresa.YouTube" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="me-1"><path d="M9 0h1.98c.144.715.54 1.617 1.235 2.512C12.895 3.389 13.797 4 15 4v2c-1.753 0-3.07-.814-4-1.829V11a5 5 0 1 1-5-5v2a3 3 0 1 0 3 3V0z"/></svg>
                                TikTok
                            </label>
                            <input type="url" class="form-control" placeholder="https://tiktok.com/@@empresa" @bind="empresa.TikTok" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">Notas</div>
                <div class="card-body">
                    <textarea class="form-control" rows="3" @bind="empresa.Notas"></textarea>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-primary" @onclick="Guardar">Guardar cambios</button>
                <a href="/empresas" class="btn btn-outline-secondary">Volver</a>
            </div>
            @if (mensaje != null)
            {
                <div class="alert alert-success mt-3">@mensaje</div>
            }
        </div>

        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header">Licencias asociadas</div>
                <div class="card-body p-0">
                    @if (licencias == null || licencias.Count == 0)
                    {
                        <p class="p-3 text-muted">Sin licencias</p>
                    }
                    else
                    {
                        <table class="table table-sm table-striped mb-0">
                            <thead>
                                <tr>
                                    <th>Plan</th>
                                    <th>Legajos</th>
                                    <th>Estado</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var lic in licencias)
                                {
                                    <tr>
                                        <td>@lic.Plan</td>
                                        <td>@lic.MaxLegajos</td>
                                        <td><span class="badge @GetBadge(lic)">@lic.EstadoDisplay</span></td>
                                        <td><a href="/licencias/@lic.Id" class="btn btn-sm btn-outline-primary">Ver</a></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">Codigo de Activacion</div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(empresa.CodigoActivacion))
                    {
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <code class="fs-5 flex-grow-1">@empresa.CodigoActivacion</code>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="CopiarCodigo" title="Copiar">
                                <span class="bi bi-clipboard"></span> Copiar
                            </button>
                        </div>
                        @if (codigoCopiado)
                        {
                            <small class="text-success">Copiado al portapapeles</small>
                        }
                        <hr />
                        <button class="btn btn-sm btn-outline-warning" @onclick="RegenerarCodigo">
                            Regenerar codigo
                        </button>
                        <small class="text-muted d-block mt-1">El codigo anterior dejara de funcionar.</small>
                    }
                    else
                    {
                        <p class="text-muted mb-2">Sin codigo asignado</p>
                        <button class="btn btn-sm btn-primary" @onclick="RegenerarCodigo">
                            Generar codigo
                        </button>
                    }
                </div>
            </div>

            <div class="card">
                <div class="card-header">Info</div>
                <div class="card-body">
                    <dl class="row mb-0 small">
                        <dt class="col-sm-5">Creada</dt>
                        <dd class="col-sm-7">@empresa.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
                        <dt class="col-sm-5">Actualizada</dt>
                        <dd class="col-sm-7">@empresa.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
                    </dl>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header"><i class="bi bi-bar-chart me-1"></i> Uso del sistema</div>
                <div class="card-body p-2">
                    @if (statsError)
                    {
                        <p class="text-muted small text-center py-2"><i class="bi bi-inbox me-1"></i>Sin datos registrados</p>
                    }
                    else if (stats == null)
                    {
                        <p class="text-muted small text-center py-2"><span class="spinner-border spinner-border-sm me-1"></span>Cargando...</p>
                    }
                    else
                    {
                        <div class="row g-1 text-center mb-2">
                            <div class="col-4">
                                <div class="border rounded p-1">
                                    <div class="fs-5 fw-bold text-primary">@stats.LegajosActivos</div>
                                    <small class="text-muted" style="font-size:.7rem">Legajos</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="border rounded p-1">
                                    <div class="fs-5 fw-bold text-success">@stats.TotalFichadas.ToString("N0")</div>
                                    <small class="text-muted" style="font-size:.7rem">Fichadas</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="border rounded p-1">
                                    <div class="fs-5 fw-bold text-info">@stats.TotalUsuarios</div>
                                    <small class="text-muted" style="font-size:.7rem">Usuarios</small>
                                </div>
                            </div>
                        </div>

                        <div class="row g-1 text-center mb-2">
                            <div class="col-4">
                                <div class="border rounded p-1">
                                    <div class="fs-6 fw-bold">@stats.TotalSucursales</div>
                                    <small class="text-muted" style="font-size:.7rem">Sucursales</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="border rounded p-1">
                                    <div class="fs-6 fw-bold">@stats.TotalTerminales</div>
                                    <small class="text-muted" style="font-size:.7rem">Terminales</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="border rounded p-1">
                                    <div class="fs-6 fw-bold">@stats.TotalMoviles</div>
                                    <small class="text-muted" style="font-size:.7rem">Moviles</small>
                                </div>
                            </div>
                        </div>

                        <hr class="my-2" />

                        @if (stats.UltimaFichada.HasValue)
                        {
                            <dl class="row mb-0 small">
                                <dt class="col-6">Ultima fichada</dt>
                                <dd class="col-6 text-end">@stats.UltimaFichada.Value.ToString("dd/MM/yyyy HH:mm")</dd>

                                <dt class="col-6">Fichadas ese dia</dt>
                                <dd class="col-6 text-end"><span class="badge bg-primary">@stats.FichadasUltimoDia</span></dd>

                                <dt class="col-6">Legajos ficharon</dt>
                                <dd class="col-6 text-end"><span class="badge bg-success">@stats.LegajosUltimoDia</span></dd>
                            </dl>

                            <div class="small mt-1">
                                <div class="text-muted mb-1" style="font-size:.75rem">Origen fichadas (ultimo dia):</div>
                                <div class="d-flex flex-wrap gap-1">
                                    @if (stats.FichadasHuella > 0)
                                    {
                                        <span class="badge bg-primary"><i class="bi bi-fingerprint"></i> @stats.FichadasHuella</span>
                                    }
                                    @if (stats.FichadasPIN > 0)
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-dialpad"></i> @stats.FichadasPIN</span>
                                    }
                                    @if (stats.FichadasMovil > 0)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-phone"></i> @stats.FichadasMovil</span>
                                    }
                                    @if (stats.FichadasManual > 0)
                                    {
                                        <span class="badge bg-info"><i class="bi bi-pencil-square"></i> @stats.FichadasManual</span>
                                    }
                                    @if (stats.FichadasWeb > 0)
                                    {
                                        <span class="badge bg-dark"><i class="bi bi-globe"></i> @stats.FichadasWeb</span>
                                    }
                                    @if (stats.FichadasDemo > 0)
                                    {
                                        <span class="badge bg-secondary"><i class="bi bi-play-circle"></i> @stats.FichadasDemo</span>
                                    }
                                </div>
                            </div>

                            <hr class="my-2" />
                            <dl class="row mb-0 small">
                                <dt class="col-8">Dias con actividad <span class="text-muted fw-normal">(ult. 30d)</span></dt>
                                <dd class="col-4 text-end">
                                    <span class="badge @(stats.DiasActivos30 >= 20 ? "bg-success" : stats.DiasActivos30 >= 10 ? "bg-warning text-dark" : stats.DiasActivos30 > 0 ? "bg-danger" : "bg-secondary")">
                                        @stats.DiasActivos30 / 30
                                    </span>
                                </dd>
                            </dl>
                            <hr class="my-2" />
                            <div class="small">
                                <div class="text-muted mb-2" style="font-size:.75rem">Fichadas por dispositivo (ult. 15 dias):</div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="text-center flex-fill">
                                        <div class="border rounded p-1 mx-1">
                                            <i class="bi bi-fingerprint text-primary fs-5"></i>
                                            <div class="fw-bold">@stats.Fichadas15dHuella</div>
                                            <div class="text-muted" style="font-size:.65rem">Huella</div>
                                        </div>
                                    </div>
                                    <div class="text-center flex-fill">
                                        <div class="border rounded p-1 mx-1">
                                            <i class="bi bi-dialpad text-warning fs-5"></i>
                                            <div class="fw-bold">@stats.Fichadas15dPIN</div>
                                            <div class="text-muted" style="font-size:.65rem">PIN</div>
                                        </div>
                                    </div>
                                    <div class="text-center flex-fill">
                                        <div class="border rounded p-1 mx-1">
                                            <i class="bi bi-phone text-success fs-5"></i>
                                            <div class="fw-bold">@stats.Fichadas15dMovil</div>
                                            <div class="text-muted" style="font-size:.65rem">Celular</div>
                                        </div>
                                    </div>
                                    <div class="text-center flex-fill">
                                        <div class="border rounded p-1 mx-1">
                                            <i class="bi bi-pencil-square text-info fs-5"></i>
                                            <div class="fw-bold">@stats.Fichadas15dManual</div>
                                            <div class="text-muted" style="font-size:.65rem">Manual</div>
                                        </div>
                                    </div>
                                </div>
                                @if (stats.Fichadas15dTotal > 0)
                                {
                                    <div class="text-muted text-center mt-1" style="font-size:.7rem">
                                        Total: @stats.Fichadas15dTotal fichadas en 15 dias
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small text-center mb-0"><i class="bi bi-inbox me-1"></i>Sin fichadas registradas</p>
                        }
                    }
                </div>
            </div>

            <div class="card mt-3 border-warning">
                <div class="card-header bg-warning bg-opacity-10 text-warning-emphasis">
                    <i class="bi bi-exclamation-triangle me-1"></i> Zona peligrosa
                </div>
                <div class="card-body d-grid gap-2">
                    <button class="btn btn-outline-warning btn-sm" @onclick="MostrarConfirmLimpiar">
                        <i class="bi bi-eraser me-1"></i>Limpiar Empresa
                    </button>
                    <button class="btn btn-outline-danger btn-sm" @onclick="MostrarConfirmEliminar">
                        <i class="bi bi-trash me-1"></i>Eliminar Empresa
                    </button>
                </div>
            </div>
        </div>
    </div>

    @* Seccion Legajos *@
    <div class="card mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-people me-1"></i> Legajos de la empresa</span>
            @if (legajosList != null)
            {
                <span class="badge bg-secondary">@legajosList.Count legajos</span>
            }
        </div>
        <div class="card-body p-0">
            @if (legajosError)
            {
                <p class="text-muted small text-center py-3"><i class="bi bi-exclamation-circle me-1"></i>No se pudieron cargar los legajos</p>
            }
            else if (legajosList == null)
            {
                <p class="text-muted small text-center py-3"><span class="spinner-border spinner-border-sm me-1"></span>Cargando legajos...</p>
            }
            else if (legajosList.Count == 0)
            {
                <p class="text-muted small text-center py-3"><i class="bi bi-inbox me-1"></i>Sin legajos registrados</p>
            }
            else
            {
                <div class="mb-2 px-3 pt-2">
                    <input type="text" class="form-control form-control-sm" placeholder="Buscar por nombre, apellido o legajo..."
                           @bind="legajoFiltro" @bind:event="oninput" />
                </div>
                <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                    <table class="table table-sm table-striped table-hover mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th style="width:70px">Nro</th>
                                <th>Apellido</th>
                                <th>Nombre</th>
                                <th>Categoria</th>
                                <th>Sucursales</th>
                                <th class="text-end" style="width:80px">Fichadas</th>
                                <th style="width:120px">Ultima</th>
                                <th style="width:70px">Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var leg in LegajosFiltrados)
                            {
                                <tr class="@(!leg.IsActive ? "table-secondary" : "")">
                                    <td>@leg.NumeroLegajo</td>
                                    <td>@leg.Apellido</td>
                                    <td>@leg.Nombre</td>
                                    <td><small class="text-muted">@(leg.Categoria ?? "-")</small></td>
                                    <td><small class="text-muted">@(leg.Sucursales ?? "-")</small></td>
                                    <td class="text-end">
                                        @if (leg.TotalFichadas > 0)
                                        {
                                            <span class="badge bg-primary">@leg.TotalFichadas.ToString("N0")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">0</span>
                                        }
                                    </td>
                                    <td>
                                        @if (leg.UltimaFichada.HasValue)
                                        {
                                            <small>@leg.UltimaFichada.Value.ToString("dd/MM/yy HH:mm")</small>
                                        }
                                        else
                                        {
                                            <small class="text-muted">-</small>
                                        }
                                    </td>
                                    <td>
                                        @if (leg.IsActive)
                                        {
                                            <span class="badge bg-success">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactivo</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@* Modal Limpiar Empresa *@
@if (showLimpiarModal)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.6);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-warning">
                <div class="modal-header bg-warning bg-opacity-10">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle text-warning me-2"></i>Limpiar Empresa</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModales"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-warning mb-3">
                        <strong>Esta accion eliminara todos los datos transaccionales de "@empresa?.Nombre":</strong>
                        <ul class="mb-0 mt-2">
                            <li>Fichadas</li>
                            <li>Vacaciones</li>
                            <li>Incidencias asignadas a legajos</li>
                            <li>Eventos de calendario</li>
                            <li>Terminales moviles registradas</li>
                            <li>Codigos de activacion movil</li>
                        </ul>
                    </div>
                    <p class="mb-2"><strong>Se mantienen:</strong> usuarios, sucursales, sectores, categorias, horarios, terminales, legajos, huellas, PINs, incidencias, feriados, noticias y codigo de activacion.</p>
                    <p class="text-danger fw-bold">Esta accion no se puede deshacer.</p>

                    @if (!limpiarConfirmado)
                    {
                        <button class="btn btn-warning w-100" @onclick="() => limpiarConfirmado = true">
                            Entiendo, quiero continuar
                        </button>
                    }
                    else
                    {
                        <div class="alert alert-danger">
                            <label class="form-label fw-bold">Escriba el nombre de la empresa para confirmar:</label>
                            <input type="text" class="form-control" @bind="confirmNombre" @bind:event="oninput" placeholder="@empresa?.Nombre" />
                        </div>
                    }
                </div>
                @if (limpiarConfirmado)
                {
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="CerrarModales">Cancelar</button>
                        <button class="btn btn-warning" disabled="@(confirmNombre != empresa?.Nombre || procesando)"
                                @onclick="EjecutarLimpiar">
                            @if (procesando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Limpiar Empresa
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
}

@* Modal Eliminar Empresa *@
@if (showEliminarModal)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.6);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-danger">
                <div class="modal-header bg-danger bg-opacity-10">
                    <h5 class="modal-title"><i class="bi bi-trash text-danger me-2"></i>Eliminar Empresa</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModales"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger mb-3">
                        <strong>Esta accion eliminara ABSOLUTAMENTE TODO de "@empresa?.Nombre":</strong>
                        <ul class="mb-0 mt-2">
                            <li>Todos los datos transaccionales (fichadas, vacaciones, etc.)</li>
                            <li>Todos los legajos, huellas, PINs</li>
                            <li>Todas las sucursales, sectores, categorias, horarios</li>
                            <li>Todas las terminales (desktop y moviles)</li>
                            <li>Todos los usuarios del portal</li>
                            <li>Todas las licencias asociadas</li>
                            <li>La empresa misma</li>
                        </ul>
                    </div>
                    <p class="text-danger fw-bold">Esta accion es IRREVERSIBLE. No quedara nada.</p>

                    @if (!eliminarConfirmado)
                    {
                        <button class="btn btn-danger w-100" @onclick="() => eliminarConfirmado = true">
                            Entiendo, quiero continuar
                        </button>
                    }
                    else
                    {
                        <div class="alert alert-danger border-danger">
                            <label class="form-label fw-bold">Escriba el nombre de la empresa para confirmar:</label>
                            <input type="text" class="form-control" @bind="confirmNombre" @bind:event="oninput" placeholder="@empresa?.Nombre" />
                        </div>
                    }
                </div>
                @if (eliminarConfirmado)
                {
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="CerrarModales">Cancelar</button>
                        <button class="btn btn-danger" disabled="@(confirmNombre != empresa?.Nombre || procesando)"
                                @onclick="EjecutarEliminar">
                            @if (procesando) { <span class="spinner-border spinner-border-sm me-1"></span> @procesandoMensaje }
                            else { <text>Eliminar Empresa Permanentemente</text> }
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private DigitalPlus.Licencias.Entidades.Empresa? empresa;
    private List<DigitalPlus.Licencias.Entidades.Licencia>? licencias;
    private List<DigitalPlus.Licencias.Entidades.Pais>? paises;
    private List<DigitalPlus.Licencias.Entidades.TipoIdentificacionFiscal>? tiposId;
    private string? mensaje;
    private bool codigoCopiado;
    private DigitalPlus.Licencias.Services.EmpresaStats? stats;
    private bool statsError;

    // Legajos
    private List<DigitalPlus.Licencias.Services.LegajoListDto>? legajosList;
    private bool legajosError;
    private string legajoFiltro = "";

    private IEnumerable<DigitalPlus.Licencias.Services.LegajoListDto> LegajosFiltrados =>
        string.IsNullOrWhiteSpace(legajoFiltro)
            ? legajosList ?? []
            : (legajosList ?? []).Where(l =>
                l.Apellido.Contains(legajoFiltro, StringComparison.OrdinalIgnoreCase) ||
                l.Nombre.Contains(legajoFiltro, StringComparison.OrdinalIgnoreCase) ||
                l.NumeroLegajo.ToString().Contains(legajoFiltro));

    // Limpiar / Eliminar
    private bool showLimpiarModal;
    private bool showEliminarModal;
    private bool limpiarConfirmado;
    private bool eliminarConfirmado;
    private string confirmNombre = "";
    private bool procesando;
    private string? procesandoMensaje;

    private string selectedPaisId => empresa?.PaisId?.ToString() ?? "";
    private string selectedTipoIdFiscalId => empresa?.TipoIdentificacionFiscalId?.ToString() ?? "";

    protected override async Task OnInitializedAsync()
    {
        empresa = await Repo.GetEmpresaAsync(Id);
        if (empresa == null) { Nav.NavigateTo("/empresas"); return; }

        paises = await Repo.GetPaisesAsync();
        if (empresa.PaisId.HasValue)
            tiposId = await Repo.GetTiposIdentificacionAsync(empresa.PaisId.Value);
        else
            tiposId = [];

        var todas = await Repo.GetLicenciasAsync(empresa.CompanyId);
        licencias = todas.Where(l => l.CompanyId == empresa.CompanyId).ToList();

        _ = Task.Run(async () =>
        {
            try
            {
                stats = await MTService.GetEmpresaStatsAsync(empresa.CompanyId);
                if (stats == null) statsError = true;
                await InvokeAsync(StateHasChanged);
            }
            catch
            {
                statsError = true;
                await InvokeAsync(StateHasChanged);
            }
        });

        _ = Task.Run(async () =>
        {
            try
            {
                legajosList = await MTService.GetLegajosAsync(empresa.CompanyId);
                await InvokeAsync(StateHasChanged);
            }
            catch
            {
                legajosError = true;
                await InvokeAsync(StateHasChanged);
            }
        });
    }

    private async Task OnPaisChangedEvent(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
        {
            empresa!.PaisId = id;
            tiposId = await Repo.GetTiposIdentificacionAsync(id);
        }
        else
        {
            empresa!.PaisId = null;
            tiposId = [];
        }
        empresa.TipoIdentificacionFiscalId = null;
    }

    private void OnTipoIdChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
            empresa!.TipoIdentificacionFiscalId = id;
        else
            empresa!.TipoIdentificacionFiscalId = null;
    }

    private async Task OnLogoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        var allowedTypes = new[] { "image/png", "image/jpeg", "image/svg+xml", "image/webp" };
        if (!allowedTypes.Contains(file.ContentType))
        {
            mensaje = null;
            return;
        }
        if (file.Size > 512_000)
        {
            mensaje = null;
            return;
        }
        using var ms = new System.IO.MemoryStream();
        await file.OpenReadStream(512_000).CopyToAsync(ms);
        empresa!.Logo = ms.ToArray();
        empresa.LogoContentType = file.ContentType;
    }

    private void QuitarLogo()
    {
        empresa!.Logo = null;
        empresa.LogoContentType = null;
    }

    private async Task Guardar()
    {
        await Repo.ActualizarEmpresaAsync(empresa!);
        mensaje = "Cambios guardados correctamente";
    }

    private async Task CopiarCodigo()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", empresa!.CodigoActivacion);
        codigoCopiado = true;
        _ = Task.Delay(2000).ContinueWith(_ => { codigoCopiado = false; InvokeAsync(StateHasChanged); });
    }

    private async Task RegenerarCodigo()
    {
        await Repo.RegenerarCodigoActivacionAsync(empresa!.Id);
        empresa = await Repo.GetEmpresaAsync(Id);
        mensaje = "Codigo de activacion regenerado";
    }

    private string GetBadge(DigitalPlus.Licencias.Entidades.Licencia lic) => lic.EstadoDisplay switch
    {
        "Activa" => "bg-success",
        "Trial" => "bg-info",
        "Suspendida" => "bg-warning text-dark",
        _ => "bg-danger"
    };

    private void MostrarConfirmLimpiar()
    {
        showLimpiarModal = true;
        showEliminarModal = false;
        limpiarConfirmado = false;
        confirmNombre = "";
        mensaje = null;
    }

    private void MostrarConfirmEliminar()
    {
        showEliminarModal = true;
        showLimpiarModal = false;
        eliminarConfirmado = false;
        confirmNombre = "";
        mensaje = null;
    }

    private void CerrarModales()
    {
        showLimpiarModal = false;
        showEliminarModal = false;
        limpiarConfirmado = false;
        eliminarConfirmado = false;
        confirmNombre = "";
    }

    private async Task EjecutarLimpiar()
    {
        if (empresa == null || confirmNombre != empresa.Nombre) return;
        procesando = true;
        StateHasChanged();

        try
        {
            var mtEmpresaId = await MTService.BuscarEmpresaIdPorCodigoAsync(empresa.CompanyId);
            if (mtEmpresaId == null)
            {
                mensaje = "No se encontro la empresa en la base de datos multi-tenant.";
                CerrarModales();
                return;
            }

            var registros = await MTService.LimpiarEmpresaAsync(mtEmpresaId.Value);
            stats = await MTService.GetEmpresaStatsAsync(empresa.CompanyId);
            CerrarModales();
            mensaje = $"Empresa limpiada correctamente. Se eliminaron {registros} registros transaccionales.";
        }
        catch (Exception ex)
        {
            CerrarModales();
            mensaje = $"Error al limpiar: {ex.Message}";
        }
        finally
        {
            procesando = false;
        }
    }

    private async Task EjecutarEliminar()
    {
        if (empresa == null || confirmNombre != empresa.Nombre) return;
        procesando = true;
        procesandoMensaje = "Buscando empresa...";
        StateHasChanged();
        await Task.Delay(100);

        try
        {
            var mtEmpresaId = await MTService.BuscarEmpresaIdPorCodigoAsync(empresa.CompanyId);

            if (mtEmpresaId != null)
            {
                procesandoMensaje = "Eliminando datos multi-tenant...";
                StateHasChanged();
                await Task.Delay(100);

                var adminConnStr = Config.GetConnectionString("DefaultConnection")!;
                await MTService.EliminarEmpresaAsync(mtEmpresaId.Value, empresa.Id, empresa.CompanyId, adminConnStr);
            }
            else
            {
                // Empresa huerfana: existe en Admin pero no en MT. Borrar solo de Admin.
                procesandoMensaje = "Eliminando de administracion...";
                StateHasChanged();
                await Task.Delay(100);

                var adminConnStr = Config.GetConnectionString("DefaultConnection")!;
                await MTService.EliminarEmpresaSoloAdminAsync(empresa.Id, empresa.CompanyId, adminConnStr);
            }

            procesandoMensaje = "Empresa eliminada. Redirigiendo...";
            StateHasChanged();
            await Task.Delay(500);

            Nav.NavigateTo("/empresas", forceLoad: true);
        }
        catch (Exception ex)
        {
            CerrarModales();
            mensaje = $"Error al eliminar: {ex.Message}";
            if (ex.InnerException != null)
                mensaje += $" | Detalle: {ex.InnerException.Message}";
            procesando = false;
            procesandoMensaje = null;
        }
    }
}
