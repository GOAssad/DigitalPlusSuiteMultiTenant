@page "/solicitudes-upgrade"
@using DigitalPlus.Licencias.Repositorios
@rendermode InteractiveServer

@inject RepositorioLicencias Repo

<PageTitle>Solicitudes de Upgrade - DigitalPlus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="bi bi-arrow-up-circle me-2"></i>Solicitudes de Upgrade</h4>
    <button class="btn btn-outline-secondary btn-sm" @onclick="Cargar">
        <i class="bi bi-arrow-clockwise me-1"></i>Actualizar
    </button>
</div>

@if (cargando)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (solicitudes.Count == 0)
{
    <div class="alert alert-info">No hay solicitudes de upgrade registradas.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Empresa</th>
                    <th>Plan actual</th>
                    <th>Plan solicitado</th>
                    <th>Importe</th>
                    <th>Estado</th>
                    <th>Solicitado por</th>
                    <th>Fecha</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in solicitudes)
                {
                    string estado = s.Estado;
                    var badgeClass = estado switch
                    {
                        "Aprobada" => "bg-success",
                        "PendientePago" => "bg-warning text-dark",
                        "Pendiente" => "bg-info",
                        "Rechazada" => "bg-danger",
                        "Cancelada" => "bg-secondary",
                        _ => "bg-secondary"
                    };

                    <tr>
                        <td>@s.Id</td>
                        <td>
                            <strong>@(s.EmpresaNombre ?? "-")</strong>
                            <br /><small class="text-muted">@s.CompanyId</small>
                        </td>
                        <td><span class="badge bg-secondary">@s.PlanActual</span></td>
                        <td><span class="badge bg-primary">@s.PlanSolicitado</span></td>
                        <td>
                            @{
                                decimal? imp = s.ImporteMensual;
                                @(imp.HasValue && imp.Value > 0 ? $"${imp.Value:N0}/mes" : "Gratis")
                            }
                        </td>
                        <td><span class="badge @badgeClass">@estado</span></td>
                        <td><small>@s.SolicitadoPor</small></td>
                        <td>
                            @{
                                DateTime? fecha = s.FechaSolicitud;
                                @(fecha?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")
                            }
                        </td>
                        <td>
                            @if (estado == "PendientePago")
                            {
                                <a href="/upgrade/@s.Token" target="_blank" class="btn btn-outline-primary btn-sm" title="Ver pagina de pago">
                                    <i class="bi bi-box-arrow-up-right"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="text-muted small">
        Total: @solicitudes.Count solicitudes
    </div>
}

@code {
    private List<dynamic> solicitudes = new();
    private bool cargando = true;

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        cargando = true;
        try
        {
            solicitudes = await Repo.GetSolicitudesUpgradeAsync();
        }
        catch { }
        finally
        {
            cargando = false;
        }
    }
}
