@page "/licencias/{Id:int}"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject DigitalPlus.Licencias.Repositorios.RepositorioLicencias Repo
@inject NavigationManager Nav
@inject DigitalPlus.Licencias.Services.MultiTenantProvisioningService MTService
@inject DigitalPlus.Licencias.Services.IEmailService EmailService

<PageTitle>Detalle Licencia - DigitalPlus</PageTitle>

@if (lic == null)
{
    <p>Cargando...</p>
}
else
{
    <h3 class="mb-4">@lic.CompanyId</h3>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header">Informacion</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Maquina</dt>
                        <dd class="col-sm-8"><code>@lic.MachineId</code></dd>
                        <dt class="col-sm-4">Estado</dt>
                        <dd class="col-sm-8"><span class="badge @GetBadgeClass()">@lic.EstadoDisplay</span></dd>
                        <dt class="col-sm-4">Creada</dt>
                        <dd class="col-sm-8">@lic.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
                        <dt class="col-sm-4">Ultimo heartbeat</dt>
                        <dd class="col-sm-8">@(lic.LastHeartbeat?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>
                    </dl>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">Editar Licencia</div>
                <div class="card-body">
                    <div class="mb-2">
                        <label class="form-label">Plan</label>
                        <select class="form-select" @bind="editPlan">
                            <option value="free">Free</option>
                            <option value="basic">Basic</option>
                            <option value="pro">Pro</option>
                            <option value="enterprise">Enterprise</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Max Legajos</label>
                        <input type="number" class="form-control" @bind="editMaxLegajos" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Vencimiento</label>
                        <input type="date" class="form-control" @bind="editExpires" />
                    </div>
                    <button class="btn btn-primary" @onclick="Guardar">Guardar</button>
                    @if (mensaje != null)
                    {
                        <div class="alert alert-success mt-2 mb-0">@mensaje</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header">Acciones rapidas</div>
                <div class="card-body d-flex gap-2 flex-wrap">
                    <button class="btn btn-outline-success" @onclick="() => Extender(30)">+30 dias</button>
                    <button class="btn btn-outline-success" @onclick="() => Extender(90)">+90 dias</button>
                    <button class="btn btn-outline-success" @onclick="() => Extender(365)">+365 dias</button>
                    @if (lic.LicenseType != "suspended")
                    {
                        <button class="btn btn-outline-warning" @onclick="() => Suspender(true)">Suspender</button>
                    }
                    else
                    {
                        <button class="btn btn-outline-info" @onclick="() => Suspender(false)">Reactivar</button>
                    }
                </div>
            </div>

            <div class="card">
                <div class="card-header">Actividad</div>
                <div class="card-body p-0">
                    @if (logs == null || logs.Count == 0)
                    {
                        <p class="p-3 text-muted">Sin actividad</p>
                    }
                    else
                    {
                        <table class="table table-sm table-striped mb-0">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Accion</th>
                                    <th>Detalle</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in logs)
                                {
                                    <tr>
                                        <td>@log.Timestamp.ToString("dd/MM HH:mm")</td>
                                        <td>@log.Action</td>
                                        <td><small>@log.Details</small></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private DigitalPlus.Licencias.Entidades.Licencia? lic;
    private List<DigitalPlus.Licencias.Entidades.LicenciaLog>? logs;
    private string editPlan = "free";
    private int editMaxLegajos;
    private DateTime? editExpires;
    private string? mensaje;

    protected override async Task OnInitializedAsync()
    {
        await Cargar();
    }

    private async Task Cargar()
    {
        lic = await Repo.GetLicenciaAsync(Id);
        if (lic == null) { Nav.NavigateTo("/licencias"); return; }
        editPlan = lic.Plan;
        editMaxLegajos = lic.MaxLegajos;
        editExpires = lic.ExpiresAt;
        logs = await Repo.GetLogsAsync(Id, 20);
        mensaje = null;
    }

    private async Task Guardar()
    {
        var planAnterior = lic?.Plan ?? "free";
        await Repo.ActualizarLicenciaAsync(Id, editPlan, editMaxLegajos, editExpires);

        // Notificar si cambió el plan
        if (planAnterior != editPlan && lic != null)
        {
            try
            {
                var mtEmpresaId = await MTService.BuscarEmpresaIdPorCodigoAsync(lic.CompanyId);
                if (mtEmpresaId.HasValue)
                    await MTService.NotificarCambioPlanAsync(mtEmpresaId.Value, planAnterior, editPlan, "Cambio realizado por IntegraIA.");
            }
            catch { /* best-effort */ }
        }

        await Cargar();
        mensaje = "Guardado correctamente";
    }

    private async Task Extender(int dias)
    {
        await Repo.ExtenderLicenciaAsync(Id, dias);
        await Cargar();
        mensaje = $"Extendida {dias} dias";
    }

    private async Task Suspender(bool suspender)
    {
        await Repo.SuspenderLicenciaAsync(Id, suspender);
        await Cargar();
        mensaje = suspender ? "Licencia suspendida" : "Licencia reactivada";
    }

    private string GetBadgeClass() => lic!.EstadoDisplay switch
    {
        "Activa" => "bg-success",
        "Trial" => "bg-info",
        "Suspendida" => "bg-warning text-dark",
        "Vencida" or "Trial Vencido" => "bg-danger",
        _ => "bg-secondary"
    };
}
