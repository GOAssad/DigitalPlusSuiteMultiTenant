@page "/usuarios"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Microsoft.AspNetCore.Identity
@using DigitalPlus.Licencias.Data
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager

<PageTitle>Usuarios - DigitalPlus</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Usuarios</h3>
    <button class="btn btn-primary" @onclick="MostrarFormNuevo">Nuevo Usuario</button>
</div>

@if (!string.IsNullOrEmpty(mensaje))
{
    <div class="alert @(esError ? "alert-danger" : "alert-success") alert-dismissible fade show">
        @mensaje
        <button type="button" class="btn-close" @onclick="() => mensaje = null"></button>
    </div>
}

@if (mostrarForm)
{
    <div class="card mb-4">
        <div class="card-header">@(editandoId == null ? "Nuevo Usuario" : "Editar Usuario")</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" @bind="formEmail" disabled="@(editandoId != null)" />
                </div>
                @if (editandoId == null)
                {
                    <div class="col-md-4">
                        <label class="form-label">Contraseña</label>
                        <input type="password" class="form-control" @bind="formPassword" />
                    </div>
                }
                else
                {
                    <div class="col-md-4">
                        <label class="form-label">Nueva contraseña (dejar vacio para no cambiar)</label>
                        <input type="password" class="form-control" @bind="formPassword" placeholder="Sin cambios" />
                    </div>
                }
                <div class="col-md-4 d-flex align-items-end gap-2">
                    <button class="btn btn-success" @onclick="Guardar" disabled="@guardando">
                        @(guardando ? "Guardando..." : "Guardar")
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="CancelarForm">Cancelar</button>
                </div>
            </div>
        </div>
    </div>
}

@if (usuarios == null)
{
    <p>Cargando...</p>
}
else if (usuarios.Count == 0)
{
    <div class="alert alert-info">No hay usuarios registrados.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Email</th>
                <th>Rol</th>
                <th>Creado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in usuarios)
            {
                <tr>
                    <td>@u.Email</td>
                    <td>
                        <span class="badge bg-primary">@u.Rol</span>
                    </td>
                    <td>-</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Editar(u)">Editar</button>
                        @if (u.Email != "admin@digitalplus.com")
                        {
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => Eliminar(u)">Eliminar</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<UsuarioVM>? usuarios;
    private bool mostrarForm;
    private string? editandoId;
    private string formEmail = "";
    private string formPassword = "";
    private string? mensaje;
    private bool esError;
    private bool guardando;

    protected override async Task OnInitializedAsync()
    {
        await CargarUsuarios();
    }

    private async Task CargarUsuarios()
    {
        var allUsers = UserManager.Users.OrderBy(u => u.Email).ToList();
        usuarios = new List<UsuarioVM>();
        foreach (var u in allUsers)
        {
            var roles = await UserManager.GetRolesAsync(u);
            usuarios.Add(new UsuarioVM
            {
                Id = u.Id,
                Email = u.Email ?? "",
                Rol = roles.FirstOrDefault() ?? "Sin rol"
            });
        }
    }

    private void MostrarFormNuevo()
    {
        editandoId = null;
        formEmail = "";
        formPassword = "";
        mostrarForm = true;
        mensaje = null;
    }

    private void Editar(UsuarioVM u)
    {
        editandoId = u.Id;
        formEmail = u.Email;
        formPassword = "";
        mostrarForm = true;
        mensaje = null;
    }

    private void CancelarForm()
    {
        mostrarForm = false;
        editandoId = null;
    }

    private async Task Guardar()
    {
        guardando = true;
        try
        {
            if (editandoId == null)
            {
                // Crear nuevo
                if (string.IsNullOrWhiteSpace(formEmail) || string.IsNullOrWhiteSpace(formPassword))
                {
                    mensaje = "Email y contraseña son requeridos.";
                    esError = true;
                    return;
                }

                var existing = await UserManager.FindByEmailAsync(formEmail);
                if (existing != null)
                {
                    mensaje = "Ya existe un usuario con ese email.";
                    esError = true;
                    return;
                }

                var user = new ApplicationUser
                {
                    UserName = formEmail,
                    Email = formEmail,
                    EmailConfirmed = true
                };
                var result = await UserManager.CreateAsync(user, formPassword);
                if (!result.Succeeded)
                {
                    mensaje = string.Join(". ", result.Errors.Select(e => e.Description));
                    esError = true;
                    return;
                }

                await UserManager.AddToRoleAsync(user, "Administrador");
                mensaje = $"Usuario {formEmail} creado exitosamente.";
                esError = false;
            }
            else
            {
                // Editar existente (solo cambiar password si se proporciona)
                if (!string.IsNullOrWhiteSpace(formPassword))
                {
                    var user = await UserManager.FindByIdAsync(editandoId);
                    if (user == null)
                    {
                        mensaje = "Usuario no encontrado.";
                        esError = true;
                        return;
                    }

                    var token = await UserManager.GeneratePasswordResetTokenAsync(user);
                    var result = await UserManager.ResetPasswordAsync(user, token, formPassword);
                    if (!result.Succeeded)
                    {
                        mensaje = string.Join(". ", result.Errors.Select(e => e.Description));
                        esError = true;
                        return;
                    }
                    mensaje = $"Contraseña de {formEmail} actualizada.";
                    esError = false;
                }
                else
                {
                    mensaje = "No se realizaron cambios.";
                    esError = false;
                }
            }

            mostrarForm = false;
            editandoId = null;
            await CargarUsuarios();
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task Eliminar(UsuarioVM u)
    {
        var user = await UserManager.FindByIdAsync(u.Id);
        if (user == null) return;

        if (user.Email == "admin@digitalplus.com")
        {
            mensaje = "No se puede eliminar el usuario administrador principal.";
            esError = true;
            return;
        }

        var result = await UserManager.DeleteAsync(user);
        if (result.Succeeded)
        {
            mensaje = $"Usuario {u.Email} eliminado.";
            esError = false;
            await CargarUsuarios();
        }
        else
        {
            mensaje = string.Join(". ", result.Errors.Select(e => e.Description));
            esError = true;
        }
    }

    private class UsuarioVM
    {
        public string Id { get; set; } = "";
        public string Email { get; set; } = "";
        public string Rol { get; set; } = "";
    }
}
