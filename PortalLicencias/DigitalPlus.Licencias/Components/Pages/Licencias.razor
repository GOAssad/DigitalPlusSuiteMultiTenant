@page "/licencias"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject DigitalPlus.Licencias.Repositorios.RepositorioLicencias Repo

<PageTitle>Licencias - DigitalPlus</PageTitle>

<h3 class="mb-4">Licencias</h3>

<div class="row mb-3">
    <div class="col-md-4">
        <input type="text" class="form-control" placeholder="Buscar por empresa o plan..."
               @bind="filtro" @bind:event="oninput" @onkeyup="Buscar" />
    </div>
</div>

@if (licencias == null)
{
    <p>Cargando...</p>
}
else if (licencias.Count == 0)
{
    <div class="alert alert-info">No se encontraron licencias.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Empresa</th>
                <th>Maquina</th>
                <th>Tipo</th>
                <th>Plan</th>
                <th>Max Legajos</th>
                <th>Estado</th>
                <th>Vence</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var lic in licencias)
            {
                <tr>
                    <td>@lic.CompanyId</td>
                    <td><small class="text-muted">@lic.MachineId[..Math.Min(12, lic.MachineId.Length)]...</small></td>
                    <td>@lic.LicenseType</td>
                    <td>@lic.Plan</td>
                    <td>@lic.MaxLegajos</td>
                    <td>
                        <span class="badge @GetBadgeClass(lic)">@lic.EstadoDisplay</span>
                    </td>
                    <td>@(lic.ExpiresAt?.ToString("dd/MM/yyyy") ?? lic.TrialEndsAt?.ToString("dd/MM/yyyy") ?? "-")</td>
                    <td>
                        <a href="/licencias/@lic.Id" class="btn btn-sm btn-outline-primary">Ver</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<DigitalPlus.Licencias.Entidades.Licencia>? licencias;
    private string? filtro;

    protected override async Task OnInitializedAsync()
    {
        licencias = await Repo.GetLicenciasAsync();
    }

    private async Task Buscar()
    {
        licencias = await Repo.GetLicenciasAsync(filtro);
    }

    private string GetBadgeClass(DigitalPlus.Licencias.Entidades.Licencia lic) => lic.EstadoDisplay switch
    {
        "Activa" => "bg-success",
        "Trial" => "bg-info",
        "Suspendida" => "bg-warning text-dark",
        "Vencida" or "Trial Vencido" => "bg-danger",
        _ => "bg-secondary"
    };
}
