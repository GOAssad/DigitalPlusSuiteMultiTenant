@page "/"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject DigitalPlus.Licencias.Repositorios.RepositorioLicencias Repo
@inject DigitalPlus.Licencias.Services.MultiTenantProvisioningService MTService

<PageTitle>Dashboard - DigitalPlus Licencias</PageTitle>

<h3 class="mb-4">Dashboard</h3>

@if (stats == null)
{
    <p>Cargando...</p>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-2">
            <div class="card text-bg-primary">
                <div class="card-body text-center">
                    <h2>@stats.TotalLicencias</h2>
                    <small>Total</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-bg-success">
                <div class="card-body text-center">
                    <h2>@stats.Activas</h2>
                    <small>Activas</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-bg-info">
                <div class="card-body text-center">
                    <h2>@stats.Trials</h2>
                    <small>Trials</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-bg-danger">
                <div class="card-body text-center">
                    <h2>@stats.Vencidas</h2>
                    <small>Vencidas</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-bg-warning">
                <div class="card-body text-center">
                    <h2>@stats.Suspendidas</h2>
                    <small>Suspendidas</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-bg-secondary">
                <div class="card-body text-center">
                    <h2>@stats.PorVencer7d</h2>
                    <small>Por vencer (7d)</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">Actividad reciente</div>
                <div class="card-body p-0">
                    @if (logs == null || logs.Count == 0)
                    {
                        <p class="p-3 text-muted">Sin actividad registrada</p>
                    }
                    else
                    {
                        <table class="table table-sm table-striped mb-0">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Accion</th>
                                    <th>Empresa</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in logs)
                                {
                                    <tr>
                                        <td>@log.Timestamp.ToString("dd/MM HH:mm")</td>
                                        <td>@log.Action</td>
                                        <td>@(log.Licencia?.CompanyId ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">Proximas a vencer (30 dias)</div>
                <div class="card-body p-0">
                    @if (porVencer == null || porVencer.Count == 0)
                    {
                        <p class="p-3 text-muted">Ninguna licencia por vencer</p>
                    }
                    else
                    {
                        <table class="table table-sm table-striped mb-0">
                            <thead>
                                <tr>
                                    <th>Empresa</th>
                                    <th>Plan</th>
                                    <th>Vence</th>
                                    <th>Dias</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var lic in porVencer)
                                {
                                    <tr class="@(lic.DiasRestantes <= 7 ? "table-danger" : "")">
                                        <td>@lic.CompanyId</td>
                                        <td>@lic.Plan</td>
                                        <td>@lic.ExpiresAt?.ToString("dd/MM/yyyy")</td>
                                        <td>@lic.DiasRestantes</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>

    @* Solicitudes de clientes *@
    <div class="row g-3 mt-1">
        <div class="col-md-12">
            <div class="card @(solicitudes?.Count > 0 ? "border-warning" : "")">
                <div class="card-header @(solicitudes?.Count > 0 ? "bg-warning bg-opacity-10 text-warning-emphasis" : "")">
                    <i class="bi bi-envelope-exclamation me-1"></i>Solicitudes de clientes
                    @if (solicitudes?.Count > 0)
                    {
                        <span class="badge bg-warning text-dark ms-2">@solicitudes.Count</span>
                    }
                </div>
                <div class="card-body p-0">
                    @if (solicitudes == null || solicitudes.Count == 0)
                    {
                        <p class="p-3 text-muted">Sin solicitudes pendientes</p>
                    }
                    else
                    {
                        <table class="table table-sm table-striped mb-0">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Fecha</th>
                                    <th>Empresa</th>
                                    <th>Tipo</th>
                                    <th>Solicitado por</th>
                                    <th>Motivo</th>
                                    <th>Estado</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in solicitudes)
                                {
                                    <tr>
                                        <td><span class="badge bg-secondary">@s.Id</span></td>
                                        <td>@s.FechaSolicitud.ToString("dd/MM HH:mm")</td>
                                        <td><strong>@s.EmpresaNombre</strong></td>
                                        <td>
                                            @if (s.Tipo == "Limpieza")
                                            {
                                                <span class="badge bg-warning text-dark"><i class="bi bi-eraser me-1"></i>Limpieza</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger"><i class="bi bi-trash me-1"></i>Eliminacion</span>
                                            }
                                        </td>
                                        <td>@s.SolicitadoPor</td>
                                        <td class="text-truncate" style="max-width:300px" title="@s.Motivo">@s.Motivo</td>
                                        <td><span class="badge bg-info">@s.Estado</span></td>
                                        <td>
                                            @if (s.AdminEmpresaId.HasValue)
                                            {
                                                <a href="/empresas/@s.AdminEmpresaId" class="btn btn-outline-primary btn-sm">
                                                    <i class="bi bi-arrow-right"></i>
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DigitalPlus.Licencias.Repositorios.DashboardStats? stats;
    private List<DigitalPlus.Licencias.Entidades.LicenciaLog>? logs;
    private List<DigitalPlus.Licencias.Entidades.Licencia>? porVencer;
    private List<DigitalPlus.Licencias.Services.SolicitudSoporteDto>? solicitudes;

    protected override async Task OnInitializedAsync()
    {
        stats = await Repo.GetDashboardStatsAsync();
        logs = await Repo.GetLogsAsync(cantidad: 10);

        var todas = await Repo.GetLicenciasAsync();
        var now = DateTime.UtcNow;
        porVencer = todas
            .Where(l => l.LicenseType == "active" && l.ExpiresAt.HasValue && l.ExpiresAt > now && l.ExpiresAt < now.AddDays(30))
            .OrderBy(l => l.ExpiresAt)
            .ToList();

        try
        {
            solicitudes = await MTService.GetSolicitudesPendientesAsync();
            // Resolver AdminEmpresaId para links
            if (solicitudes.Count > 0)
            {
                var empresasAdmin = await Repo.GetEmpresasAsync();
                foreach (var s in solicitudes)
                {
                    var admin = empresasAdmin.FirstOrDefault(e => e.CompanyId == s.EmpresaCodigo);
                    if (admin != null) s.AdminEmpresaId = admin.Id;
                }
            }
        }
        catch { solicitudes = []; }
    }
}
